@* =====================================================================
   Pages/Yarns.razor  —  실 장고
   ===================================================================== *@
@page "/yarns"
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage

<div class="page-header">
    <div>
        <h1 class="page-title">🧵 실 장고</h1>
        <p class="page-subtitle">보유중인 실 목록</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenAddModal">+ 실 추가</button>
</div>

@if (_loading)
{
    <div class="loading">불러오는 중...</div>
}
else if (_yarns.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">🧵</div>
        <p>보유한 실이 없어요.<br/>실 정보를 추가해 보세요!</p>
    </div>
}
else
{
    <!-- 검색 -->
    <div class="form-group" style="max-width:320px; margin-bottom:20px;">
        <input class="form-control" @bind-value="_searchText" @bind-value:event="oninput"
               placeholder="🔍 실 이름, 브랜드, 색상으로 검색..." />
    </div>

    <div class="grid-3">
        @foreach (var yarn in FilteredYarns)
        {
            <div class="card">
                <div class="flex-between mb-1">
                    <div style="display:flex; align-items:center; gap:8px;">
                        <span class="color-dot" style="background:@yarn.ColorCode;"></span>
                        <div class="card-title" style="margin-bottom:0;">@yarn.Name</div>
                    </div>
                    @if (yarn.Quantity > 0)
                    {
                        <span class="badge badge-done">x @(yarn.Quantity)</span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(yarn.Brand))
                {
                    <div style="font-size:0.82rem; color:var(--text-mid);">@yarn.Brand</div>
                }
                <div style="font-size:0.82rem; color:var(--text-mid);">@yarn.Color · @yarn.Weight</div>

                @if (!string.IsNullOrEmpty(yarn.Material))
                {
                    <div style="font-size:0.8rem; color:var(--text-light);">@yarn.Material</div>
                }

                <div style="display:flex; gap:12px; font-size:0.78rem; color:var(--text-light); margin:8px 0;">
                    @if (yarn.WeightGram > 0) { <span>@yarn.WeightGram g</span> }
                    @if (yarn.LengthMeter > 0) { <span>@yarn.LengthMeter m</span> }
                    @if (yarn.Price > 0) { <span>₩@yarn.Price.ToString("N0")</span> }
                </div>

                @if (!string.IsNullOrEmpty(yarn.PurchasePlace))
                {
                    <div style="font-size:0.78rem; color:var(--text-light); margin-bottom:10px;">🛒 @yarn.PurchasePlace</div>
                }

                <div class="flex gap-1">
                    <button class="btn btn-secondary btn-sm" @onclick="() => OpenEditModal(yarn)">✏️ 수정</button>
                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteYarn(yarn.Id)">🗑️</button>
                </div>
            </div>
        }
    </div>
}

<!-- 추가/수정 모달 -->
@if (_showModal && _editingYarn != null)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">@(_editingYarn.Id == Guid.Empty ? "실 추가" : "실 수정")</h2>
                <button class="btn btn-ghost btn-sm" @onclick="CloseModal">✕</button>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">실 이름 *</label>
                    <input class="form-control" @bind="_editingYarn.Name" placeholder="예: 러스크" />
                </div>
                <div class="form-group">
                    <label class="form-label">브랜드</label>
                    <input class="form-control" @bind="_editingYarn.Brand" placeholder="예: 솜솜뜨개" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">색상명</label>
                    <input class="form-control" @bind="_editingYarn.Color" placeholder="예: 아이보리" />
                </div>
                <div class="form-group">
                    <label class="form-label">색상 코드</label>
                    <div style="display:flex; gap:8px; align-items:center;">
                        <input type="color" class="form-control" style="width:50px; padding:4px; height:40px;"
                               @bind="_editingYarn.ColorCode" />
                        <input class="form-control" @bind="_editingYarn.ColorCode" placeholder="#ffffff" style="flex:1;" />
                    </div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">굵기</label>
                    <select class="form-control" @bind="_editingYarn.Weight">
                        @foreach (var w in Enum.GetValues<YarnWeight>())
                        { <option value="@w">@w</option> }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">소재</label>
                    <input class="form-control" @bind="_editingYarn.Material" placeholder="예: 울 100%" />
                </div>
            </div>

            <div class="form-row-3">
                <div class="form-group">
                    <label class="form-label">무게 (g/볼)</label>
                    <input type="number" class="form-control" @bind="_editingYarn.WeightGram" min="0" />
                </div>
                <div class="form-group">
                    <label class="form-label">길이 (m/볼)</label>
                    <input type="number" class="form-control" @bind="_editingYarn.LengthMeter" min="0" />
                </div>
                <div class="form-group">
                    <label class="form-label">수량 (볼)</label>
                    <input type="number" class="form-control" @bind="_editingYarn.Quantity" min="0" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">구매처</label>
                    <input class="form-control" @bind="_editingYarn.PurchasePlace" placeholder="예: 솜솜뜨개" />
                </div>
                <div class="form-group">
                    <label class="form-label">가격 (볼당)</label>
                    <input type="number" class="form-control" @bind="_editingYarn.Price" min="0" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">메모</label>
                <textarea class="form-control" rows="2" @bind="_editingYarn.Memo" placeholder="기타 메모"></textarea>
            </div>

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseModal">취소</button>
                <button class="btn btn-primary" @onclick="SaveYarn">저장</button>
            </div>
        </div>
    </div>
}

@code {
    bool _loading = true;
    bool _showModal = false;
    string _searchText = "";
    List<Yarn> _yarns = new();
    Yarn? _editingYarn;

    IEnumerable<Yarn> FilteredYarns => string.IsNullOrWhiteSpace(_searchText)
        ? _yarns
        : _yarns.Where(y =>
            y.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
            y.Brand.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
            y.Color.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
            y.Material.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _yarns = await Storage.GetYarnsAsync();
        _loading = false;
    }

    void OpenAddModal() { _editingYarn = new Yarn { Id = Guid.Empty }; _showModal = true; }
    void OpenEditModal(Yarn yarn) { _editingYarn = yarn; _showModal = true; }
    void CloseModal() { _showModal = false; _editingYarn = null; }

    async Task SaveYarn()
    {
        if (_editingYarn == null || string.IsNullOrWhiteSpace(_editingYarn.Name)) return;
        if (_editingYarn.Id == Guid.Empty) _editingYarn.Id = Guid.NewGuid();
        await Storage.SaveYarnAsync(_editingYarn);
        _yarns = await Storage.GetYarnsAsync();
        CloseModal();
    }

    async Task DeleteYarn(Guid id)
    {
        await Storage.DeleteYarnAsync(id);
        _yarns = await Storage.GetYarnsAsync();
    }
}
