@* =====================================================================
   Pages/Home.razor  —  홈 대시보드
   ===================================================================== *@
@page "/"
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage

<div class="page-header">
    <div>
        <h1 class="page-title">나의 뜨개 공간</h1>
        <p class="page-subtitle">오늘도 즐거운 뜨개질 하세요!</p>
    </div>
</div>

@if (_loading)
{
    <div class="loading">불러오는 중...</div>
}
else
{
    <!-- 요약 카드 4개 -->
    <div class="stats-grid">
        <a href="schedule" class="card" style="text-decoration:none; text-align:center;">
            <div style="font-size:2.2rem; margin-bottom:8px;">📆</div>
            <div style="font-size:2rem; font-weight:700; color:#8a6a08;">@_inProgress</div>
            <div style="color:var(--text-mid); font-size:0.88rem;">진행중인 뜨케줄</div>
        </a>
        <a href="finished" class="card" style="text-decoration:none; text-align:center;">
            <div style="font-size:2.2rem; margin-bottom:8px;">✅</div>
            <div style="font-size:2rem; font-weight:700; color:#267848;">@_finished</div>
            <div style="color:var(--text-mid); font-size:0.88rem;">완성작</div>
        </a>
        <a href="wishlist" class="card" style="text-decoration:none; text-align:center;">
            <div style="font-size:2.2rem; margin-bottom:8px;">💫</div>
            <div style="font-size:2rem; font-weight:700; color:#4e3290;">@_wishlist</div>
            <div style="color:var(--text-mid); font-size:0.88rem;">위시리스트</div>
        </a>
        <a href="yarns" class="card" style="text-decoration:none; text-align:center;">
            <div style="font-size:2.2rem; margin-bottom:8px;">🧵</div>
            <div style="font-size:2rem; font-weight:700; color:var(--text-dark);">@_yarns</div>
            <div style="color:var(--text-mid); font-size:0.88rem;">실 종류</div>
        </a>
    </div>

    <!-- 진행중인 프로젝트 미리보기 -->
    @if (_recentProjects.Count > 0)
    {
        <h2 style="font-family:'DM Sans','Noto Sans KR',sans-serif; font-weight:600; color:var(--text-dark); margin-bottom:16px;">지금 뜨고 있어요</h2>
        <div class="grid-3">
            @foreach (var proj in _recentProjects)
            {
                <div class="card">
                    <div class="card-title">@proj.Title</div>
                    @if (!string.IsNullOrEmpty(proj.PatternName))
                    {
                        <div style="font-size:0.82rem; color:var(--text-mid); margin-bottom:8px;">도안: @proj.PatternName</div>
                    }
                    @if (proj.StartDate.HasValue)
                    {
                        <div style="font-size:0.82rem; color:var(--text-light);">시작일: @proj.StartDate.Value.ToString("yyyy.MM.dd")</div>
                    }
                    <div class="mt-2">
                        <a href="schedule" class="btn btn-secondary btn-sm">자세히 보기</a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card" style="text-align:center; padding:40px;">
            <div style="font-size:2.5rem; margin-bottom:12px;">📆</div>
            <p style="color:var(--text-mid); margin-bottom:16px;">아직 진행중인 프로젝트가 없어요.</p>
            <a href="schedule" class="btn btn-primary">첫 뜨케줄 만들기</a>
        </div>
    }
}

@code {
    bool _loading = true;
    int _inProgress, _finished, _wishlist, _yarns;
    List<KnitProject> _recentProjects = new();

    protected override async Task OnInitializedAsync()
    {
        var projects = await Storage.GetProjectsAsync();
        _inProgress = projects.Count(p => p.Status == ProjectStatus.진행중);
        _finished   = projects.Count(p => p.Status == ProjectStatus.완료);
        _wishlist   = projects.Count(p => p.Status == ProjectStatus.위시리스트);
        _recentProjects = projects
            .Where(p => p.Status == ProjectStatus.진행중)
            .OrderByDescending(p => p.StartDate)
            .Take(3)
            .ToList();

        var yarns = await Storage.GetYarnsAsync();
        _yarns = yarns.Count;

        _loading = false;
    }
}
