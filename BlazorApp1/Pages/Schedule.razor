@page "/projects"
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="page-header">
    <div>
        <h1 class="page-title">🐙 문어발</h1>
        <p class="page-subtitle">진행중 · 일시중단 프로젝트</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenAddModal">+ 새 프로젝트</button>
</div>

@if (_loading)
{
    <div class="loading">불러오는 중...</div>
}
else if (_projects.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">📆</div>
        <p>진행중인 프로젝트가 없어요.<br />새 프로젝트를 추가해 보세요!</p>
    </div>
}
else
{
    <!-- 컨트롤 바: 필터 + 정렬 + 뷰 전환 -->
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; gap:8px; flex-wrap:wrap;">
        <!-- 왼쪽: 필터 + 정렬 -->
        <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">

            <!-- 상태 필터 -->
            <div style="display:flex; gap:4px;">
                <button class="btn btn-sm @(_statusFilter == "all" ? "btn-sage" : "btn-ghost")"
                        @onclick='async () => { _statusFilter = "all"; await JS.InvokeVoidAsync("localStorage.setItem", "sched_filter", _statusFilter); }'>전체</button>
                <button class="btn btn-sm @(_statusFilter == "진행중" ? "btn-sage" : "btn-ghost")"
                        @onclick='async () => { _statusFilter = "진행중"; await JS.InvokeVoidAsync("localStorage.setItem", "sched_filter", _statusFilter); }'>진행중</button>
                <button class="btn btn-sm @(_statusFilter == "일시중단" ? "btn-sage" : "btn-ghost")"
                        @onclick='async () => { _statusFilter = "일시중단"; await JS.InvokeVoidAsync("localStorage.setItem", "sched_filter", _statusFilter); }'>중단</button>
            </div>

            <!-- 정렬 기준 + 오름/내림 묶음 -->
            <div style="display:flex; align-items:center; gap:4px;">
                <span style="font-size:0.82rem; color:var(--text-mid);">정렬</span>
                <select class="form-control" style="width:auto; padding:5px 10px; font-size:0.75rem;" @bind="_sortField"
                            @bind:after="SaveSchedulePrefs">
                    <option value="created">등록일</option>
                    <option value="start">시작일</option>
                    <option value="updated">수정일</option>
                    <option value="title">이름순</option>
                </select>

                <!-- 오름/내림차순 -->
                <button class="btn btn-sm btn-ghost" @onclick="ToggleSortDir" title="@(_sortAsc ? "오름차순" : "내림차순")">
                    @(_sortAsc ? "↑ 오름" : "↓ 내림")
                </button>
            </div>
        </div>

        <!-- 오른쪽: 뷰 전환 -->
        <div style="display:flex; gap:4px;">
            <button class="btn btn-sm @(_isListView ? "btn-ghost" : "btn-sage")" @onclick='async () => { _isListView = false; await JS.InvokeVoidAsync("localStorage.setItem", "sched_listview", "false"); }' title="카드형">⊞</button>
            <button class="btn btn-sm @(_isListView ? "btn-sage" : "btn-ghost")" @onclick='async () => { _isListView = true; await JS.InvokeVoidAsync("localStorage.setItem", "sched_listview", "true"); }' title="리스트형">☰</button>
        </div>
    </div>

    @if (!FilteredSortedProjects.Any())
    {
        <div class="empty-state" style="padding:40px 0;">
            <p style="color:var(--text-mid);">해당 상태의 프로젝트가 없어요.</p>
        </div>
    }
    else if (!_isListView)
    {
        <!-- 카드형 -->
        <div class="grid-2">
            @foreach (var proj in FilteredSortedProjects)
            {
                <div class="card" style="cursor:pointer;" @onclick="() => GoToDetail(proj.Id)">
                    @if (proj.Photos.Count > 0)
                    {
                        <img src="@proj.Photos[0].Base64Data" class="photo-thumb"
                             style="width:100%; height:160px; object-fit:cover; border-radius:var(--radius-sm); margin-bottom:12px;"
                             alt="프로젝트 사진" />
                    }

                    <div class="flex-between mb-1">
                        <div class="card-title" style="margin-bottom:0;">@proj.Title</div>
                        @if (proj.Status == ProjectStatus.일시중단)
                        {
                            <span class="badge" style="background:#fef0f0; color:#c0392b; border:1px solid #f5c0c0;">일시중단</span>
                        }
                        else
                        {
                            <span class="badge" style="background:#fffbe6; color:#b58a00; border:1px solid #f5d97a;">진행중</span>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(proj.PatternName))
                    {
                        <div style="font-size:0.82rem; color:var(--text-mid); margin-bottom:4px;">📋 @proj.PatternName</div>
                    }

                    @if (!string.IsNullOrEmpty(proj.PatternMemo))
                    {
                        <p style="font-size:0.85rem; color:var(--text-mid); margin-bottom:6px; white-space:pre-wrap; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">@proj.PatternMemo</p>
                    }

                    <div style="display:flex; gap:12px; font-size:0.8rem; color:var(--text-light); margin-bottom:14px;">
                        @if (proj.StartDate.HasValue)
                        {
                            <span>시작 @proj.StartDate.Value.ToString("yy.MM.dd")</span>
                        }
                        @if (proj.EndDate.HasValue)
                        {
                            <span>→ @proj.EndDate.Value.ToString("yy.MM.dd") 목표</span>
                        }
                    </div>

                    <div style="display:flex; gap:8px; flex-wrap:wrap;" @onclick:stopPropagation="true">
                        <button class="btn btn-secondary btn-sm" @onclick="() => OpenEditModal(proj)">✏️ 수정</button>
                        @if (proj.Status == ProjectStatus.진행중)
                        {
                            <button class="btn btn-sm" style="background:#ffffff; color:#666; border:1px solid #ddd;"
                                    @onclick="() => ToggleSuspend(proj)">⏸️ 일시중단</button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-ghost"
                                    @onclick="() => ToggleSuspend(proj)">▶️ 재개</button>
                        }
                        <button class="btn btn-sm btn-sage" @onclick="() => CompleteProject(proj.Id)">✅ 완료</button>
                        <button class="btn btn-danger btn-sm" @onclick='() => Confirm("이 프로젝트를 삭제하면 복구할 수 없어요.", async () => await DeleteProject(proj.Id))'>🗑️</button>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- 리스트형 -->
        <div style="display:flex; flex-direction:column; gap:8px;">
            @foreach (var proj in FilteredSortedProjects)
            {
                <div class="card" style="cursor:pointer; display:flex; align-items:center; gap:14px; padding:12px 16px;"
                     @onclick="() => GoToDetail(proj.Id)">
                    @if (proj.Photos.Count > 0)
                    {
                        <img src="@proj.Photos[0].Base64Data"
                             style="width:52px; height:52px; object-fit:cover; border-radius:var(--radius-sm); border:1px solid var(--border); flex-shrink:0;"
                             alt="사진" />
                    }
                    else
                    {
                        <div style="width:52px; height:52px; background:var(--ivory-dark); border-radius:var(--radius-sm); display:flex; align-items:center; justify-content:center; font-size:1.4rem; flex-shrink:0;">🧶</div>
                    }

                    <div style="flex:1; min-width:0;">
                        <div style="display:flex; align-items:center; gap:8px; margin-bottom:2px;">
                            <span style="font-weight:700; font-size:0.95rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@proj.Title</span>
                            @if (proj.Status == ProjectStatus.일시중단)
                            {
                                <span class="badge" style="background:#fef0f0; color:#c0392b; border:1px solid #f5c0c0; flex-shrink:0;">⏸️ 일시중단</span>
                            }
                        </div>
                        <div style="font-size:0.78rem; color:var(--text-mid); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                            @if (!string.IsNullOrEmpty(proj.PatternName)) { <span>@proj.PatternName</span> }
                            @if (proj.StartDate.HasValue) { <span style="margin-left:8px;">· @proj.StartDate.Value.ToString("yy.MM.dd")▶️ 시작</span> }
                        </div>
                    </div>

                    <div style="display:flex; gap:6px; flex-shrink:0;" @onclick:stopPropagation="true">
                        <button class="btn btn-secondary btn-sm" @onclick="() => OpenEditModal(proj)">✏️</button>
                        @if (proj.Status == ProjectStatus.진행중)
                        {
                            <button class="btn btn-sm" style="background:#ffffff; color:#666; border:1px solid #ddd; padding:4px 8px;"
                                    @onclick="() => ToggleSuspend(proj)">⏸</button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-ghost" @onclick="() => ToggleSuspend(proj)">▶</button>
                        }
                        <button class="btn btn-sage btn-sm" @onclick="() => CompleteProject(proj.Id)">✅</button>
                        <button class="btn btn-danger btn-sm" @onclick='() => Confirm("이 프로젝트를 삭제하면 복구할 수 없어요.", async () => await DeleteProject(proj.Id))'>🗑️</button>
                    </div>
                </div>
            }
        </div>
    }
}

<!-- 완성작 미리보기 팝업 -->
@if (_showCompletedPopup && _completedPreview != null)
{
    <div class="modal-backdrop">
        <div class="modal" style="max-width:740px;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">@_completedPreview.Title</h2>
                <button class="btn btn-ghost btn-sm" @onclick="CloseCompletedPopup">✕</button>
            </div>

            <!-- 사진 갤러리 -->
            @if (_completedPreview.Photos.Count > 0)
            {
                <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px;">
                    @foreach (var photo in _completedPreview.Photos)
                    {
                        <img src="@photo.Base64Data"
                             style="width:130px; height:130px; object-fit:cover; border-radius:var(--radius-sm); border:1px solid var(--border);"
                             alt="과정 사진" />
                    }
                </div>
            }

            <!-- 날짜 바 -->
            <div style="margin-bottom:14px; padding:12px; background:var(--ivory-dark); border-radius:var(--radius-sm);">
                @if (!_popupEditingBasicInfo)
                {
                    <div style="display:flex; gap:16px; flex-wrap:wrap; align-items:center;">
                        @if (_completedPreview.StartDate.HasValue)
                        {
                            <div style="text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:2px;">시작일</div>
                                <div style="font-size:0.9rem; font-weight:600;">@_completedPreview.StartDate.Value.ToString("yyyy.MM.dd")</div>
                            </div>
                        }
                        @if (_completedPreview.EndDate.HasValue)
                        {
                            <div style="text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:2px;">완성일</div>
                                <div style="font-size:0.9rem; font-weight:600;">@_completedPreview.EndDate.Value.ToString("yyyy.MM.dd")</div>
                            </div>
                        }
                        @if (_completedPreview.StartDate.HasValue && _completedPreview.EndDate.HasValue)
                        {
                            var days = (_completedPreview.EndDate.Value - _completedPreview.StartDate.Value).Days;
                            <div style="text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:2px;">소요일</div>
                                <div style="font-size:0.9rem; font-weight:600; color:#8a6a08;">@days 일</div>
                            </div>
                        }
                        @{
                            var popMin = _completedPreview.Sessions
                                .Where(s => s.EndTime.HasValue)
                                .Sum(s => (int)(s.EndTime!.Value - s.StartTime).TotalMinutes);
                        }
                        @if (popMin > 0)
                        {
                            var ph = popMin / 60; var pm = popMin % 60;
                            <div style="text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:2px;">누적 시간</div>
                                <div style="font-size:0.9rem; font-weight:600; color:#267848;">@(ph > 0 ? $"{ph}시간 " : "")@(pm > 0 ? $"{pm}분" : "")</div>
                            </div>
                        }
                        else
                        {
                            <div style="text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:2px;">누적 시간</div>
                                <div style="font-size:0.82rem; color:var(--text-light);">기록 없음</div>
                            </div>
                        }
                        <button class="btn btn-ghost btn-sm" style="font-size:0.72rem; margin-left:auto;"
                                @onclick="() => _popupEditingBasicInfo = true">✏️ 수정</button>
                    </div>
                }
                else
                {
                    <div class="form-row" style="margin-bottom:8px;">
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">시작일</label>
                            <input type="date" class="form-control"
                                   value="@_completedPreview.StartDate?.ToString("yyyy-MM-dd")"
                                   @onchange="e => _completedPreview.StartDate = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!)" />
                        </div>
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">완성일</label>
                            <input type="date" class="form-control"
                                   value="@_completedPreview.EndDate?.ToString("yyyy-MM-dd")"
                                   @onchange="e => _completedPreview.EndDate = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!)" />
                        </div>
                    </div>
                    <div style="display:flex; gap:8px;">
                        <button class="btn btn-primary btn-sm" @onclick="SavePopBasicInfo">저장</button>
                        <button class="btn btn-ghost btn-sm" @onclick="() => _popupEditingBasicInfo = false">취소</button>
                    </div>
                }
            </div>

            <!-- 도안 정보 -->
            @if (!string.IsNullOrEmpty(_completedPreview.PatternName))
            {
                <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                    <div class="form-label" style="margin-bottom:4px;">📋 도안</div>
                    <div style="font-size:0.92rem;">@_completedPreview.PatternName</div>
                    @if (!string.IsNullOrEmpty(_completedPreview.PatternSource))
                    {
                        <div style="font-size:0.82rem; color:var(--text-mid);">출처: @_completedPreview.PatternSource</div>
                    }
                    @if (!string.IsNullOrEmpty(_completedPreview.PatternMemo))
                    {
                        <div style="font-size:0.82rem; color:var(--text-mid); margin-top:2px; white-space:pre-wrap;">@_completedPreview.PatternMemo</div>
                    }
                </div>
            }

            <!-- 사용 실 -->
            @{
                var popYarns = _completedPreview.YarnUsages
                    .Select(u => (u, _yarns.Find(y => y.Id == u.YarnId)))
                    .Where(x => x.Item2 != null)
                    .Select(x => (x.u, x.Item2!))
                    .ToList();
            }
            @if (popYarns.Any())
            {
                <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                    <div class="form-label" style="margin-bottom:6px;">🧵 사용 실</div>
                    @foreach (var (usage, yarn) in popYarns)
                    {
                        <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px; font-size:0.88rem;">
                            <span class="color-dot" style="background:@yarn.ColorCode; flex-shrink:0;"></span>
                            <span>@yarn.Brand @yarn.Name (@yarn.Color)</span>
                            @if (usage.BallsUsed > 0)
                            {
                                <span style="color:var(--text-light); font-size:0.8rem;">@usage.BallsUsed 볼</span>
                            }
                        </div>
                    }
                </div>
            }

            <!-- 사용 바늘 -->
            @{
                var popTools = _tools.Where(t => _completedPreview.ToolIds.Contains(t.Id)).ToList();
            }
            @if (popTools.Any() || !string.IsNullOrEmpty(_completedPreview.NeedleNote))
            {
                <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                    <div class="form-label" style="margin-bottom:6px;">⚒️ 사용 바늘</div>
                    <div style="display:flex; flex-wrap:wrap; gap:6px;">
                        @foreach (var tool in popTools)
                        {
                            <span style="background:var(--ivory-dark); border-radius:4px; padding:3px 8px; font-size:0.8rem;">@tool.NeedleType @tool.SizeDisplay</span>
                        }
                        @if (!string.IsNullOrEmpty(_completedPreview.NeedleNote))
                        {
                            <span style="background:var(--ivory-dark); border-radius:4px; padding:3px 8px; font-size:0.8rem;">@_completedPreview.NeedleNote</span>
                        }
                    </div>
                </div>
            }

            <!-- 스와치 -->
            @{
                var popSwatches = _allSwatches.Where(s => s.ProjectId == _completedPreview.Id).ToList();
            }
            @if (popSwatches.Any())
            {
                <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                    <div class="form-label" style="margin-bottom:6px;">📐 스와치</div>
                    @foreach (var s in popSwatches)
                    {
                        <div style="background:var(--ivory-dark); border-radius:var(--radius-sm); padding:10px 12px; margin-bottom:6px; font-size:0.84rem;">
                            <div style="font-weight:600; margin-bottom:6px;">@(string.IsNullOrEmpty(s.Name) ? "스와치" : s.Name)
                                @if (!string.IsNullOrEmpty(s.Stitch))
                                {
                                    <span style="font-weight:400; color:var(--text-mid); margin-left:6px;">(@s.Stitch)</span>
                                }
                                @if (s.NeedleSizeMm > 0)
                                {
                                    <span style="font-weight:400; color:var(--text-mid); margin-left:6px;">@(s.NeedleSizeMm)mm</span>
                                }
                            </div>
                            <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
                                <div>
                                    <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:3px;">세탁 전</div>
                                    @if (s.PreWashStitches > 0 || s.PreWashRows > 0)
                                    {
                                        <div>@(s.PreWashStitches)코 × @(s.PreWashRows)단</div>
                                    }
                                    @if (s.PreWashWidthCm > 0 || s.PreWashHeightCm > 0)
                                    {
                                        <div style="color:var(--text-mid);">@(s.PreWashWidthCm)cm × @(s.PreWashHeightCm)cm</div>
                                    }
                                </div>
                                @if (s.PostWashStitches > 0 || s.PostWashWidthCm > 0)
                                {
                                    <div>
                                        <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:3px;">세탁 후</div>
                                        @if (s.PostWashStitches > 0 || s.PostWashRows > 0)
                                        {
                                            <div>@(s.PostWashStitches)코 × @(s.PostWashRows)단</div>
                                        }
                                        @if (s.PostWashWidthCm > 0 || s.PostWashHeightCm > 0)
                                        {
                                            <div style="color:var(--text-mid);">@(s.PostWashWidthCm)cm × @(s.PostWashHeightCm)cm</div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- 완성 치수 -->
            <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px;">
                    <div class="form-label" style="margin-bottom:0;">📏 완성 치수</div>
                    @if (!_popupEditingMeasurements)
                    {
                        <button class="btn btn-ghost btn-sm" style="font-size:0.75rem;" @onclick="() => { LoadPopMeasures(); _popupEditingMeasurements = true; }">✏️ 입력</button>
                    }
                </div>
                @if (!_popupEditingMeasurements)
                {
                    @if (_popMeasures.Any(m => !string.IsNullOrEmpty(m.Before) || !string.IsNullOrEmpty(m.After)))
                    {
                        <div style="border:0.5px solid var(--border); border-radius:var(--radius-sm); overflow:hidden; font-size:0.82rem;">
                            <div style="display:grid; grid-template-columns:120px 1fr 1fr; background:#f8f8f8; border-bottom:0.5px solid var(--border);">
                                <div style="padding:6px 10px; color:var(--text-mid); font-weight:500;">항목</div>
                                <div style="padding:6px 10px; color:var(--text-mid); font-weight:500; border-left:0.5px solid var(--border);">세탁 전</div>
                                <div style="padding:6px 10px; color:var(--text-mid); font-weight:500; border-left:0.5px solid var(--border);">세탁 후</div>
                            </div>
                            @foreach (var m in _popMeasures)
                            {
                                @if (!string.IsNullOrEmpty(m.Before) || !string.IsNullOrEmpty(m.After))
                                {
                                    <div style="display:grid; grid-template-columns:120px 1fr 1fr; border-top:0.5px solid var(--border);">
                                        <div style="padding:6px 10px; color:var(--text-dark);">@m.Label</div>
                                        <div style="padding:6px 10px; color:var(--text-mid); border-left:0.5px solid var(--border);">@(string.IsNullOrEmpty(m.Before) ? "-" : m.Before + "cm")</div>
                                        <div style="padding:6px 10px; color:var(--text-mid); border-left:0.5px solid var(--border);">@(string.IsNullOrEmpty(m.After) ? "-" : m.After + "cm")</div>
                                    </div>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <p style="font-size:0.82rem; color:var(--text-light);">치수 정보가 없어요.</p>
                    }
                }
                else
                {
                    <div style="border:0.5px solid var(--border); border-radius:var(--radius-sm); overflow:hidden; font-size:0.82rem; margin-bottom:8px;">
                        <div style="display:grid; grid-template-columns:120px 1fr 1fr; background:#f8f8f8; border-bottom:0.5px solid var(--border);">
                            <div style="padding:6px 10px; color:var(--text-mid); font-weight:500;">항목</div>
                            <div style="padding:6px 10px; color:var(--text-mid); font-weight:500; border-left:0.5px solid var(--border);">세탁 전 (cm)</div>
                            <div style="padding:6px 10px; color:var(--text-mid); font-weight:500; border-left:0.5px solid var(--border);">세탁 후 (cm)</div>
                        </div>
                        @foreach (var m in _popMeasures)
                        {
                            <div style="display:grid; grid-template-columns:120px 1fr 1fr; border-top:0.5px solid var(--border);">
                                <div style="padding:4px 6px; display:flex; align-items:center; gap:4px;">
                                    @if (m.IsCustom)
                                    {
                                        <input class="form-control" style="border:none; padding:3px 6px; font-size:0.82rem; width:100%;"
                                               @bind="m.Label" placeholder="항목명" />
                                        <button class="btn btn-danger btn-sm" style="padding:1px 5px; font-size:0.7rem; flex-shrink:0;" @onclick="() => _popMeasures.Remove(m)">✕</button>
                                    }
                                    else
                                    {
                                        <span style="padding:3px 4px; color:var(--text-dark);">@m.Label</span>
                                    }
                                </div>
                                <div style="border-left:0.5px solid var(--border); padding:2px 6px;">
                                    <input class="form-control" style="border:none; padding:4px 6px; font-size:0.82rem;"
                                           @bind="m.Before" placeholder="-" />
                                </div>
                                <div style="border-left:0.5px solid var(--border); padding:2px 6px;">
                                    <input class="form-control" style="border:none; padding:4px 6px; font-size:0.82rem;"
                                           @bind="m.After" placeholder="-" />
                                </div>
                            </div>
                        }
                    </div>
                    <div style="display:flex; gap:8px; margin-bottom:8px;">
                        <button class="btn btn-ghost btn-sm" @onclick="() => _popMeasures.Add(new PopMeasureItem { IsCustom = true })">+ 항목 추가</button>
                    </div>
                    <div style="display:flex; gap:8px;">
                        <button class="btn btn-primary btn-sm" @onclick="SavePopMeasurements">저장</button>
                        <button class="btn btn-ghost btn-sm" @onclick="CancelPopMeasurements">취소</button>
                    </div>
                }
            </div>

            <!-- 메모 -->
            @if (!string.IsNullOrEmpty(_completedPreview.Memo))
            {
                <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                    <div class="form-label" style="margin-bottom:4px;">📝 메모</div>
                    <p style="white-space:pre-wrap; font-size:0.9rem; color:var(--text-mid);">@_completedPreview.Memo</p>
                </div>
            }

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseCompletedPopup">닫기</button>
                <button class="btn btn-primary" @onclick="GoToFinished">완성작 목록 보기 →</button>
            </div>
        </div>
    </div>
}

@if (_showModal)
{
    <div class="modal-backdrop">
        <div class="modal" style="max-width:680px;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">@(_editingProject?.Id == Guid.Empty ? "새 프로젝트" : "프로젝트 수정")</h2>
                <button class="btn btn-ghost btn-sm" @onclick="CloseModal">✕</button>
            </div>

            @if (_editingProject != null)
            {
                @* ── 도안명 / 출처 ── *@
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">도안명 *</label>
                        <input class="form-control" @bind="_editingProject.PatternName" placeholder="예: 마시멜로 후드 집업" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">도안 출처</label>
                        <input class="form-control" @bind="_editingProject.PatternSource" placeholder="작가명, 책 이름, URL 등" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">도안 메모</label>
                    <textarea class="form-control" rows="2" @bind="_editingProject.PatternMemo" placeholder="사이즈, 수정 사항 등"></textarea>
                </div>

                @* ── 날짜 ── *@
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">시작일</label>
                        <input type="date" class="form-control"
                               value="@_editingProject.StartDate?.ToString("yyyy-MM-dd")"
                               @onchange="e => _editingProject.StartDate = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!)" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">@(_editingProject!.Status == ProjectStatus.완료 ? "완성일" : "목표 완성일")</label>
                        <input type="date" class="form-control"
                               value="@_editingProject.EndDate?.ToString("yyyy-MM-dd")"
                               @onchange="e => _editingProject.EndDate = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!)" />
                    </div>
                </div>

                @* ── 사용 바늘 ── *@
                <div class="form-group">
                    <label class="form-label">⚒️ 사용 바늘</label>
                    <div style="display:flex; gap:6px; margin-bottom:6px;">
                        <button type="button" class="btn btn-sm @(_editingProject.NeedleType == NeedleType.대바늘 ? "btn-sage" : "btn-ghost")"
                                @onclick='() => _editingProject.NeedleType = (_editingProject.NeedleType == NeedleType.대바늘 ? (NeedleType?)null : NeedleType.대바늘)'>대바늘</button>
                        <button type="button" class="btn btn-sm @(_editingProject.NeedleType == NeedleType.코바늘 ? "btn-sage" : "btn-ghost")"
                                @onclick='() => _editingProject.NeedleType = (_editingProject.NeedleType == NeedleType.코바늘 ? (NeedleType?)null : NeedleType.코바늘)'>코바늘</button>
                    </div>
                    <input class="form-control" @bind="_editingProject.NeedleNote" placeholder="예: 4mm 대바늘 80cm줄, 3.5mm 코바늘" />
                </div>

                @* ── 사용 실 ── *@
                <div class="form-group">
                    <label class="form-label">🧵 사용 실</label>
                    <select class="form-control" style="margin-bottom:8px;" @onchange="OnAddYarn">
                        <option value="">+ 실 추가</option>
                        @foreach (var y in _yarns)
                        {
                            <option value="@y.Id">@y.Brand @y.Name (@y.Color)</option>
                        }
                    </select>
                    @foreach (var usage in _editingProject.YarnUsages)
                    {
                        var yarn = _yarns.Find(y => y.Id == usage.YarnId);
                        <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px; padding:6px 10px;
                                    border-radius:9px; background:#f8f8f8; border:1px solid var(--border);">
                            @if (yarn != null)
                            {
                                <span class="color-dot" style="background:@yarn.ColorCode; flex-shrink:0;"></span>
                                <span style="flex:1; font-size:0.88rem;">@yarn.Brand @yarn.Name (@yarn.Color)</span>
                            }
                            <input class="form-control" type="number" min="1" style="width:64px;"
                                   value="@usage.BallsUsed"
                                   @onchange="e => usage.BallsUsed = int.TryParse(e.Value?.ToString(), out var n) ? n : 1" />
                            <span style="font-size:0.82rem; color:var(--text-mid);">볼</span>
                            <button class="btn btn-danger btn-sm" @onclick="() => _editingProject.YarnUsages.Remove(usage)">✕</button>
                        </div>
                    }
                </div>

                @* ── 스와치 연결 ── *@
                <div class="form-group">
                    <label class="form-label">📐 스와치</label>
                    @if (!_allSwatches.Any())
                    {
                        <p style="font-size:0.82rem; color:var(--text-light);">스와치 페이지에서 먼저 스와치를 만들어주세요.</p>
                    }
                    else
                    {
                        <select class="form-control" @onchange="OnScheduleSwatchSelect">
                            <option value="">+ 스와치 연결</option>
                            @foreach (var s in _allSwatches)
                            {
                                var sy = _yarns.Find(y => y.Id == s.YarnId);
                                bool isLinked = s.ProjectId == _editingProject!.Id && _editingProject.Id != Guid.Empty;
                                <option value="@s.Id" disabled="@isLinked">
                                    @(string.IsNullOrEmpty(s.Name) ? "이름 없는 스와치" : s.Name)
                                    @(sy != null ? $" ({sy.Brand} {sy.Name})" : "")
                                </option>
                            }
                        </select>
                        @if (_allSwatches.Any(s => s.ProjectId == _editingProject!.Id && _editingProject.Id != Guid.Empty))
                        {
                            <div style="margin-top:8px;">
                                @foreach (var s in _allSwatches.Where(s => s.ProjectId == _editingProject!.Id && _editingProject.Id != Guid.Empty))
                                {
                                    var sy = _yarns.Find(y => y.Id == s.YarnId);
                                    <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px; padding:8px 12px;
                                                border-radius:var(--radius-sm); background:#f0faf4; border:1px solid #b8e0c8;">
                                        <div style="flex:1; min-width:0;">
                                            <div style="font-size:0.88rem; font-weight:600;">
                                                @(string.IsNullOrEmpty(s.Name) ? "이름 없는 스와치" : s.Name)
                                                @if (!string.IsNullOrEmpty(s.Stitch))
                                                {
                                                    <span style="font-weight:400; color:var(--text-mid); margin-left:6px;">(@s.Stitch)</span>
                                                }
                                                @if (s.NeedleSizeMm > 0)
                                                {
                                                    <span style="font-weight:400; color:var(--text-mid); margin-left:4px;">@(s.NeedleSizeMm)mm</span>
                                                }
                                            </div>
                                            @if (sy != null)
                                            {
                                                <div style="font-size:0.75rem; color:var(--text-light); display:flex; align-items:center; gap:4px; margin-top:3px;">
                                                    <span class="color-dot" style="background:@sy.ColorCode; width:8px; height:8px;"></span>
                                                    @sy.Brand @sy.Name
                                                </div>
                                            }
                                            <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:6px; font-size:0.8rem;">
                                                <div>
                                                    <div style="font-size:0.7rem; color:var(--text-light);">세탁 전</div>
                                                    @if (s.PreWashStitches > 0 || s.PreWashRows > 0)
                                                    {
                                                        <div>@(s.PreWashStitches)코 × @(s.PreWashRows)단</div>
                                                    }
                                                    @if (s.PreWashWidthCm > 0 || s.PreWashHeightCm > 0)
                                                    {
                                                        <div style="color:var(--text-mid);">@(s.PreWashWidthCm)cm × @(s.PreWashHeightCm)cm</div>
                                                    }
                                                </div>
                                                @if (s.PostWashStitches > 0 || s.PostWashWidthCm > 0)
                                                {
                                                    <div>
                                                        <div style="font-size:0.7rem; color:var(--text-light);">세탁 후</div>
                                                        @if (s.PostWashStitches > 0 || s.PostWashRows > 0)
                                                        {
                                                            <div>@(s.PostWashStitches)코 × @(s.PostWashRows)단</div>
                                                        }
                                                        @if (s.PostWashWidthCm > 0 || s.PostWashHeightCm > 0)
                                                        {
                                                            <div style="color:var(--text-mid);">@(s.PostWashWidthCm)cm × @(s.PostWashHeightCm)cm</div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                        <button class="btn btn-danger btn-sm" style="padding:2px 8px; flex-shrink:0;" @onclick="() => s.ProjectId = null">✕</button>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>

                @* ── 카테고리 + 캘린더 색상 ── *@
                <div class="form-group" style="margin-top:28px;">
                    <label class="form-label">카테고리</label>
                    <div style="display:flex; gap:6px; flex-wrap:wrap; margin-bottom:10px;">
                        @foreach (var cat in Enum.GetValues<ProjectCategory>().Where(c => c != ProjectCategory.미분류))
                        {
                            <button type="button"
                                    class="btn btn-sm @(_editingProject.Category == cat ? "btn-sage" : "btn-ghost")"
                                    @onclick="() => _editingProject.Category = (_editingProject.Category == cat ? ProjectCategory.미분류 : cat)">
                                @cat
                            </button>
                        }
                    </div>
                    <label class="form-label" style="margin-top:20px; display:block;">캘린더 색상</label>
                    <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
                        @foreach (var hex in _colorOptions)
                        {
                            bool selected = _editingProject.ColorCode == hex;
                            string dotBorder    = selected ? "3px solid #333"       : "2px solid transparent";
                            string dotShadow    = selected ? "0 0 0 2px #fff inset" : "none";
                            string dotTransform = selected ? "scale(1.2)"           : "scale(1)";
                            <div @onclick="() => _editingProject.ColorCode = hex"
                                 style="width:28px; height:28px; border-radius:50%; background:@hex; cursor:pointer;
                                        border:@dotBorder; box-shadow:@dotShadow; transform:@dotTransform;">
                            </div>
                        }
                        <input type="color"
                               value="@(string.IsNullOrEmpty(_editingProject.ColorCode) ? "#b8e0c8" : _editingProject.ColorCode)"
                               @onchange="e => _editingProject.ColorCode = e.Value?.ToString() ?? string.Empty"
                               style="width:28px; height:28px; border-radius:50%; border:2px solid var(--border);
                                      padding:0; cursor:pointer; overflow:hidden;"
                               title="직접 색상 선택" />
                    </div>
                </div>

                @* ── 메모 ── *@
                <div class="form-group" style="margin-top:28px;">
                    <label class="form-label">📝 메모</label>
                    <textarea class="form-control" rows="2" @bind="_editingProject.Memo" placeholder="기타 메모"></textarea>
                </div>
            }

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseModal">취소</button>
                <button class="btn btn-primary" @onclick="SaveProject">저장</button>
            </div>
        </div>
    </div>
}

<!-- 삭제 확인 모달 -->
@if (_showConfirm)
{
    <div class="modal-backdrop modal-confirm" style="z-index:9999;">
        <div class="modal" style="max-width:360px; text-align:center;" @onclick:stopPropagation="true">
            <div style="font-size:2rem; margin-bottom:12px;">🗑️</div>
            <div style="font-size:1rem; font-weight:600; margin-bottom:8px; color:var(--text-dark);">정말 삭제할까요?</div>
            <div style="font-size:0.88rem; color:var(--text-mid); margin-bottom:20px;">@_confirmMsg</div>
            <div style="display:flex; gap:10px; justify-content:center;">
                <button class="btn btn-ghost" @onclick="() => _showConfirm = false">취소</button>
                <button class="btn btn-danger" @onclick="ExecuteConfirm">삭제</button>
            </div>
        </div>
    </div>
}

@code {
    bool _showConfirm = false;
    string _confirmMsg = "";
    Func<Task>? _confirmAction;

    void Confirm(string msg, Func<Task> action)
    {
        _confirmMsg    = msg;
        _confirmAction = action;
        _showConfirm   = true;
    }

    async Task ExecuteConfirm()
    {
        _showConfirm = false;
        if (_confirmAction != null)
            await _confirmAction();
        _confirmAction = null;
    }

    bool _loading = true;
    bool _isListView = false;
    bool _showCompletedPopup = false;
    List<Guid>? _swatchSnapshot;
    KnitProject? _completedPreview;
    bool _popupEditingBasicInfo = false;
    bool _popupEditingMeasurements = false;

    class PopMeasureItem
    {
        public string Label { get; set; } = "";
        public string Before { get; set; } = "";
        public string After  { get; set; } = "";
        public bool IsCustom { get; set; } = false;
    }
    static readonly string[] _popDefaultLabels = { "가슴둘레", "총장", "소매 길이", "소매 단면" };
    List<PopMeasureItem> _popMeasures = new();
    string _sortField = "created";
    bool _sortAsc = false;          // false = 내림차순(기본), true = 오름차순
    string _statusFilter = "all";   // "all" | "진행중" | "일시중단"
    List<KnitProject> _projects = new();

    // 컬러피커 프리셋
    static readonly string[] _colorOptions = new[]
    {
        "#f2b8c6", "#f7e4a0", "#b8e0c8", "#c8b8e8", "#b8d8f0",
        "#ffb74d", "#a5d6a7", "#ef9a9a", "#90caf9", "#ce93d8"
    };

    IEnumerable<KnitProject> FilteredSortedProjects
    {
        get
        {
            // 1) 상태 필터
            var filtered = _statusFilter switch
            {
                "진행중"   => _projects.Where(p => p.Status == ProjectStatus.진행중),
                "일시중단" => _projects.Where(p => p.Status == ProjectStatus.일시중단),
                _          => _projects.AsEnumerable(),
            };

            // 2) 정렬 (오름/내림 모두 지원)
            Func<KnitProject, object> keySelector = _sortField switch
            {
                "start"   => p => (object)(p.StartDate ?? DateTime.MaxValue),
                "updated" => p => (object)p.CreatedAt,
                "title"   => p => (object)p.Title,
                _         => p => (object)p.CreatedAt,
            };

            return _sortAsc
                ? filtered.OrderBy(keySelector)
                : filtered.OrderByDescending(keySelector);
        }
    }

    async Task ToggleSortDir()
    {
        _sortAsc = !_sortAsc;
        await SaveSchedulePrefs();
    }

    bool _showModal = false;
    List<Yarn> _yarns = new();
    List<KnitTool> _tools = new();
    List<Swatch> _allSwatches = new();
    KnitProject? _editingProject;

    protected override async Task OnInitializedAsync()
    {
        // 마지막 상태 복원
        var filter   = await JS.InvokeAsync<string?>("localStorage.getItem", "sched_filter");
        var sort     = await JS.InvokeAsync<string?>("localStorage.getItem", "sched_sort");
        var sortAsc  = await JS.InvokeAsync<string?>("localStorage.getItem", "sched_sortasc");
        var listview = await JS.InvokeAsync<string?>("localStorage.getItem", "sched_listview");
        if (!string.IsNullOrEmpty(filter))   _statusFilter = filter;
        if (!string.IsNullOrEmpty(sort))     _sortField    = sort;
        if (!string.IsNullOrEmpty(sortAsc))  _sortAsc      = sortAsc == "true";
        if (!string.IsNullOrEmpty(listview)) _isListView   = listview == "true";
        await LoadData();
        _loading = false;
    }

    async Task SaveSchedulePrefs()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "sched_filter",  _statusFilter);
        await JS.InvokeVoidAsync("localStorage.setItem", "sched_sort",    _sortField);
        await JS.InvokeVoidAsync("localStorage.setItem", "sched_sortasc", _sortAsc.ToString().ToLower());
        await JS.InvokeVoidAsync("localStorage.setItem", "sched_listview",_isListView.ToString().ToLower());
    }

    async Task LoadData()
    {
        var all = await Storage.GetProjectsAsync();
        _projects = all.Where(p => p.Status == ProjectStatus.진행중 || p.Status == ProjectStatus.일시중단).ToList();
        _yarns = await Storage.GetYarnsAsync();
        _tools = await Storage.GetToolsAsync();
        _allSwatches = await Storage.GetSwatchesAsync();
    }

    void GoToDetail(Guid id) => Nav.NavigateTo("projects/" + id);

    void OpenAddModal()
    {
        _editingProject = new KnitProject
        {
            Id = Guid.Empty,
            Status = ProjectStatus.진행중,
            StartDate = DateTime.Today
        };
        _showModal = true;
    }

    void OpenEditModal(KnitProject proj)
    {
        // 취소 시 복원을 위해 JSON 딥카피
        var json = System.Text.Json.JsonSerializer.Serialize(proj);
        _editingProject = System.Text.Json.JsonSerializer.Deserialize<KnitProject>(json)!;
        // 스와치 연결 상태 스냅샷 (projectId 기준)
        _swatchSnapshot = _allSwatches
            .Where(s => s.ProjectId == proj.Id)
            .Select(s => s.Id)
            .ToList();
        _showModal = true;
    }

    void CloseModal()
    {
        // 스와치 연결 상태 복원
        if (_swatchSnapshot != null && _editingProject != null)
        {
            foreach (var s in _allSwatches.Where(s => s.ProjectId == _editingProject.Id).ToList())
                s.ProjectId = null;
            foreach (var id in _swatchSnapshot)
            {
                var s = _allSwatches.FirstOrDefault(x => x.Id == id);
                if (s != null) s.ProjectId = _editingProject.Id;
            }
            _swatchSnapshot = null;
        }
        _showModal = false;
        _editingProject = null;
    }

    void OnAddYarn(ChangeEventArgs e)
    {
        if (_editingProject == null) return;
        var val = e.Value?.ToString();
        if (string.IsNullOrEmpty(val)) return;
        var yarnId = Guid.Parse(val);
        if (!_editingProject.YarnUsages.Any(u => u.YarnId == yarnId))
            _editingProject.YarnUsages.Add(new ProjectYarnUsage { YarnId = yarnId, BallsUsed = 1 });
    }

    void OnScheduleSwatchSelect(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        if (string.IsNullOrEmpty(val) || _editingProject == null) return;
        if (!Guid.TryParse(val, out var swatchId)) return;
        var swatch = _allSwatches.FirstOrDefault(s => s.Id == swatchId);
        if (swatch == null) return;
        if (_editingProject.Id == Guid.Empty) return;
        // 기존 연결 스와치 해제 (단일 연결)
        foreach (var s in _allSwatches.Where(s => s.ProjectId == _editingProject.Id))
            s.ProjectId = null;
        swatch.ProjectId = _editingProject.Id;
    }

    void ToggleTool(Guid toolId)
    {
        if (_editingProject == null) return;
        if (_editingProject.ToolIds.Contains(toolId))
            _editingProject.ToolIds.Remove(toolId);
        else
            _editingProject.ToolIds.Add(toolId);
    }

    async Task SaveProject()
    {
        if (_editingProject == null || string.IsNullOrWhiteSpace(_editingProject.PatternName)) return;
        if (string.IsNullOrWhiteSpace(_editingProject.Title))
            _editingProject.Title = _editingProject.PatternName;
        if (_editingProject.Id == Guid.Empty)
            _editingProject.Id = Guid.NewGuid();
        await Storage.SaveProjectAsync(_editingProject);
        foreach (var s in _allSwatches)
            await Storage.SaveSwatchAsync(s);
        _swatchSnapshot = null;
        await LoadData();
        CloseModal();
    }

    async Task ToggleSuspend(KnitProject proj)
    {
        proj.Status = proj.Status == ProjectStatus.진행중
            ? ProjectStatus.일시중단
            : ProjectStatus.진행중;
        await Storage.SaveProjectAsync(proj);
        await LoadData();
    }

    async Task CompleteProject(Guid id)
    {
        // 완료 처리 전에 프로젝트 정보 저장
        var proj = _projects.FirstOrDefault(p => p.Id == id);
        await Storage.CompleteProjectAsync(id);
        await LoadData();
        // 완성작 팝업 표시
        if (proj != null)
        {
            // 완료 처리 후 EndDate가 설정되므로 Storage에서 다시 읽기
            var allProjects = await Storage.GetProjectsAsync();
            _completedPreview = allProjects.FirstOrDefault(p => p.Id == id) ?? proj;
            _popupEditingBasicInfo = false;
            _popupEditingMeasurements = false;
            LoadPopMeasures();
            _showCompletedPopup = true;
        }
    }

    void CloseCompletedPopup()
    {
        _showCompletedPopup = false;
        _completedPreview = null;
        _popupEditingBasicInfo = false;
        _popupEditingMeasurements = false;
        _popMeasures.Clear();
    }

    void LoadPopMeasures()
    {
        if (_completedPreview == null) return;
        var dict = new Dictionary<string, (string, string)>();
        if (!string.IsNullOrEmpty(_completedPreview.MeasurementsMemo))
        {
            foreach (var part in _completedPreview.MeasurementsMemo.Split('|'))
            {
                var seg = part.Split(':');
                if (seg.Length >= 3) dict[seg[0]] = (seg[1], seg[2]);
                else if (seg.Length == 2) dict[seg[0]] = (seg[1], "");
            }
        }
        _popMeasures = new List<PopMeasureItem>();
        foreach (var label in _popDefaultLabels)
        {
            var (b, a) = dict.TryGetValue(label, out var v) ? v : ("", "");
            _popMeasures.Add(new PopMeasureItem { Label = label, Before = b, After = a, IsCustom = false });
            dict.Remove(label);
        }
        foreach (var kv in dict)
            _popMeasures.Add(new PopMeasureItem { Label = kv.Key, Before = kv.Value.Item1, After = kv.Value.Item2, IsCustom = true });
    }

    async Task SavePopBasicInfo()
    {
        if (_completedPreview == null) return;
        await Storage.SaveProjectAsync(_completedPreview);
        _popupEditingBasicInfo = false;
    }

    async Task SavePopMeasurements()
    {
        if (_completedPreview == null) return;
        _completedPreview.MeasurementsMemo = string.Join("|",
            _popMeasures
                .Where(m => !string.IsNullOrEmpty(m.Label) && (!string.IsNullOrEmpty(m.Before) || !string.IsNullOrEmpty(m.After)))
                .Select(m => $"{m.Label}:{m.Before}:{m.After}"));
        await Storage.SaveProjectAsync(_completedPreview);
        _popupEditingMeasurements = false;
    }

    void CancelPopMeasurements()
    {
        LoadPopMeasures();
        _popupEditingMeasurements = false;
    }

    void GoToFinished() => Nav.NavigateTo("finished");

    async Task DeleteProject(Guid id)
    {
        await Storage.DeleteProjectAsync(id);
        await LoadData();
    }

    async Task OnPhotoSelected(InputFileChangeEventArgs e)
    {
        if (_editingProject == null) return;
        foreach (var file in e.GetMultipleFiles(10))
        {
            var buf = new byte[file.Size];
            await file.OpenReadStream(10 * 1024 * 1024).ReadAsync(buf);
            var base64 = $"data:{file.ContentType};base64,{Convert.ToBase64String(buf)}";
            _editingProject.Photos.Add(new ProjectPhoto
            {
                FileName = file.Name,
                Base64Data = base64,
                TakenAt = DateTime.Now
            });
        }
    }

    void RemovePhoto(Guid photoId)
    {
        _editingProject?.Photos.RemoveAll(p => p.Id == photoId);
    }
}
