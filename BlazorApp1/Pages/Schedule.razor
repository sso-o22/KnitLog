@page "/schedule"
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage
@inject NavigationManager Nav

<div class="page-header">
    <div>
        <h1 class="page-title">📆 뜨케줄</h1>
        <p class="page-subtitle">진행중 · 일시중단 프로젝트</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenAddModal">+ 새 프로젝트</button>
</div>

@if (_loading)
{
    <div class="loading">불러오는 중...</div>
}
else if (_projects.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">📆</div>
        <p>진행중인 프로젝트가 없어요.<br />새 프로젝트를 추가해 보세요!</p>
    </div>
}
else
{
    <!-- 컨트롤 바: 정렬 + 뷰 전환 -->
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; gap:8px; flex-wrap:wrap;">
        <div style="display:flex; align-items:center; gap:8px;">
            <span style="font-size:0.82rem; color:var(--text-mid);">정렬</span>
            <select class="form-control" style="width:auto; padding:5px 10px; font-size:0.82rem;" @bind="_sortOrder">
                <option value="created">등록순</option>
                <option value="start">시작일</option>
                <option value="updated">수정일</option>
                <option value="title">이름순</option>
            </select>
        </div>
        <div style="display:flex; gap:4px;">
            <button class="btn btn-sm @(_isListView ? "btn-ghost" : "btn-sage")" @onclick="() => _isListView = false" title="카드형">⊞</button>
            <button class="btn btn-sm @(_isListView ? "btn-sage" : "btn-ghost")" @onclick="() => _isListView = true" title="리스트형">☰</button>
        </div>
    </div>

    @if (!_isListView)
    {
        <!-- 카드형 -->
        <div class="grid-2">
            @foreach (var proj in SortedProjects)
            {
                <div class="card" style="cursor:pointer;" @onclick="() => GoToDetail(proj.Id)">
                    @if (proj.Photos.Count > 0)
                    {
                        <img src="@proj.Photos[0].Base64Data" class="photo-thumb"
                             style="width:100%; height:160px; object-fit:cover; border-radius:var(--radius-sm); margin-bottom:12px;"
                             alt="프로젝트 사진" />
                    }

                    <div class="flex-between mb-1">
                        <div class="card-title" style="margin-bottom:0;">@proj.Title</div>
                        @if (proj.Status == ProjectStatus.일시중단)
                        {
                            <span class="badge" style="background:#f5e6c0; color:#8a6010;">⏸️ 일시중단</span>
                        }
                        else
                        {
                            <span class="badge badge-progress">진행중</span>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(proj.PatternName))
                    {
                        <div style="font-size:0.82rem; color:var(--text-mid); margin-bottom:4px;">📋 @proj.PatternName</div>
                    }
                    @if (!string.IsNullOrEmpty(proj.Description))
                    {
                        <p style="font-size:0.85rem; color:var(--text-mid); margin-bottom:10px; white-space:pre-wrap;">@proj.Description</p>
                    }

                    <div style="display:flex; gap:12px; font-size:0.8rem; color:var(--text-light); margin-bottom:14px;">
                        @if (proj.StartDate.HasValue)
                        {
                            <span>시작 @proj.StartDate.Value.ToString("yy.MM.dd")</span>
                        }
                        @if (proj.EndDate.HasValue)
                        {
                            <span>→ @proj.EndDate.Value.ToString("yy.MM.dd") 목표</span>
                        }
                    </div>

                    <div style="display:flex; gap:8px; flex-wrap:wrap;" @onclick:stopPropagation="true">
                        <button class="btn btn-secondary btn-sm" @onclick="() => OpenEditModal(proj)">✏️ 수정</button>
                        <button class="btn btn-sm btn-sage" @onclick="() => CompleteProject(proj.Id)">✅ 완료</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteProject(proj.Id)">🗑️</button>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- 리스트형 -->
        <div style="display:flex; flex-direction:column; gap:8px;">
            @foreach (var proj in SortedProjects)
            {
                <div class="card" style="cursor:pointer; display:flex; align-items:center; gap:14px; padding:12px 16px;"
                     @onclick="() => GoToDetail(proj.Id)">
                    @if (proj.Photos.Count > 0)
                    {
                        <img src="@proj.Photos[0].Base64Data"
                             style="width:52px; height:52px; object-fit:cover; border-radius:var(--radius-sm); border:1px solid var(--border); flex-shrink:0;"
                             alt="사진" />
                    }
                    else
                    {
                        <div style="width:52px; height:52px; background:var(--ivory-dark); border-radius:var(--radius-sm); display:flex; align-items:center; justify-content:center; font-size:1.4rem; flex-shrink:0;">🧶</div>
                    }

                    <div style="flex:1; min-width:0;">
                        <div style="display:flex; align-items:center; gap:8px; margin-bottom:2px;">
                            <span style="font-weight:700; font-size:0.95rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@proj.Title</span>
                            @if (proj.Status == ProjectStatus.일시중단)
                            {
                                <span class="badge" style="background:#f5e6c0; color:#8a6010; flex-shrink:0;">⏸️</span>
                            }
                        </div>
                        <div style="font-size:0.78rem; color:var(--text-mid); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                            @if (!string.IsNullOrEmpty(proj.PatternName)) { <span>@proj.PatternName</span> }
                            @if (proj.StartDate.HasValue) { <span style="margin-left:8px;">· @proj.StartDate.Value.ToString("yy.MM.dd") 시작</span> }
                        </div>
                    </div>

                    <div style="display:flex; gap:6px; flex-shrink:0;" @onclick:stopPropagation="true">
                        <button class="btn btn-secondary btn-sm" @onclick="() => OpenEditModal(proj)">✏️</button>
                        <button class="btn btn-sage btn-sm" @onclick="() => CompleteProject(proj.Id)">✅</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteProject(proj.Id)">🗑️</button>
                    </div>
                </div>
            }
        </div>
    }
}

@if (_showModal)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">@(_editingProject?.Id == Guid.Empty ? "새 프로젝트" : "프로젝트 수정")</h2>
                <button class="btn btn-ghost btn-sm" @onclick="CloseModal">✕</button>
            </div>

            @if (_editingProject != null)
            {
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">도안명 *</label>
                        <input class="form-control" @bind="_editingProject.PatternName" placeholder="예: 마시멜로 후드 집업" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">도안 출처</label>
                        <input class="form-control" @bind="_editingProject.PatternSource" placeholder="작가명, 책 이름, URL 등" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">도안 메모</label>
                    <textarea class="form-control" rows="2" @bind="_editingProject.PatternMemo" placeholder="사이즈, 수정 사항 등"></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">설명</label>
                    <textarea class="form-control" rows="2" @bind="_editingProject.Description" placeholder="작품에 대한 설명"></textarea>
                </div>

                @* 사용 실 *@
                <div class="form-group">
                    <label class="form-label">사용 실 — 실 창고에서 선택</label>
                    @foreach (var usage in _editingProject.YarnUsages)
                    {
                        var yarn = _yarns.Find(y => y.Id == usage.YarnId);
                        <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px;">
                            @if (yarn != null)
                            {
                                <span class="color-dot" style="background:@yarn.ColorCode;"></span>
                                <span style="flex:1; font-size:0.88rem;">@yarn.Brand @yarn.Name (@yarn.Color)</span>
                            }
                            <input class="form-control" type="number" min="1" style="width:70px;"
                                   value="@usage.BallsUsed"
                                   @onchange="e => usage.BallsUsed = int.TryParse(e.Value?.ToString(), out var n) ? n : 1" />
                            <span style="font-size:0.82rem; color:var(--text-mid);">볼</span>
                            <button class="btn btn-danger btn-sm" @onclick="() => _editingProject.YarnUsages.Remove(usage)">✕</button>
                        </div>
                    }
                    <select class="form-control" @onchange="OnAddYarn">
                        <option value="">+ 실 추가</option>
                        @foreach (var y in _yarns)
                        {
                            <option value="@y.Id">@y.Brand @y.Name (@y.Color)</option>
                        }
                    </select>
                </div>

                @* 사용 바늘 *@
                <div class="form-group">
                    <label class="form-label">사용 바늘</label>
                    @if (_tools.Count > 0)
                    {
                        <div style="display:flex; flex-wrap:wrap; gap:6px; margin-bottom:8px;">
                            @foreach (var tool in _tools)
                            {
                                var selected = _editingProject.ToolIds.Contains(tool.Id);
                                <button type="button"
                                        class="btn btn-sm @(selected ? "btn-sage" : "btn-ghost")"
                                        @onclick="() => ToggleTool(tool.Id)">
                                    @tool.NeedleType @tool.SizeMm mm
                                </button>
                            }
                        </div>
                    }
                    <input class="form-control" @bind="_editingProject.NeedleNote" placeholder="예: 4mm 대바늘 80cm줄, 3.5mm 코바늘" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">시작일</label>
                        <input type="date" class="form-control"
                               value="@_editingProject.StartDate?.ToString("yyyy-MM-dd")"
                               @onchange="e => _editingProject.StartDate = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!)" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">목표 종료일</label>
                        <input type="date" class="form-control"
                               value="@_editingProject.EndDate?.ToString("yyyy-MM-dd")"
                               @onchange="e => _editingProject.EndDate = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!)" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">메모</label>
                    <textarea class="form-control" rows="2" @bind="_editingProject.Memo" placeholder="기타 메모"></textarea>
                </div>
            }

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseModal">취소</button>
                <button class="btn btn-primary" @onclick="SaveProject">저장</button>
            </div>
        </div>
    </div>
}

@code {
    bool _loading = true;
    bool _isListView = false;
    string _sortOrder = "created";
    List<KnitProject> _projects = new();

    IEnumerable<KnitProject> SortedProjects => _sortOrder switch
    {
        "start"   => _projects.OrderBy(p => p.StartDate ?? DateTime.MaxValue),
        "updated" => _projects.OrderByDescending(p => p.CreatedAt),
        "title"   => _projects.OrderBy(p => p.Title),
        _         => _projects.OrderByDescending(p => p.CreatedAt),
    };

    bool _showModal = false;
    List<Yarn> _yarns = new();
    List<KnitTool> _tools = new();
    KnitProject? _editingProject;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _loading = false;
    }

    async Task LoadData()
    {
        var all = await Storage.GetProjectsAsync();
        _projects = all.Where(p => p.Status == ProjectStatus.진행중 || p.Status == ProjectStatus.일시중단).ToList();
        _yarns = await Storage.GetYarnsAsync();
        _tools = await Storage.GetToolsAsync();
    }

    void GoToDetail(Guid id) => Nav.NavigateTo("schedule/" + id);

    void OpenAddModal()
    {
        _editingProject = new KnitProject
        {
            Id = Guid.Empty,
            Status = ProjectStatus.진행중,
            StartDate = DateTime.Today
        };
        _showModal = true;
    }

    void OpenEditModal(KnitProject proj)
    {
        _editingProject = proj;
        _showModal = true;
    }

    void CloseModal()
    {
        _showModal = false;
        _editingProject = null;
    }

    void OnAddYarn(ChangeEventArgs e)
    {
        if (_editingProject == null) return;
        var val = e.Value?.ToString();
        if (string.IsNullOrEmpty(val)) return;
        var yarnId = Guid.Parse(val);
        if (!_editingProject.YarnUsages.Any(u => u.YarnId == yarnId))
            _editingProject.YarnUsages.Add(new ProjectYarnUsage { YarnId = yarnId, BallsUsed = 1 });
    }

    void ToggleTool(Guid toolId)
    {
        if (_editingProject == null) return;
        if (_editingProject.ToolIds.Contains(toolId))
            _editingProject.ToolIds.Remove(toolId);
        else
            _editingProject.ToolIds.Add(toolId);
    }

    async Task SaveProject()
    {
        if (_editingProject == null || string.IsNullOrWhiteSpace(_editingProject.PatternName)) return;
        // 도안명을 작품명으로도 사용
        if (string.IsNullOrWhiteSpace(_editingProject.Title))
            _editingProject.Title = _editingProject.PatternName;
        if (_editingProject.Id == Guid.Empty)
            _editingProject.Id = Guid.NewGuid();
        await Storage.SaveProjectAsync(_editingProject);
        await LoadData();
        CloseModal();
    }

    async Task CompleteProject(Guid id)
    {
        await Storage.CompleteProjectAsync(id);
        await LoadData();
    }

    async Task DeleteProject(Guid id)
    {
        await Storage.DeleteProjectAsync(id);
        await LoadData();
    }

    async Task OnPhotoSelected(InputFileChangeEventArgs e)
    {
        if (_editingProject == null) return;
        foreach (var file in e.GetMultipleFiles(10))
        {
            var buf = new byte[file.Size];
            await file.OpenReadStream(10 * 1024 * 1024).ReadAsync(buf);
            var base64 = $"data:{file.ContentType};base64,{Convert.ToBase64String(buf)}";
            _editingProject.Photos.Add(new ProjectPhoto
            {
                FileName = file.Name,
                Base64Data = base64,
                TakenAt = DateTime.Now
            });
        }
    }

    void RemovePhoto(Guid photoId)
    {
        _editingProject?.Photos.RemoveAll(p => p.Id == photoId);
    }
}