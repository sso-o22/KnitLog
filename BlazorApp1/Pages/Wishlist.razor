@* =====================================================================
   Pages/Wishlist.razor  —  위시리스트
   ===================================================================== *@
@page "/wishlist"
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage

<div class="page-header">
    <div>
        <h1 class="page-title">💫 위시리스트</h1>
        <p class="page-subtitle">언젠가 꼭 뜨고 싶은 작품들</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenAddModal">+ 추가</button>
</div>

@if (_loading)
{
    <div class="loading">불러오는 중...</div>
}
else if (_projects.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">💫</div>
        <p>위시리스트가 비어 있어요.<br/>뜨고 싶은 작품을 추가해 보세요!</p>
    </div>
}
else
{
    <div class="grid-3">
        @foreach (var proj in _projects)
        {
            <div class="card">
                <div class="flex-between mb-1">
                    <div class="card-title" style="margin-bottom:0;">@proj.PatternName</div>
                    <span class="badge badge-wish">위시</span>
                </div>

                @if (!string.IsNullOrEmpty(proj.PatternName))
                {
                    <div style="font-size:0.82rem; color:var(--text-mid); margin-bottom:6px;">📋 @proj.PatternName</div>
                }
                @if (!string.IsNullOrEmpty(proj.WishMemo))
                {
                    <p style="font-size:0.84rem; color:var(--text-mid); margin-bottom:12px; white-space:pre-wrap;">@proj.WishMemo</p>
                }
                @if (!string.IsNullOrEmpty(proj.PatternSource))
                {
                    <div style="font-size:0.78rem; color:var(--text-light); margin-bottom:10px;">🔗 @proj.PatternSource</div>
                }

                <div class="flex gap-1" style="flex-wrap:wrap;">
                    <button class="btn btn-sm btn-primary" @onclick="() => StartProject(proj.Id)">시작하기</button>
                    <button class="btn btn-secondary btn-sm" @onclick="() => OpenEditModal(proj)">✏️</button>
                    <button class="btn btn-danger btn-sm" @onclick='() => Confirm("위시리스트에서 삭제하면 복구할 수 없어요.", async () => await DeleteProject(proj.Id))'>🗑️</button>
                </div>
            </div>
        }
    </div>
}

<!-- 추가/수정 모달 -->
@if (_showModal && _editingProject != null)
{
    <div class="modal-backdrop">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">@(_editingProject.Id == Guid.Empty ? "위시 추가" : "위시 수정")</h2>
                <button class="btn btn-ghost btn-sm" @onclick="CloseModal">✕</button>
            </div>

            @* <div class="form-group">
                <label class="form-label">작품명 *</label>
                <input class="form-control" @bind="_editingProject.Title" placeholder="예: 올드패션드 가디건" />
            </div> *@

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">도안명</label>
                    <input class="form-control" @bind="_editingProject.PatternName" placeholder="예: 올드패션드 가디건" />
                </div>
                <div class="form-group">
                    <label class="form-label">도안 출처</label>
                    <input class="form-control" @bind="_editingProject.PatternSource" placeholder="작가명, 책 이름, URL 등" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">메모</label>
                <textarea class="form-control" rows="4" @bind="_editingProject.WishMemo"
                          placeholder="뜨고 싶은 이유, 사용할 실 아이디어 등 자유롭게!"></textarea>
            </div>

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseModal">취소</button>
                <button class="btn btn-primary" @onclick="SaveProject">저장</button>
            </div>
        </div>
    </div>
}

<!-- 삭제 확인 모달 -->
@if (_showConfirm)
{
    <div class="modal-backdrop" style="z-index:9999;">
        <div class="modal" style="max-width:360px; text-align:center;" @onclick:stopPropagation="true">
            <div style="font-size:2rem; margin-bottom:12px;">🗑️</div>
            <div style="font-size:1rem; font-weight:600; margin-bottom:8px; color:var(--text-dark);">정말 삭제할까요?</div>
            <div style="font-size:0.88rem; color:var(--text-mid); margin-bottom:20px;">@_confirmMsg</div>
            <div style="display:flex; gap:10px; justify-content:center;">
                <button class="btn btn-ghost" @onclick="() => _showConfirm = false">취소</button>
                <button class="btn btn-danger" @onclick="ExecuteConfirm">삭제</button>
            </div>
        </div>
    </div>
}

@code {
    bool _showConfirm = false;
    string _confirmMsg = "";
    Func<Task>? _confirmAction;

    void Confirm(string msg, Func<Task> action)
    {
        _confirmMsg    = msg;
        _confirmAction = action;
        _showConfirm   = true;
    }

    async Task ExecuteConfirm()
    {
        _showConfirm = false;
        if (_confirmAction != null)
            await _confirmAction();
        _confirmAction = null;
    }

    bool _loading = true;
    bool _showModal = false;
    List<KnitProject> _projects = new();
    KnitProject? _editingProject;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _loading = false;
    }

    async Task LoadData()
    {
        var all = await Storage.GetProjectsAsync();
        // 데이터 표시 시에도 Title 대신 PatternName을 우선적으로 보여주려면 
        // 여기서 정렬이나 가공을 할 수 있습니다.
        _projects = all.Where(p => p.Status == ProjectStatus.위시리스트).ToList();
    }

    void OpenAddModal()
    {
        // 초기화 시 빈 문자열이라도 넣어둡니다.
        _editingProject = new KnitProject { 
            Id = Guid.Empty, 
            Status = ProjectStatus.위시리스트,
            Title = "",
            PatternName = "" 
        };
        _showModal = true;
    }

    void OpenEditModal(KnitProject proj) { _editingProject = proj; _showModal = true; }
    void CloseModal() { _showModal = false; _editingProject = null; }

    async Task SaveProject()
    {
        if (_editingProject == null) return;

        // [수정 포인트] Title 대신 PatternName이 있는지 확인합니다.
        if (string.IsNullOrWhiteSpace(_editingProject.PatternName))
        {
            // 도안명이 비어있으면 저장되지 않도록 하거나, 기본값을 넣어줍니다.
            return; 
        }

        // 다른 로직에서 Title을 참조할 수 있으므로 PatternName과 동일하게 맞춰줍니다.
        _editingProject.Title = _editingProject.PatternName;

        if (_editingProject.Id == Guid.Empty) _editingProject.Id = Guid.NewGuid();
        
        await Storage.SaveProjectAsync(_editingProject);
        await LoadData();
        CloseModal();
    }

    async Task StartProject(Guid id)
    {
        await Storage.StartProjectAsync(id);
        await LoadData();
    }

    async Task DeleteProject(Guid id)
    {
        await Storage.DeleteProjectAsync(id);
        await LoadData();
    }
}
