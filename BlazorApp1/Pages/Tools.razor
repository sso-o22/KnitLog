@page "/tools"
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage

<div class="page-header">
    <div>
        <h1 class="page-title">⚒️ 도구</h1>
        <p class="page-subtitle">보유중인 대바늘 · 코바늘 · 케이블</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenAddModal">+ 도구 추가</button>
</div>

@if (_loading)
{
    <div class="loading">불러오는 중...</div>
}
else
{
    <div style="display:flex; gap:8px; margin-bottom:20px;">
        <button class="btn @(_tab == -1 ? "btn-primary" : "btn-ghost")" @onclick="() => _tab = -1">
            전체 (@_tools.Count)
        </button>
        <button class="btn @(_tab == 0 ? "btn-primary" : "btn-ghost")" @onclick="() => _tab = 0">
            대바늘 (@KnitCount)
        </button>
        <button class="btn @(_tab == 1 ? "btn-primary" : "btn-ghost")" @onclick="() => _tab = 1">
            코바늘 (@CrochetCount)
        </button>
        <button class="btn @(_tab == 2 ? "btn-primary" : "btn-ghost")" @onclick="() => _tab = 2">
            케이블 (@CableCount)
        </button>
    </div>

    @if (FilteredTools.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">⚒️</div>
            <p>등록된 도구가 없어요.<br/>바늘 정보를 추가해 보세요!</p>
        </div>
    }
    else
    {
        <div class="grid-3">
            @foreach (var tool in FilteredTools.OrderBy(t => t.NeedleType).ThenBy(t => t.IsSet ? 999 : t.SizeMm))
            {
                <div class="card">
                    <div class="flex-between mb-1">
                        <div class="card-title" style="margin-bottom:0;">
                            @if (!string.IsNullOrEmpty(tool.Brand) || !string.IsNullOrEmpty(tool.ModelName))
                            {
                                <span>@tool.Brand @tool.ModelName</span>
                            }
                            else if (tool.NeedleType == NeedleType.케이블)
                            {
                                <span>케이블</span>
                            }
                            else
                            {
                                <span>@(tool.IsSet ? "세트" : $"{tool.SizeMm}mm")</span>
                            }
                        </div>
                        <div style="display:flex; gap:4px; align-items:center;">
                            @if (tool.NeedleType != NeedleType.케이블)
                            {
                                <span class="badge badge-done" style="font-size:0.7rem;">
                                    @(tool.IsSet ? "세트" : "단품")
                                </span>
                            }
                            <span class="badge @(tool.NeedleType == NeedleType.대바늘 ? "badge-progress" : tool.NeedleType == NeedleType.코바늘 ? "badge-wish" : "badge-done")">
                                @tool.NeedleType
                            </span>
                        </div>
                    </div>

                    @* 굵기: 회색 태그로 표시 *@
                    @if (tool.NeedleType != NeedleType.케이블)
                    {
                        <div style="display:flex; flex-wrap:wrap; gap:4px; margin-bottom:6px;">
                            @if (tool.IsSet && tool.SetSizes.Count > 0)
                            {
                                @foreach (var s in tool.SetSizes.OrderBy(x => x))
                                {
                                    <span style="background:var(--ivory-dark); border-radius:4px; padding:2px 6px; font-size:0.75rem; color:var(--text-mid);">@(s)mm</span>
                                }
                            }
                            else if (!tool.IsSet && tool.SizeMm > 0)
                            {
                                <span style="background:var(--ivory-dark); border-radius:4px; padding:2px 6px; font-size:0.75rem; color:var(--text-mid);">@(tool.SizeMm)mm</span>
                            }
                        </div>
                    }

                    @* 케이블 사이즈 태그 *@
                    @if (tool.NeedleType == NeedleType.케이블 && !string.IsNullOrEmpty(tool.Material))
                    {
                        <div style="display:flex; flex-wrap:wrap; gap:4px; margin-bottom:6px;">
                            <span style="background:var(--ivory-dark); border-radius:4px; padding:2px 6px; font-size:0.75rem; color:var(--text-mid);">@tool.Material</span>
                        </div>
                    }

                    @if (tool.NeedleType == NeedleType.코바늘 && !string.IsNullOrEmpty(tool.HookSize))
                    {
                        <div style="font-size:0.8rem; color:var(--text-light);">호수: @tool.HookSize</div>
                    }
                    @if (!string.IsNullOrEmpty(tool.Material) && tool.NeedleType != NeedleType.케이블)
                    {
                        <div style="font-size:0.8rem; color:var(--text-light);">소재: @tool.Material</div>
                    }
                    @if (tool.LengthCm > 0)
                    {
                        <div style="font-size:0.8rem; color:var(--text-light);">길이: @(tool.LengthCm)cm</div>
                    }
                    @if (!string.IsNullOrEmpty(tool.Memo))
                    {
                        <div style="font-size:0.8rem; color:var(--text-light); margin-top:4px;">@tool.Memo</div>
                    }

                    <div class="flex gap-1 mt-2">
                        <button class="btn btn-secondary btn-sm" @onclick="() => OpenEditModal(tool)">✏️ 수정</button>
                        <button class="btn btn-danger btn-sm" @onclick='() => Confirm("이 도구를 삭제하면 복구할 수 없어요.", async () => await DeleteTool(tool.Id))'>🗑️</button>
                    </div>
                </div>
            }
        </div>
    }
}

@if (_showModal && _editingTool != null)
{
    <div class="modal-backdrop">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">@(_editingTool.Id == Guid.Empty ? "도구 추가" : "도구 수정")</h2>
                <button class="btn btn-ghost btn-sm" @onclick="CloseModal">✕</button>
            </div>

            <!-- 종류 -->
            <div class="form-group">
                <label class="form-label">종류 *</label>
                <div style="display:flex; gap:12px;">
                    <label style="cursor:pointer; display:flex; align-items:center; gap:6px;">
                        <input type="radio" name="needleType" checked="@(_editingTool.NeedleType == NeedleType.대바늘)"
                               @onchange="() => _editingTool.NeedleType = NeedleType.대바늘" />
                        대바늘
                    </label>
                    <label style="cursor:pointer; display:flex; align-items:center; gap:6px;">
                        <input type="radio" name="needleType" checked="@(_editingTool.NeedleType == NeedleType.코바늘)"
                               @onchange="() => _editingTool.NeedleType = NeedleType.코바늘" />
                        코바늘
                    </label>
                    <label style="cursor:pointer; display:flex; align-items:center; gap:6px;">
                        <input type="radio" name="needleType" checked="@(_editingTool.NeedleType == NeedleType.케이블)"
                               @onchange="() => _editingTool.NeedleType = NeedleType.케이블" />
                        케이블
                    </label>
                </div>
            </div>

            @if (_editingTool.NeedleType == NeedleType.케이블)
            {
                <!-- 케이블: 브랜드, 길이, 사이즈(선택) -->
                <div class="form-group">
                    <label class="form-label">브랜드</label>
                    <input class="form-control" @bind="_editingTool.Brand" placeholder="예: 니트프로" />
                </div>
                <div class="form-group">
                    <label class="form-label">길이 (cm)</label>
                    <input type="number" class="form-control"
                           value="@(_editingTool.LengthCm == 0 ? "" : _editingTool.LengthCm.ToString())"
                           @onchange="e => _editingTool.LengthCm = int.TryParse(e.Value?.ToString(), out var v) ? v : 0"
                           min="0" placeholder="예: 80" />
                </div>
                <div class="form-group">
                    <label class="form-label">사이즈 (선택)</label>
                    <input class="form-control" @bind="_editingTool.Material" placeholder="" />
                </div>
            }
            else if (_editingTool.NeedleType == NeedleType.대바늘)
            {
                <!-- 대바늘: 브랜드, 모델명, 굵기, 길이, 소재(선택) -->
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">브랜드</label>
                        <input class="form-control" @bind="_editingTool.Brand" placeholder="예: 치아오구" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">모델명</label>
                        <input class="form-control" @bind="_editingTool.ModelName" placeholder="예: 밤부" />
                    </div>
                </div>

                <!-- 세트 여부 -->
                <div class="form-group">
                    <label style="cursor:pointer; display:flex; align-items:center; gap:8px; font-size:0.88rem;">
                        <input type="checkbox" checked="@_editingTool.IsSet"
                               @onchange="e => _editingTool.IsSet = (bool)(e.Value ?? false)"
                               style="width:16px; height:16px;" />
                        <span>세트 바늘 (굵기 여러 개)</span>
                    </label>
                </div>

                @if (!_editingTool.IsSet)
                {
                    <div class="form-group">
                        <label class="form-label">굵기 (mm) *</label>
                        <input type="number" class="form-control"
                               value="@(_editingTool.SizeMm == 0 ? "" : _editingTool.SizeMm.ToString())"
                               @onchange="e => _editingTool.SizeMm = double.TryParse(e.Value?.ToString(), out var v) ? v : 0"
                               step="0.25" min="0.5" max="30" placeholder="예: 3.5" />
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <label class="form-label">굵기 목록</label>
                        <div style="display:flex; flex-wrap:wrap; gap:6px; margin-bottom:8px;">
                            @foreach (var s in _editingTool.SetSizes.OrderBy(x => x).ToList())
                            {
                                <div style="display:flex; align-items:center; gap:3px; background:var(--ivory-dark); border-radius:6px; padding:3px 8px;">
                                    <span style="font-size:0.82rem;">@(s)mm</span>
                                    <button class="btn btn-danger btn-sm" style="padding:0 4px; font-size:0.7rem; line-height:1.2;"
                                            @onclick="() => _editingTool.SetSizes.Remove(s)">✕</button>
                                </div>
                            }
                        </div>
                        <div style="display:flex; gap:8px; align-items:center;">
                            <button class="btn btn-ghost btn-sm" style="font-size:1.1rem; padding:3px 12px;"
                                    @onclick="DecNewSetSize">−</button>
                            <input type="number" class="form-control" style="text-align:center;"
                                   value="@(_newSetSize == 0 ? "" : _newSetSize.ToString())"
                                   @onchange="e => _newSetSize = double.TryParse(e.Value?.ToString(), out var v) ? v : _newSetSize"
                                   step="0.25" min="0.5" max="30" placeholder="굵기 (mm)" />
                            <button class="btn btn-ghost btn-sm" style="font-size:1.1rem; padding:3px 12px;"
                                    @onclick="IncNewSetSize">+</button>
                            <button class="btn btn-sage btn-sm" @onclick="AddSetSize">추가</button>
                        </div>
                    </div>
                }

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">길이 (cm)</label>
                        <input type="number" class="form-control"
                               value="@(_editingTool.LengthCm == 0 ? "" : _editingTool.LengthCm.ToString())"
                               @onchange="e => _editingTool.LengthCm = int.TryParse(e.Value?.ToString(), out var v) ? v : 0"
                               min="0" placeholder="예: 13" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">소재 (선택)</label>
                        <input class="form-control" @bind="_editingTool.Material" placeholder="예: 대나무" />
                    </div>
                </div>
            }
            else
            {
                <!-- 코바늘: 브랜드, 모델명, 굵기(mm) 또는 호수 -->
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">브랜드</label>
                        <input class="form-control" @bind="_editingTool.Brand" placeholder="예: 튤립" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">모델명</label>
                        <input class="form-control" @bind="_editingTool.ModelName" placeholder="예: 에티모" />
                    </div>
                </div>

                <!-- 세트 여부 -->
                <div class="form-group">
                    <label style="cursor:pointer; display:flex; align-items:center; gap:8px; font-size:0.88rem;">
                        <input type="checkbox" checked="@_editingTool.IsSet"
                               @onchange="e => _editingTool.IsSet = (bool)(e.Value ?? false)"
                               style="width:16px; height:16px;" />
                        <span>세트 바늘 (굵기 여러 개)</span>
                    </label>
                </div>

                @if (!_editingTool.IsSet)
                {
                    <div class="form-group">
                        <label class="form-label">굵기 / 호수</label>
                        <input class="form-control" @bind="_editingTool.HookSize" placeholder="예: 3.5mm / 5호 / 7/0호" />
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <label class="form-label">굵기 목록</label>
                        <div style="display:flex; flex-wrap:wrap; gap:6px; margin-bottom:8px;">
                            @foreach (var s in _editingTool.SetSizes.OrderBy(x => x).ToList())
                            {
                                <div style="display:flex; align-items:center; gap:3px; background:var(--ivory-dark); border-radius:6px; padding:3px 8px;">
                                    <span style="font-size:0.82rem;">@(s)mm</span>
                                    <button class="btn btn-danger btn-sm" style="padding:0 4px; font-size:0.7rem; line-height:1.2;"
                                            @onclick="() => _editingTool.SetSizes.Remove(s)">✕</button>
                                </div>
                            }
                        </div>
                        <div style="display:flex; gap:8px; align-items:center;">
                            <button class="btn btn-ghost btn-sm" style="font-size:1.1rem; padding:3px 12px;"
                                    @onclick="DecNewSetSize">−</button>
                            <input type="number" class="form-control" style="text-align:center;"
                                   value="@(_newSetSize == 0 ? "" : _newSetSize.ToString())"
                                   @onchange="e => _newSetSize = double.TryParse(e.Value?.ToString(), out var v) ? v : _newSetSize"
                                   step="0.25" min="0.5" max="30" placeholder="굵기 (mm)" />
                            <button class="btn btn-ghost btn-sm" style="font-size:1.1rem; padding:3px 12px;"
                                    @onclick="IncNewSetSize">+</button>
                            <button class="btn btn-sage btn-sm" @onclick="AddSetSize">추가</button>
                        </div>
                    </div>
                }
            }

            <div class="form-group">
                <label class="form-label">메모</label>
                <textarea class="form-control" rows="2" @bind="_editingTool.Memo" placeholder="기타 메모"></textarea>
            </div>

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseModal">취소</button>
                <button class="btn btn-primary" @onclick="SaveTool">저장</button>
            </div>
        </div>
    </div>
}

<!-- 삭제 확인 모달 -->
@if (_showConfirm)
{
    <div class="modal-backdrop" style="z-index:9999;">
        <div class="modal" style="max-width:360px; text-align:center;" @onclick:stopPropagation="true">
            <div style="font-size:2rem; margin-bottom:12px;">🗑️</div>
            <div style="font-size:1rem; font-weight:600; margin-bottom:8px; color:var(--text-dark);">정말 삭제할까요?</div>
            <div style="font-size:0.88rem; color:var(--text-mid); margin-bottom:20px;">@_confirmMsg</div>
            <div style="display:flex; gap:10px; justify-content:center;">
                <button class="btn btn-ghost" @onclick="() => _showConfirm = false">취소</button>
                <button class="btn btn-danger" @onclick="ExecuteConfirm">삭제</button>
            </div>
        </div>
    </div>
}

@code {
    bool _showConfirm = false;
    string _confirmMsg = "";
    Func<Task>? _confirmAction;

    void Confirm(string msg, Func<Task> action)
    {
        _confirmMsg    = msg;
        _confirmAction = action;
        _showConfirm   = true;
    }

    async Task ExecuteConfirm()
    {
        _showConfirm = false;
        if (_confirmAction != null)
            await _confirmAction();
        _confirmAction = null;
    }

    bool _loading = true;
    bool _showModal = false;
    int _tab = -1;  // -1 = 전체
    double _newSetSize = 0;
    List<KnitTool> _tools = new();
    KnitTool? _editingTool;

    int KnitCount    => _tools.Count(t => t.NeedleType == NeedleType.대바늘);
    int CrochetCount => _tools.Count(t => t.NeedleType == NeedleType.코바늘);
    int CableCount   => _tools.Count(t => t.NeedleType == NeedleType.케이블);

    List<KnitTool> FilteredTools => _tab switch
    {
        0  => _tools.Where(t => t.NeedleType == NeedleType.대바늘).ToList(),
        1  => _tools.Where(t => t.NeedleType == NeedleType.코바늘).ToList(),
        2  => _tools.Where(t => t.NeedleType == NeedleType.케이블).ToList(),
        _  => _tools.ToList(),
    };

    protected override async Task OnInitializedAsync()
    {
        _tools = await Storage.GetToolsAsync();
        _loading = false;
    }

    void OpenAddModal()
    {
        _editingTool = new KnitTool
        {
            Id = Guid.Empty,
            NeedleType = _tab switch
            {
                0 => NeedleType.대바늘,
                1 => NeedleType.코바늘,
                2 => NeedleType.케이블,
                _ => NeedleType.대바늘
            }
        };
        _newSetSize = 0;
        _showModal = true;
    }

    void OpenEditModal(KnitTool tool)
    {
        _editingTool = tool;
        _newSetSize = 0;
        _showModal = true;
    }

    void CloseModal() { _showModal = false; _editingTool = null; }

    double GetStep(double size) => size < 4.0 ? 0.25 : 0.5;

    void IncNewSetSize()
    {
        var step = GetStep(_newSetSize);
        _newSetSize = Math.Round(_newSetSize + step, 2);
    }

    void DecNewSetSize()
    {
        var step = GetStep(_newSetSize > 0 ? _newSetSize : 0.25);
        _newSetSize = Math.Max(0.5, Math.Round(_newSetSize - step, 2));
    }

    void AddSetSize()
    {
        if (_editingTool == null || _newSetSize <= 0) return;
        if (!_editingTool.SetSizes.Contains(_newSetSize))
            _editingTool.SetSizes.Add(_newSetSize);
    }

    async Task SaveTool()
    {
        if (_editingTool == null) return;
        if (_editingTool.NeedleType != NeedleType.케이블)
        {
            if (!_editingTool.IsSet && _editingTool.SizeMm <= 0) return;
            if (_editingTool.IsSet && _editingTool.SetSizes.Count == 0) return;
        }
        if (_editingTool.Id == Guid.Empty) _editingTool.Id = Guid.NewGuid();
        await Storage.SaveToolAsync(_editingTool);
        _tools = await Storage.GetToolsAsync();
        CloseModal();
    }

    async Task DeleteTool(Guid id)
    {
        await Storage.DeleteToolAsync(id);
        _tools = await Storage.GetToolsAsync();
    }
}
