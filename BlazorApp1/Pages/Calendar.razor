@* =====================================================================
   Pages/Calendar.razor  —  뜨케줄 캘린더 페이지
   ===================================================================== *@
@page "/schedule"
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="page-header">
    <div>
        <h1 class="page-title">🗓️ 뜨케줄</h1>
        <p class="page-subtitle">프로젝트 일정 · 마감 관리</p>
    </div>
</div>

@if (_loading)
{
    <div class="loading">불러오는 중...</div>
}
else
{
    <div class="calendar-mobile-layout" style="display:flex; gap:20px; align-items:flex-start;">

        <!-- ── 메인 캘린더 ── -->
        <div style="flex:1; min-width:0; width:100%;">

            <!-- 뷰 탭 -->
            <div style="display:flex; gap:4px; background:#f5f5f5; border-radius:9px; padding:3px; margin-bottom:20px; width:fit-content;">
                <button class="btn btn-sm @(_view == "month" ? "btn-sage" : "btn-ghost")" @onclick='async () => { _view = "month"; await JS.InvokeVoidAsync("localStorage.setItem", "cal_view", "month"); }'>월간</button>
                <button class="btn btn-sm @(_view == "timeline" ? "btn-sage" : "btn-ghost")" @onclick='async () => { _view = "timeline"; await JS.InvokeVoidAsync("localStorage.setItem", "cal_view", "timeline"); }'>타임라인</button>
            </div>

            <!-- 월 네비게이션 -->
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;">
                <button class="btn btn-ghost btn-sm" @onclick="PrevMonth">‹ 이전달</button>
                <span style="font-size:1.05rem; font-weight:500; color:var(--text-dark);">
                    @(_current.Year)년 @(_current.Month)월
                </span>
                <button class="btn btn-ghost btn-sm" @onclick="NextMonth">다음달 ›</button>
            </div>

            @if (_view == "month")
            {
                <!-- ── 월간 뷰 ── -->
                <div style="border:1px solid var(--border); border-radius:var(--radius); overflow:hidden;">
                    <!-- 요일 헤더 -->
                    <div style="display:grid; grid-template-columns:repeat(7,1fr); background:#f8f8f8; border-bottom:1px solid var(--border);">
                        @foreach (var (day, idx) in new[]{"일","월","화","수","목","금","토"}.Select((d,i)=>(d,i)))
                        {
                            string dayColor = idx == 0 ? "#e05a5a" : idx == 6 ? "#6a8fcc" : "#9a9a9a";
                            <div style="text-align:center; padding:8px 0; font-size:0.78rem; font-weight:500;
                                        color:@dayColor;">@day</div>
                        }
                    </div>
                    <!-- 날짜 그리드 -->
                    <div style="display:grid; grid-template-columns:repeat(7,1fr);">
                        @foreach (var cell in _calendarCells)
                        {
                            var isToday = cell.Date == _today;
                            var isOther = cell.Date.Month != _current.Month;
                            var events  = GetEventsForDate(cell.Date);
                            string numColor = isToday ? "#fff" : isOther ? "#9a9a9a" : "var(--black)";
                            <div style="min-height:80px; border-right:0.5px solid var(--border); border-bottom:0.5px solid var(--border);
                                        padding:5px; overflow:hidden; background:@(isToday?"var(--ivory-mid)":"transparent");">
                                <!-- 날짜 숫자 -->
                                <div style="width:22px; height:22px; display:flex; align-items:center; justify-content:center;
                                            border-radius:50%; font-size:0.75rem; font-weight:500; margin-bottom:3px;
                                            background:@(isToday?"var(--text-dark)":"transparent");
                                            color:@numColor;">
                                    @cell.Date.Day
                                </div>
                                <!-- 이벤트: 시작/종료일은 텍스트 칩, 중간날짜는 동그라미 -->
                                @{
                                    var chips  = events.Where(e => e.Label != "·").Take(2).ToList();
                                    var dots   = events.Where(e => e.Label == "·").ToList();
                                }
                                @foreach (var ev in chips)
                                {
                                    <div @onclick="() => GoToProject(ev.Id)" title="@ev.Title"
                                         style="font-size:0.65rem; border-radius:4px; padding:1px 5px; margin-bottom:2px;
                                                white-space:normal; word-break:break-word; overflow-wrap:break-word;
                                                cursor:pointer; display:block; width:100%; box-sizing:border-box;
                                                background:@ev.AccentColor; color:@ev.TextColor;">
                                        @ev.Label @ev.Title
                                    </div>
                                }
                                @if (dots.Any())
                                {
                                    <div style="display:flex; flex-wrap:wrap; gap:2px; margin-top:1px;">
                                        @foreach (var ev in dots.Take(6))
                                        {
                                            <div @onclick="() => GoToProject(ev.Id)" title="@ev.Title"
                                                 style="width:8px; height:8px; border-radius:50%; cursor:pointer;
                                                        background:@ev.AccentColor; opacity:0.85;">
                                            </div>
                                        }
                                        @if (dots.Count > 6)
                                        {
                                            <span style="font-size:0.6rem; color:var(--text-light);">+@(dots.Count-6)</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <!-- ── 타임라인 뷰 ── -->
                <div style="display:flex; flex-direction:column; gap:10px;">
                    @if (!_timelineProjects.Any())
                    {
                        <div class="empty-state" style="padding:40px 0;">
                            <p style="color:var(--text-mid);">이번 달 일정이 있는 프로젝트가 없어요.</p>
                        </div>
                    }
                    @foreach (var proj in _timelineProjects)
                    {
                        var style = GetProjectStyle(proj);
                        var (barLeft, barWidth) = GetTimelineBar(proj);
                        <div class="card" style="padding:14px 16px;">
                            <div style="display:flex; align-items:center; gap:10px; margin-bottom:10px;">
                                <span style="font-size:0.82rem; font-weight:500; color:var(--text-dark);">@proj.Title</span>
                                <span style="font-size:0.75rem; padding:2px 8px; border-radius:9px; font-weight:500; @GetStatusBadgeStyle(proj.Status)">@proj.Status</span>
                            </div>
                            <!-- 바 트랙 -->
                            <div style="position:relative; height:10px; background:#f0f0f0; border-radius:6px; overflow:hidden;">
                                <div style="position:absolute; left:@(barLeft)%; width:@(barWidth)%; height:100%;
                                            background:@style.AccentColor; border-radius:6px; min-width:4px;"></div>
                            </div>
                            <div style="display:flex; justify-content:space-between; margin-top:5px; font-size:0.72rem; color:var(--text-light);">
                                <span>@(proj.StartDate.HasValue ? proj.StartDate.Value.ToString("M/d") : "시작일 미정")</span>
                                <span>@(proj.EndDate.HasValue ? proj.EndDate.Value.ToString("M/d 마감") : "마감일 미정")</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- ── 오른쪽 사이드패널 ── -->
        <div class="calendar-sidebar-panel" style="width:200px; flex-shrink:0; display:flex; flex-direction:column; gap:16px;">

            <!-- 이번달 현황 -->
            <div class="card" style="padding:14px 16px;">
                <div style="font-size:0.82rem; font-weight:500; color:var(--text-dark); margin-bottom:10px;">이번달 현황</div>
                <div style="display:flex; flex-direction:column; gap:8px;">
                    <div style="display:flex; justify-content:space-between; font-size:0.8rem;">
                        <span style="color:var(--text-mid);">진행중</span>
                        <span style="font-weight:500;">@(_activeCount)개</span>
                    </div>
                    <div style="display:flex; justify-content:space-between; font-size:0.8rem;">
                        <span style="color:var(--text-mid);">이번달 마감</span>
                        <span style="font-weight:500; color:#c05070;">@(_deadlineThisMonth)개</span>
                    </div>
                    <div style="display:flex; justify-content:space-between; font-size:0.8rem;">
                        <span style="color:var(--text-mid);">마감 지남</span>
                        <span style="font-weight:500; color:#e05a5a;">@(_overdueCount)개</span>
                    </div>
                </div>
            </div>

            <!-- 다가오는 마감 -->
            <div class="card" style="padding:14px 16px;">
                <div style="font-size:0.82rem; font-weight:500; color:var(--text-dark); margin-bottom:10px;">다가오는 마감</div>
                @if (!_upcomingDeadlines.Any())
                {
                    <p style="font-size:0.78rem; color:var(--text-light);">마감일이 설정된 프로젝트가 없어요.</p>
                }
                @foreach (var proj in _upcomingDeadlines)
                {
                    var daysLeft = (int)(proj.EndDate!.Value.Date - _today).TotalDays;
                    var isUrgent = daysLeft <= 7;
                    var cardBg = isUrgent ? "#fef0f3" : "#fdfaee";
                    var badgeBg = isUrgent ? "#fad5de" : "#faf0c8";
                    var cardText = ContrastText(cardBg);
                    var badgeText = ContrastText(badgeBg);
                    <div @onclick="() => GoToProject(proj.Id)" style="display:flex; align-items:center; gap:8px;
                                padding:8px 10px; border-radius:9px; margin-bottom:6px; cursor:pointer;
                                background:@cardBg;">
                        <div style="flex:1; min-width:0;">
                            <div style="font-size:0.78rem; font-weight:500; color:@cardText;
                                        white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@proj.Title</div>
                            <div style="font-size:0.7rem; color:@cardText; opacity:0.7;">@proj.EndDate.Value.ToString("M월 d일")</div>
                        </div>
                        <span style="font-size:0.68rem; padding:2px 6px; border-radius:4px; white-space:nowrap;
                                     background:@badgeBg; color:@badgeText; font-weight:500;">
                            @(daysLeft == 0 ? "오늘" : daysLeft < 0 ? $"{-daysLeft}일 지남" : $"{daysLeft}일")
                        </span>
                    </div>
                }
            </div>

            <!-- 프로젝트 범례 -->
            @if (_legendProjects.Any())
            {
                <div class="card" style="padding:14px 16px;">
                    <div style="font-size:0.82rem; font-weight:500; color:var(--text-dark); margin-bottom:10px;">프로젝트</div>
                    @foreach (var (proj, style) in _legendProjects)
                    {
                        <div @onclick="() => GoToProject(proj.Id)"
                             style="display:flex; align-items:center; gap:8px; margin-bottom:7px; cursor:pointer;">
                            <div style="width:10px; height:10px; border-radius:50%; background:@style.AccentColor; flex-shrink:0;"></div>
                            <span style="font-size:0.78rem; color:var(--text-mid); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@proj.Title</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<!-- 완성작 상세 팝업 -->
@if (_showFinishedPopup && _finishedPopupProject != null)
{
    <div class="modal-backdrop">
        <div class="modal" style="max-width:740px;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">@_finishedPopupProject.Title</h2>
                <button class="btn btn-ghost btn-sm" @onclick="CloseFinishedPopup">✕</button>
            </div>

            <!-- 사진 갤러리 -->
            @if (_finishedPopupProject.Photos.Count > 0)
            {
                <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px;">
                    @foreach (var photo in _finishedPopupProject.Photos)
                    {
                        <img src="@photo.Base64Data"
                             style="width:130px; height:130px; object-fit:cover; border-radius:var(--radius-sm); border:1px solid var(--border);"
                             alt="과정 사진" />
                    }
                </div>
            }

            <!-- 날짜 바 + 인라인 편집 -->
            <div style="margin-bottom:14px; padding:12px; background:var(--ivory-dark); border-radius:var(--radius-sm);">
                @if (!_calEditingBasicInfo)
                {
                    <div style="display:flex; gap:16px; flex-wrap:wrap; align-items:center;">
                        @if (_finishedPopupProject.StartDate.HasValue)
                        {
                            <div style="text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:2px;">시작일</div>
                                <div style="font-size:0.9rem; font-weight:600;">@_finishedPopupProject.StartDate.Value.ToString("yyyy.MM.dd")</div>
                            </div>
                        }
                        @if (_finishedPopupProject.EndDate.HasValue)
                        {
                            <div style="text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:2px;">완성일</div>
                                <div style="font-size:0.9rem; font-weight:600;">@_finishedPopupProject.EndDate.Value.ToString("yyyy.MM.dd")</div>
                            </div>
                        }
                        @if (_finishedPopupProject.StartDate.HasValue && _finishedPopupProject.EndDate.HasValue)
                        {
                            var popDays = (_finishedPopupProject.EndDate.Value - _finishedPopupProject.StartDate.Value).Days;
                            <div style="text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:2px;">소요일</div>
                                <div style="font-size:0.9rem; font-weight:600; color:#8a6a08;">@popDays 일</div>
                            </div>
                        }
                        @{
                            var popMin = _finishedPopupProject.Sessions
                                .Where(s => s.EndTime.HasValue)
                                .Sum(s => (int)(s.EndTime!.Value - s.StartTime).TotalMinutes);
                        }
                        @if (popMin > 0)
                        {
                            var ph = popMin / 60; var pm = popMin % 60;
                            <div style="text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:2px;">누적 시간</div>
                                <div style="font-size:0.9rem; font-weight:600; color:#267848;">@(ph > 0 ? $"{ph}시간 " : "")@(pm > 0 ? $"{pm}분" : "")</div>
                            </div>
                        }
                        else
                        {
                            <div style="text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:2px;">누적 시간</div>
                                <div style="font-size:0.82rem; color:var(--text-light);">기록 없음</div>
                            </div>
                        }
                        <button class="btn btn-ghost btn-sm" style="font-size:0.72rem; margin-left:auto;"
                                @onclick="() => _calEditingBasicInfo = true">✏️ 수정</button>
                    </div>
                }
                else
                {
                    <div class="form-row" style="margin-bottom:8px;">
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">시작일</label>
                            <input type="date" class="form-control"
                                   value="@_finishedPopupProject.StartDate?.ToString("yyyy-MM-dd")"
                                   @onchange="e => _finishedPopupProject.StartDate = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!)" />
                        </div>
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">완성일</label>
                            <input type="date" class="form-control"
                                   value="@_finishedPopupProject.EndDate?.ToString("yyyy-MM-dd")"
                                   @onchange="e => _finishedPopupProject.EndDate = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!)" />
                        </div>
                    </div>
                    <div style="display:flex; gap:8px;">
                        <button class="btn btn-primary btn-sm" @onclick="SaveCalBasicInfo">저장</button>
                        <button class="btn btn-ghost btn-sm" @onclick="() => _calEditingBasicInfo = false">취소</button>
                    </div>
                }
            </div>

            <!-- 도안 정보 -->
            @if (!string.IsNullOrEmpty(_finishedPopupProject.PatternName))
            {
                <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                    <div class="form-label" style="margin-bottom:4px;">📋 도안</div>
                    <div style="font-size:0.92rem;">@_finishedPopupProject.PatternName</div>
                    @if (!string.IsNullOrEmpty(_finishedPopupProject.PatternSource))
                    {
                        <div style="font-size:0.82rem; color:var(--text-mid);">출처: @_finishedPopupProject.PatternSource</div>
                    }
                    @if (!string.IsNullOrEmpty(_finishedPopupProject.PatternMemo))
                    {
                        <div style="font-size:0.82rem; color:var(--text-mid); margin-top:2px; white-space:pre-wrap;">@_finishedPopupProject.PatternMemo</div>
                    }
                </div>
            }

            <!-- 사용 실 -->
            @{
                var calYarns = _finishedPopupProject.YarnUsages
                    .Select(u => (u, _calYarns.Find(y => y.Id == u.YarnId)))
                    .Where(x => x.Item2 != null)
                    .Select(x => (x.u, x.Item2!))
                    .ToList();
            }
            @if (calYarns.Any())
            {
                <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                    <div class="form-label" style="margin-bottom:6px;">🧵 사용 실</div>
                    @foreach (var (usage, yarn) in calYarns)
                    {
                        <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px; font-size:0.88rem;">
                            <span class="color-dot" style="background:@yarn.ColorCode; flex-shrink:0;"></span>
                            <span>@yarn.Brand @yarn.Name (@yarn.Color)</span>
                            @if (usage.BallsUsed > 0)
                            {
                                <span style="color:var(--text-light); font-size:0.8rem;">@usage.BallsUsed 볼</span>
                            }
                        </div>
                    }
                </div>
            }

            <!-- 사용 바늘 -->
            @{
                var calTools = _calTools.Where(t => _finishedPopupProject.ToolIds.Contains(t.Id)).ToList();
            }
            @if (calTools.Any() || !string.IsNullOrEmpty(_finishedPopupProject.NeedleNote))
            {
                <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                    <div class="form-label" style="margin-bottom:6px;">⚒️ 사용 바늘</div>
                    <div style="display:flex; flex-wrap:wrap; gap:6px;">
                        @foreach (var tool in calTools)
                        {
                            <span style="background:var(--ivory-dark); border-radius:4px; padding:3px 8px; font-size:0.8rem;">@tool.NeedleType @tool.SizeDisplay</span>
                        }
                        @if (!string.IsNullOrEmpty(_finishedPopupProject.NeedleNote))
                        {
                            <span style="background:var(--ivory-dark); border-radius:4px; padding:3px 8px; font-size:0.8rem;">@_finishedPopupProject.NeedleNote</span>
                        }
                    </div>
                </div>
            }

            <!-- 스와치 -->
            @{
                var calSwatches = _calSwatches.Where(s => s.ProjectId == _finishedPopupProject.Id).ToList();
            }
            @if (calSwatches.Any())
            {
                <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                    <div class="form-label" style="margin-bottom:6px;">📐 스와치</div>
                    @foreach (var s in calSwatches)
                    {
                        <div style="background:var(--ivory-dark); border-radius:var(--radius-sm); padding:10px 12px; margin-bottom:6px; font-size:0.84rem;">
                            <div style="font-weight:600; margin-bottom:6px;">@(string.IsNullOrEmpty(s.Name) ? "스와치" : s.Name)
                                @if (!string.IsNullOrEmpty(s.Stitch))
                                {
                                    <span style="font-weight:400; color:var(--text-mid); margin-left:6px;">(@s.Stitch)</span>
                                }
                                @if (s.NeedleSizeMm > 0)
                                {
                                    <span style="font-weight:400; color:var(--text-mid); margin-left:6px;">@(s.NeedleSizeMm)mm</span>
                                }
                            </div>
                            <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
                                <div>
                                    <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:3px;">세탁 전</div>
                                    @if (s.PreWashStitches > 0 || s.PreWashRows > 0)
                                    {
                                        <div>@(s.PreWashStitches)코 × @(s.PreWashRows)단</div>
                                    }
                                    @if (s.PreWashWidthCm > 0 || s.PreWashHeightCm > 0)
                                    {
                                        <div style="color:var(--text-mid);">@(s.PreWashWidthCm)cm × @(s.PreWashHeightCm)cm</div>
                                    }
                                </div>
                                @if (s.PostWashStitches > 0 || s.PostWashWidthCm > 0)
                                {
                                    <div>
                                        <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:3px;">세탁 후</div>
                                        @if (s.PostWashStitches > 0 || s.PostWashRows > 0)
                                        {
                                            <div>@(s.PostWashStitches)코 × @(s.PostWashRows)단</div>
                                        }
                                        @if (s.PostWashWidthCm > 0 || s.PostWashHeightCm > 0)
                                        {
                                            <div style="color:var(--text-mid);">@(s.PostWashWidthCm)cm × @(s.PostWashHeightCm)cm</div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- 완성 치수 -->
            <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px;">
                    <div class="form-label" style="margin-bottom:0;">📏 완성 치수</div>
                    @if (!_calEditingMeasurements)
                    {
                        <button class="btn btn-ghost btn-sm" style="font-size:0.75rem;" @onclick="() => { LoadCalMeasures(); _calEditingMeasurements = true; }">✏️ 입력</button>
                    }
                </div>
                @if (!_calEditingMeasurements)
                {
                    @if (_calMeasures.Any(m => !string.IsNullOrEmpty(m.Before) || !string.IsNullOrEmpty(m.After)))
                    {
                        <div style="border:0.5px solid var(--border); border-radius:var(--radius-sm); overflow:hidden; font-size:0.82rem;">
                            <div style="display:grid; grid-template-columns:120px 1fr 1fr; background:#f8f8f8; border-bottom:0.5px solid var(--border);">
                                <div style="padding:6px 10px; color:var(--text-mid); font-weight:500;">항목</div>
                                <div style="padding:6px 10px; color:var(--text-mid); font-weight:500; border-left:0.5px solid var(--border);">세탁 전</div>
                                <div style="padding:6px 10px; color:var(--text-mid); font-weight:500; border-left:0.5px solid var(--border);">세탁 후</div>
                            </div>
                            @foreach (var m in _calMeasures)
                            {
                                @if (!string.IsNullOrEmpty(m.Before) || !string.IsNullOrEmpty(m.After))
                                {
                                    <div style="display:grid; grid-template-columns:120px 1fr 1fr; border-top:0.5px solid var(--border);">
                                        <div style="padding:6px 10px; color:var(--text-dark);">@m.Label</div>
                                        <div style="padding:6px 10px; color:var(--text-mid); border-left:0.5px solid var(--border);">@(string.IsNullOrEmpty(m.Before) ? "-" : m.Before + "cm")</div>
                                        <div style="padding:6px 10px; color:var(--text-mid); border-left:0.5px solid var(--border);">@(string.IsNullOrEmpty(m.After) ? "-" : m.After + "cm")</div>
                                    </div>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <p style="font-size:0.82rem; color:var(--text-light);">치수 정보가 없어요.</p>
                    }
                }
                else
                {
                    <div style="border:0.5px solid var(--border); border-radius:var(--radius-sm); overflow:hidden; font-size:0.82rem; margin-bottom:8px;">
                        <div style="display:grid; grid-template-columns:120px 1fr 1fr; background:#f8f8f8; border-bottom:0.5px solid var(--border);">
                            <div style="padding:6px 10px; color:var(--text-mid); font-weight:500;">항목</div>
                            <div style="padding:6px 10px; color:var(--text-mid); font-weight:500; border-left:0.5px solid var(--border);">세탁 전 (cm)</div>
                            <div style="padding:6px 10px; color:var(--text-mid); font-weight:500; border-left:0.5px solid var(--border);">세탁 후 (cm)</div>
                        </div>
                        @foreach (var m in _calMeasures)
                        {
                            <div style="display:grid; grid-template-columns:120px 1fr 1fr; border-top:0.5px solid var(--border);">
                                <div style="padding:4px 6px; display:flex; align-items:center; gap:4px;">
                                    @if (m.IsCustom)
                                    {
                                        <input class="form-control" style="border:none; padding:3px 6px; font-size:0.82rem; width:100%;"
                                               @bind="m.Label" placeholder="항목명" />
                                        <button class="btn btn-danger btn-sm" style="padding:1px 5px; font-size:0.7rem; flex-shrink:0;" @onclick="() => _calMeasures.Remove(m)">✕</button>
                                    }
                                    else
                                    {
                                        <span style="padding:3px 4px; color:var(--text-dark);">@m.Label</span>
                                    }
                                </div>
                                <div style="border-left:0.5px solid var(--border); padding:2px 6px;">
                                    <input class="form-control" style="border:none; padding:4px 6px; font-size:0.82rem;"
                                           @bind="m.Before" placeholder="-" />
                                </div>
                                <div style="border-left:0.5px solid var(--border); padding:2px 6px;">
                                    <input class="form-control" style="border:none; padding:4px 6px; font-size:0.82rem;"
                                           @bind="m.After" placeholder="-" />
                                </div>
                            </div>
                        }
                    </div>
                    <div style="display:flex; gap:8px; margin-bottom:8px;">
                        <button class="btn btn-ghost btn-sm" @onclick="() => _calMeasures.Add(new CalMeasureItem { IsCustom = true })">+ 항목 추가</button>
                    </div>
                    <div style="display:flex; gap:8px;">
                        <button class="btn btn-primary btn-sm" @onclick="SaveCalMeasurements">저장</button>
                        <button class="btn btn-ghost btn-sm" @onclick="CancelCalMeasurements">취소</button>
                    </div>
                }
            </div>

            <!-- 메모 -->
            @if (!string.IsNullOrEmpty(_finishedPopupProject.Memo))
            {
                <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                    <div class="form-label" style="margin-bottom:4px;">📝 메모</div>
                    <p style="white-space:pre-wrap; font-size:0.9rem; color:var(--text-mid);">@_finishedPopupProject.Memo</p>
                </div>
            }

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseFinishedPopup">닫기</button>
                <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("finished")'>완성작 목록 →</button>
            </div>
        </div>
    </div>
}

@code {
    // ── 상태 ───────────────────────────────────────────────────────────
    bool _loading = true;
    string _view  = "month";
    bool _showFinishedPopup = false;
    KnitProject? _finishedPopupProject;
    bool _calEditingBasicInfo = false;
    bool _calEditingMeasurements = false;
    List<Yarn> _calYarns = new();
    List<KnitTool> _calTools = new();
    List<Swatch> _calSwatches = new();

    class CalMeasureItem
    {
        public string Label { get; set; } = "";
        public string Before { get; set; } = "";
        public string After  { get; set; } = "";
        public bool IsCustom { get; set; } = false;
    }
    static readonly string[] _calDefaultLabels = { "가슴둘레", "총장", "소매 길이", "소매 단면" };
    List<CalMeasureItem> _calMeasures = new();
    DateTime _today   = DateTime.Today;
    DateTime _current = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

    List<KnitProject> _allProjects = new();
    List<CalendarCell>  _calendarCells    = new();
    List<KnitProject>   _timelineProjects = new();
    List<KnitProject>   _upcomingDeadlines = new();
    List<(KnitProject, ProjectStyle)> _legendProjects = new();

    int _activeCount        = 0;
    int _deadlineThisMonth  = 0;
    int _overdueCount       = 0;

    // ── 색상 팔레트 (프로젝트 인덱스별 순환) ──────────────────────────
    static readonly (string Pale, string Accent, string Text)[] _palette = new[]
    {
        ("#dff2e8", "#5aaa7a", "#2a6a3a"),
        ("#fef0f3", "#f2b8c6", "#8a3a4a"),
        ("#fdfaee", "#f7e4a0", "#7a6020"),
        ("#f4f0fc", "#c8b8e8", "#4a3a7a"),
        ("#edf5fc", "#b8d8f0", "#2a5070"),
        ("#fff3e0", "#ffb74d", "#7a4a00"),
    };

    record ProjectStyle(string PaleBg, string AccentColor, string TextColor);
    record CalendarCell(DateTime Date);
    record CalendarEvent(Guid Id, string Title, string Label, string PaleBg, string AccentColor, string TextColor);

    // ── 초기화 ────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        // 마지막 뷰 복원
        var savedView = await JS.InvokeAsync<string?>("localStorage.getItem", "cal_view");
        if (!string.IsNullOrEmpty(savedView)) _view = savedView;
        _allProjects = await Storage.GetProjectsAsync();
        _calYarns    = await Storage.GetYarnsAsync();
        _calTools    = await Storage.GetToolsAsync();
        _calSwatches = await Storage.GetSwatchesAsync();
        Rebuild();
        _loading = false;
    }

    void Rebuild()
    {
        BuildCalendarCells();
        BuildStats();
        BuildTimeline();
        BuildDeadlines();
        BuildLegend();
    }

    void BuildCalendarCells()
    {
        _calendarCells.Clear();
        var first     = _current;
        var startCell = first.AddDays(-(int)first.DayOfWeek);
        for (int i = 0; i < 42; i++)
            _calendarCells.Add(new CalendarCell(startCell.AddDays(i)));
    }

    void BuildStats()
    {
        var active = _allProjects.Where(p =>
            p.Status != ProjectStatus.위시리스트).ToList();
        _activeCount       = active.Count(p => p.Status == ProjectStatus.진행중);
        _overdueCount      = active.Count(p => p.EndDate.HasValue && p.EndDate.Value.Date < _today);
        _deadlineThisMonth = active.Count(p => p.EndDate.HasValue
            && p.EndDate.Value.Year == _current.Year
            && p.EndDate.Value.Month == _current.Month);
    }

    void BuildTimeline()
    {
        var monthStart = _current;
        var monthEnd   = _current.AddMonths(1).AddDays(-1);
        _timelineProjects = _allProjects
            .Where(p => p.Status != ProjectStatus.위시리스트)
            .Where(p => p.StartDate.HasValue || p.EndDate.HasValue)
            .Where(p =>
                (!p.StartDate.HasValue || p.StartDate.Value.Date <= monthEnd) &&
                (!p.EndDate.HasValue   || p.EndDate.Value.Date   >= monthStart))
            .OrderBy(p => p.StartDate ?? p.EndDate)
            .ToList();
    }

    void BuildDeadlines()
    {
        _upcomingDeadlines = _allProjects
            .Where(p => p.Status != ProjectStatus.완료 && p.Status != ProjectStatus.위시리스트)
            .Where(p => p.EndDate.HasValue)
            .OrderBy(p => p.EndDate)
            .Take(5)
            .ToList();
    }

    void BuildLegend()
    {
        var visible = _allProjects
            .Where(p => p.Status != ProjectStatus.위시리스트)
            .Take(6)
            .ToList();
        _legendProjects = visible
            .Select(p => (p, GetProjectStyle(p)))
            .ToList();
    }

    // ── 이벤트 조회 ───────────────────────────────────────────────────
    List<CalendarEvent> GetEventsForDate(DateTime date)
    {
        var result = new List<CalendarEvent>();
        var relevant = _allProjects
            .Where(p => p.Status != ProjectStatus.위시리스트)
            .ToList();

        for (int i = 0; i < relevant.Count; i++)
        {
            var p = relevant[i];
            var s = GetProjectStyle(p);

            bool isStart    = p.StartDate.HasValue && p.StartDate.Value.Date == date;
            bool isEnd      = p.EndDate.HasValue   && p.EndDate.Value.Date   == date;
            bool isInRange  = p.StartDate.HasValue && p.EndDate.HasValue
                              && p.StartDate.Value.Date < date && date < p.EndDate.Value.Date;

            if (isStart || isEnd)
                result.Add(new CalendarEvent(p.Id, p.Title,
                    isStart && isEnd ? "📌" : isStart ? "▶" : "🏁",
                    s.PaleBg, s.AccentColor, s.TextColor));
            else if (isInRange)
                result.Add(new CalendarEvent(p.Id, p.Title, "·", s.PaleBg, s.AccentColor, s.TextColor));
        }
        return result;
    }

    // ── 타임라인 바 위치 계산 (이번달 기준 %) ─────────────────────────
    (double left, double width) GetTimelineBar(KnitProject proj)
    {
        var monthStart = _current;
        var monthEnd   = _current.AddMonths(1).AddDays(-1);
        int totalDays  = (int)(monthEnd - monthStart).TotalDays + 1;

        var start = proj.StartDate.HasValue
            ? (proj.StartDate.Value.Date < monthStart ? monthStart : proj.StartDate.Value.Date)
            : monthStart;
        var end = proj.EndDate.HasValue
            ? (proj.EndDate.Value.Date > monthEnd ? monthEnd : proj.EndDate.Value.Date)
            : monthEnd;

        double left  = Math.Max(0, (start - monthStart).TotalDays / totalDays * 100);
        double width = Math.Max(2, (end - start).TotalDays + 1) / totalDays * 100;
        width = Math.Min(width, 100 - left);
        return (Math.Round(left, 1), Math.Round(width, 1));
    }

    // ── 스타일 헬퍼 ───────────────────────────────────────────────────

    // hex 색상의 상대 밝기 계산 (0=어둠, 1=밝음)
    static double HexLuminance(string hex)
    {
        hex = hex.TrimStart('#');
        if (hex.Length < 6) return 0.5;
        int r = Convert.ToInt32(hex[0..2], 16);
        int g = Convert.ToInt32(hex[2..4], 16);
        int b = Convert.ToInt32(hex[4..6], 16);
        // sRGB 상대 밝기 공식
        double Linearize(int c) { double s = c / 255.0; return s <= 0.04045 ? s / 12.92 : Math.Pow((s + 0.055) / 1.055, 2.4); }
        return 0.2126 * Linearize(r) + 0.7152 * Linearize(g) + 0.0722 * Linearize(b);
    }

    // 배경색에 따라 흰색/검정 텍스트 자동 선택
    static string ContrastText(string hex) => HexLuminance(hex) > 0.35 ? "#111111" : "#ffffff";

    ProjectStyle GetStyle(int index)
    {
        var (pale, accent, _) = _palette[index % _palette.Length];
        return new ProjectStyle(pale, accent, ContrastText(accent));
    }

    ProjectStyle GetProjectStyle(KnitProject proj)
    {
        if (!string.IsNullOrEmpty(proj.ColorCode))
        {
            var chipText = ContrastText(proj.ColorCode);
            return new ProjectStyle(proj.ColorCode + "33", proj.ColorCode, chipText);
        }
        int idx = Math.Abs(proj.Id.GetHashCode()) % _palette.Length;
        return GetStyle(idx);
    }

    string GetStatusBadgeStyle(ProjectStatus s) => s switch
    {
        ProjectStatus.완료     => "background:#e6f4ea; color:#267848; border:1px solid #b8e0c8;",
        ProjectStatus.진행중   => "background:#fffbe6; color:#b58a00; border:1px solid #f5d97a;",
        ProjectStatus.일시중단 => "background:#fef0f0; color:#c0392b; border:1px solid #f5c0c0;",
        _                      => "background:#f0f0f0; color:#888;"
    };

    // ── 네비게이션 ────────────────────────────────────────────────────
    void PrevMonth()
    {
        _current = _current.AddMonths(-1);
        Rebuild();
    }

    void NextMonth()
    {
        _current = _current.AddMonths(1);
        Rebuild();
    }

    void GoToProject(Guid id)
    {
        var proj = _allProjects.FirstOrDefault(p => p.Id == id);
        if (proj?.Status == ProjectStatus.완료)
        {
            _finishedPopupProject = proj;
            _calEditingBasicInfo = false;
            _calEditingMeasurements = false;
            LoadCalMeasures();
            _showFinishedPopup = true;
        }
        else
        {
            Nav.NavigateTo("projects/" + id);
        }
    }

    void CloseFinishedPopup()
    {
        _showFinishedPopup = false;
        _finishedPopupProject = null;
        _calEditingBasicInfo = false;
        _calEditingMeasurements = false;
        _calMeasures.Clear();
    }

    void LoadCalMeasures()
    {
        if (_finishedPopupProject == null) return;
        var dict = new Dictionary<string, (string, string)>();
        if (!string.IsNullOrEmpty(_finishedPopupProject.MeasurementsMemo))
        {
            foreach (var part in _finishedPopupProject.MeasurementsMemo.Split('|'))
            {
                var seg = part.Split(':');
                if (seg.Length >= 3) dict[seg[0]] = (seg[1], seg[2]);
                else if (seg.Length == 2) dict[seg[0]] = (seg[1], "");
            }
        }
        _calMeasures = new List<CalMeasureItem>();
        foreach (var label in _calDefaultLabels)
        {
            var (b, a) = dict.TryGetValue(label, out var v) ? v : ("", "");
            _calMeasures.Add(new CalMeasureItem { Label = label, Before = b, After = a, IsCustom = false });
            dict.Remove(label);
        }
        foreach (var kv in dict)
            _calMeasures.Add(new CalMeasureItem { Label = kv.Key, Before = kv.Value.Item1, After = kv.Value.Item2, IsCustom = true });
    }

    async Task SaveCalBasicInfo()
    {
        if (_finishedPopupProject == null) return;
        await Storage.SaveProjectAsync(_finishedPopupProject);
        _calEditingBasicInfo = false;
        _allProjects = await Storage.GetProjectsAsync();
        Rebuild();
    }

    async Task SaveCalMeasurements()
    {
        if (_finishedPopupProject == null) return;
        _finishedPopupProject.MeasurementsMemo = string.Join("|",
            _calMeasures
                .Where(m => !string.IsNullOrEmpty(m.Label) && (!string.IsNullOrEmpty(m.Before) || !string.IsNullOrEmpty(m.After)))
                .Select(m => $"{m.Label}:{m.Before}:{m.After}"));
        await Storage.SaveProjectAsync(_finishedPopupProject);
        _calEditingMeasurements = false;
    }

    void CancelCalMeasurements()
    {
        LoadCalMeasures();
        _calEditingMeasurements = false;
    }
}
