@* =====================================================================
   Pages/Finished.razor  —  완성작 갤러리
   ===================================================================== *@
@page "/finished"
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage

<div class="page-header">
    <div>
        <h1 class="page-title">✅ 완성작</h1>
        <p class="page-subtitle">지금까지 완성한 작품들</p>
    </div>
</div>

@if (_loading)
{
    <div class="loading">불러오는 중...</div>
}
else if (_projects.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">🎉</div>
        <p>아직 완성작이 없어요.<br/>뜨케줄에서 작품을 완성하면 여기로 이동해요!</p>
    </div>
}
else
{
    <div class="grid-3">
        @foreach (var proj in _projects)
        {
            <div class="card" style="cursor:pointer;" @onclick="() => OpenDetail(proj)">
                @if (proj.Photos.Count > 0)
                {
                    <img src="@proj.Photos[0].Base64Data"
                         style="width:100%; height:180px; object-fit:cover; border-radius:var(--radius-sm); margin-bottom:12px;"
                         alt="완성 사진" />
                }
                else
                {
                    <div style="width:100%; height:100px; background:#e8e8e8; border-radius:var(--radius-sm);
                                display:flex; align-items:center; justify-content:center; font-size:2.5rem; margin-bottom:12px;">👕</div>
                }
                <div class="card-title">@proj.Title</div>
                @if (!string.IsNullOrEmpty(proj.PatternName))
                {
                    <div style="font-size:0.8rem; color:var(--text-mid);">@proj.PatternName</div>
                }
                @if (proj.EndDate.HasValue)
                {
                    <div style="font-size:0.78rem; color:var(--text-light); margin-top:6px;">
                        완성일: @proj.EndDate.Value.ToString("yyyy년 M월 d일")
                    </div>
                }
                @if (proj.StartDate.HasValue && proj.EndDate.HasValue)
                {
                    var days = (proj.EndDate.Value - proj.StartDate.Value).Days;
                    <div style="font-size:0.78rem; color:#8a6a08; margin-top:2px;">총 @(days)일 소요</div>
                }
            </div>
        }
    </div>
}

<!-- 상세 모달 -->
@if (_showDetail && _selectedProject != null)
{
    <div class="modal-backdrop">
        <div class="modal" style="max-width:740px;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">@_selectedProject.Title</h2>
                <button class="btn btn-ghost btn-sm" @onclick="CloseDetail">✕</button>
            </div>

            <!-- 사진 갤러리 -->
            @if (_selectedProject.Photos.Count > 0)
            {
                <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px;">
                    @foreach (var photo in _selectedProject.Photos)
                    {
                        <img src="@photo.Base64Data"
                             style="width:130px; height:130px; object-fit:cover; border-radius:var(--radius-sm); border:1px solid var(--border);"
                             alt="과정 사진" />
                    }
                </div>
            }

            <!-- 날짜 / 소요일 / 누적시간 + 인라인 편집 -->
            <div style="margin-bottom:14px; padding:12px; background:var(--ivory-dark); border-radius:var(--radius-sm);">
                @if (!_editingBasicInfo)
                {
                    <!-- 보기 모드 -->
                    <div style="display:flex; gap:16px; flex-wrap:wrap; align-items:center;">
                        @if (_selectedProject.StartDate.HasValue)
                        {
                            <div style="text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:2px;">시작일</div>
                                <div style="font-size:0.9rem; font-weight:600;">@_selectedProject.StartDate.Value.ToString("yyyy.MM.dd")</div>
                            </div>
                        }
                        @if (_selectedProject.EndDate.HasValue)
                        {
                            <div style="text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:2px;">완성일</div>
                                <div style="font-size:0.9rem; font-weight:600;">@_selectedProject.EndDate.Value.ToString("yyyy.MM.dd")</div>
                            </div>
                        }
                        @if (_selectedProject.StartDate.HasValue && _selectedProject.EndDate.HasValue)
                        {
                            var days = (_selectedProject.EndDate.Value - _selectedProject.StartDate.Value).Days;
                            <div style="text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:2px;">소요일</div>
                                <div style="font-size:0.9rem; font-weight:600; color:#8a6a08;">@days 일</div>
                            </div>
                        }
                        @{
                            var completedMin = _selectedProject.Sessions
                                .Where(s => s.EndTime.HasValue)
                                .Sum(s => (int)(s.EndTime!.Value - s.StartTime).TotalMinutes);
                        }
                        @if (completedMin > 0)
                        {
                            var h = completedMin / 60; var m = completedMin % 60;
                            <div style="text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:2px;">누적 시간</div>
                                <div style="font-size:0.9rem; font-weight:600; color:#267848;">@(h > 0 ? $"{h}시간 " : "")@(m > 0 ? $"{m}분" : "")</div>
                            </div>
                        }
                        else
                        {
                            <div style="text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:2px;">누적 시간</div>
                                <div style="font-size:0.82rem; color:var(--text-light);">기록 없음</div>
                            </div>
                        }
                        <button class="btn btn-ghost btn-sm" style="font-size:0.72rem; margin-left:auto;"
                                @onclick="() => _editingBasicInfo = true">✏️ 수정</button>
                    </div>
                }
                else
                {
                    <!-- 편집 모드 -->
                    <div class="form-row" style="margin-bottom:8px;">
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">시작일</label>
                            <input type="date" class="form-control"
                                   value="@_selectedProject.StartDate?.ToString("yyyy-MM-dd")"
                                   @onchange="e => _selectedProject.StartDate = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!)" />
                        </div>
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">완성일</label>
                            <input type="date" class="form-control"
                                   value="@_selectedProject.EndDate?.ToString("yyyy-MM-dd")"
                                   @onchange="e => _selectedProject.EndDate = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!)" />
                        </div>
                    </div>
                    <div style="display:flex; gap:8px;">
                        <button class="btn btn-primary btn-sm" @onclick="SaveBasicInfo">저장</button>
                        <button class="btn btn-ghost btn-sm" @onclick="() => _editingBasicInfo = false">취소</button>
                    </div>
                }
            </div>

            <!-- 도안 정보 -->
            @if (!string.IsNullOrEmpty(_selectedProject.PatternName))
            {
                <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                    <div class="form-label" style="margin-bottom:4px;">📋 도안</div>
                    <div style="font-size:0.92rem;">@_selectedProject.PatternName</div>
                    @if (!string.IsNullOrEmpty(_selectedProject.PatternSource))
                    {
                        <div style="font-size:0.82rem; color:var(--text-mid);">출처: @_selectedProject.PatternSource</div>
                    }
                    @if (!string.IsNullOrEmpty(_selectedProject.PatternMemo))
                    {
                        <div style="font-size:0.82rem; color:var(--text-mid); margin-top:2px; white-space:pre-wrap;">@_selectedProject.PatternMemo</div>
                    }
                </div>
            }

            <!-- 사용 실 -->
            @if (_selectedYarns.Count > 0)
            {
                <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                    <div class="form-label" style="margin-bottom:6px;">🧵 사용 실</div>
                    @foreach (var (usage, yarn) in _selectedYarns)
                    {
                        <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px; font-size:0.88rem;">
                            <span class="color-dot" style="background:@yarn.ColorCode; flex-shrink:0;"></span>
                            <span>@yarn.Brand @yarn.Name (@yarn.Color)</span>
                            @if (usage.BallsUsed > 0)
                            {
                                <span style="color:var(--text-light); font-size:0.8rem;">@usage.BallsUsed 볼</span>
                            }
                        </div>
                    }
                </div>
            }

            <!-- 사용 바늘 -->
            @if (_selectedTools.Count > 0 || !string.IsNullOrEmpty(_selectedProject.NeedleNote))
            {
                <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                    <div class="form-label" style="margin-bottom:6px;">⚒️ 사용 바늘</div>
                    <div style="display:flex; flex-wrap:wrap; gap:6px;">
                        @foreach (var tool in _selectedTools)
                        {
                            <span style="background:var(--ivory-dark); border-radius:4px; padding:3px 8px; font-size:0.8rem;">@tool.NeedleType @tool.SizeDisplay</span>
                        }
                        @if (!string.IsNullOrEmpty(_selectedProject.NeedleNote))
                        {
                            <span style="background:var(--ivory-dark); border-radius:4px; padding:3px 8px; font-size:0.8rem;">@_selectedProject.NeedleNote</span>
                        }
                    </div>
                </div>
            }

            <!-- 스와치 -->
            @if (_selectedSwatches.Count > 0)
            {
                <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                    <div class="form-label" style="margin-bottom:6px;">📐 스와치</div>
                    @foreach (var s in _selectedSwatches)
                    {
                        <div style="background:var(--ivory-dark); border-radius:var(--radius-sm); padding:10px 12px; margin-bottom:6px; font-size:0.84rem;">
                            <div style="font-weight:600; margin-bottom:6px;">@(string.IsNullOrEmpty(s.Name) ? "스와치" : s.Name)
                                @if (!string.IsNullOrEmpty(s.Stitch))
                                {
                                    <span style="font-weight:400; color:var(--text-mid); margin-left:6px;">(@s.Stitch)</span>
                                }
                                @if (s.NeedleSizeMm > 0)
                                {
                                    <span style="font-weight:400; color:var(--text-mid); margin-left:6px;">@(s.NeedleSizeMm)mm</span>
                                }
                            </div>
                            <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
                                <div>
                                    <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:3px;">세탁 전</div>
                                    @if (s.PreWashStitches > 0 || s.PreWashRows > 0)
                                    {
                                        <div>@(s.PreWashStitches)코 × @(s.PreWashRows)단</div>
                                    }
                                    @if (s.PreWashWidthCm > 0 || s.PreWashHeightCm > 0)
                                    {
                                        <div style="color:var(--text-mid);">@(s.PreWashWidthCm)cm × @(s.PreWashHeightCm)cm</div>
                                    }
                                </div>
                                @if (s.PostWashStitches > 0 || s.PostWashWidthCm > 0)
                                {
                                    <div>
                                        <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:3px;">세탁 후</div>
                                        @if (s.PostWashStitches > 0 || s.PostWashRows > 0)
                                        {
                                            <div>@(s.PostWashStitches)코 × @(s.PostWashRows)단</div>
                                        }
                                        @if (s.PostWashWidthCm > 0 || s.PostWashHeightCm > 0)
                                        {
                                            <div style="color:var(--text-mid);">@(s.PostWashWidthCm)cm × @(s.PostWashHeightCm)cm</div>
                                        }
                                        @if (s.WidthShrinkagePercent != 0 || s.HeightShrinkagePercent != 0)
                                        {
                                            <div style="font-size:0.75rem; margin-top:2px;">
                                                <span style="color:@(s.WidthShrinkagePercent < 0 ? "#c0392b" : "#267848");">가로 @(s.WidthShrinkagePercent > 0 ? "+" : "")@(s.WidthShrinkagePercent)%</span>
                                                <span style="color:@(s.HeightShrinkagePercent < 0 ? "#c0392b" : "#267848"); margin-left:6px;">세로 @(s.HeightShrinkagePercent > 0 ? "+" : "")@(s.HeightShrinkagePercent)%</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- 완성 치수 -->
            <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px;">
                    <div class="form-label" style="margin-bottom:0;">📏 완성 치수</div>
                    @if (!_editingMeasurements)
                    {
                        <button class="btn btn-ghost btn-sm" style="font-size:0.75rem;" @onclick="() => _editingMeasurements = true">✏️ 입력</button>
                    }
                </div>
                @if (!_editingMeasurements)
                {
                    @if (_measures.Any(m => !string.IsNullOrEmpty(m.Before) || !string.IsNullOrEmpty(m.After)))
                    {
                        <div style="border:0.5px solid var(--border); border-radius:var(--radius-sm); overflow:hidden; font-size:0.82rem;">
                            <div style="display:grid; grid-template-columns:120px 1fr 1fr; background:#f8f8f8; border-bottom:0.5px solid var(--border);">
                                <div style="padding:6px 10px; color:var(--text-mid); font-weight:500;">항목</div>
                                <div style="padding:6px 10px; color:var(--text-mid); font-weight:500; border-left:0.5px solid var(--border);">세탁 전</div>
                                <div style="padding:6px 10px; color:var(--text-mid); font-weight:500; border-left:0.5px solid var(--border);">세탁 후</div>
                            </div>
                            @foreach (var m in _measures)
                            {
                                @if (!string.IsNullOrEmpty(m.Before) || !string.IsNullOrEmpty(m.After))
                                {
                                    <div style="display:grid; grid-template-columns:120px 1fr 1fr; border-top:0.5px solid var(--border);">
                                        <div style="padding:6px 10px; color:var(--text-dark);">@m.Label</div>
                                        <div style="padding:6px 10px; color:var(--text-mid); border-left:0.5px solid var(--border);">@(string.IsNullOrEmpty(m.Before) ? "-" : m.Before + "cm")</div>
                                        <div style="padding:6px 10px; color:var(--text-mid); border-left:0.5px solid var(--border);">@(string.IsNullOrEmpty(m.After) ? "-" : m.After + "cm")</div>
                                    </div>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <p style="font-size:0.82rem; color:var(--text-light);">치수 정보가 없어요.</p>
                    }
                }
                else
                {
                    <div style="border:0.5px solid var(--border); border-radius:var(--radius-sm); overflow:hidden; font-size:0.82rem; margin-bottom:8px;">
                        <div style="display:grid; grid-template-columns:120px 1fr 1fr; background:#f8f8f8; border-bottom:0.5px solid var(--border);">
                            <div style="padding:6px 10px; color:var(--text-mid); font-weight:500;">항목</div>
                            <div style="padding:6px 10px; color:var(--text-mid); font-weight:500; border-left:0.5px solid var(--border);">세탁 전 (cm)</div>
                            <div style="padding:6px 10px; color:var(--text-mid); font-weight:500; border-left:0.5px solid var(--border);">세탁 후 (cm)</div>
                        </div>
                        @foreach (var m in _measures)
                        {
                            <div style="display:grid; grid-template-columns:120px 1fr 1fr; border-top:0.5px solid var(--border);">
                                <div style="padding:4px 6px; display:flex; align-items:center; gap:4px;">
                                    @if (m.IsCustom)
                                    {
                                        <input class="form-control" style="border:none; padding:3px 6px; font-size:0.82rem; width:100%;"
                                               @bind="m.Label" placeholder="항목명" />
                                        <button class="btn btn-danger btn-sm" style="padding:1px 5px; font-size:0.7rem; flex-shrink:0;" @onclick="() => _measures.Remove(m)">✕</button>
                                    }
                                    else
                                    {
                                        <span style="padding:3px 4px; color:var(--text-dark);">@m.Label</span>
                                    }
                                </div>
                                <div style="border-left:0.5px solid var(--border); padding:2px 6px;">
                                    <input class="form-control" style="border:none; padding:4px 6px; font-size:0.82rem;"
                                           @bind="m.Before" placeholder="-" />
                                </div>
                                <div style="border-left:0.5px solid var(--border); padding:2px 6px;">
                                    <input class="form-control" style="border:none; padding:4px 6px; font-size:0.82rem;"
                                           @bind="m.After" placeholder="-" />
                                </div>
                            </div>
                        }
                    </div>
                    <div style="display:flex; gap:8px; margin-bottom:8px;">
                        <button class="btn btn-ghost btn-sm" @onclick="AddCustomMeasure">+ 항목 추가</button>
                    </div>
                    <div style="display:flex; gap:8px;">
                        <button class="btn btn-primary btn-sm" @onclick="SaveMeasurements">저장</button>
                        <button class="btn btn-ghost btn-sm" @onclick="CancelMeasurements">취소</button>
                    </div>
                }
            </div>

            <!-- 메모 -->
            @if (!string.IsNullOrEmpty(_selectedProject.Memo))
            {
                <div style="margin-bottom:12px; padding-top:12px; border-top:1px solid var(--border);">
                    <div class="form-label" style="margin-bottom:4px;">📝 메모</div>
                    <p style="white-space:pre-wrap; font-size:0.9rem; color:var(--text-mid);">@_selectedProject.Memo</p>
                </div>
            }

            <div class="modal-footer">
                <button class="btn btn-danger btn-sm" @onclick='() => Confirm("이 완성작을 삭제하면 복구할 수 없어요.", async () => await DeleteProject(_selectedProject!.Id))'>삭제</button>
                <button class="btn btn-secondary btn-sm" @onclick="() => RestoreToSchedule(_selectedProject.Id)">↩ 문어발로 복귀</button>
                <button class="btn btn-ghost" @onclick="CloseDetail">닫기</button>
            </div>
        </div>
    </div>
}

<!-- 삭제 확인 모달 -->
@if (_showConfirm)
{
    <div class="modal-backdrop" style="z-index:9999;">
        <div class="modal" style="max-width:360px; text-align:center;" @onclick:stopPropagation="true">
            <div style="font-size:2rem; margin-bottom:12px;">🗑️</div>
            <div style="font-size:1rem; font-weight:600; margin-bottom:8px; color:var(--text-dark);">정말 삭제할까요?</div>
            <div style="font-size:0.88rem; color:var(--text-mid); margin-bottom:20px;">@_confirmMsg</div>
            <div style="display:flex; gap:10px; justify-content:center;">
                <button class="btn btn-ghost" @onclick="() => _showConfirm = false">취소</button>
                <button class="btn btn-danger" @onclick="ExecuteConfirm">삭제</button>
            </div>
        </div>
    </div>
}

@code {
    bool _showConfirm = false;
    string _confirmMsg = "";
    Func<Task>? _confirmAction;

    void Confirm(string msg, Func<Task> action)
    {
        _confirmMsg    = msg;
        _confirmAction = action;
        _showConfirm   = true;
    }

    async Task ExecuteConfirm()
    {
        _showConfirm = false;
        if (_confirmAction != null)
            await _confirmAction();
        _confirmAction = null;
    }

    bool _loading = true;
    bool _showDetail = false;
    bool _editingMeasurements = false;
    bool _editingBasicInfo = false;
    List<KnitProject> _projects = new();
    KnitProject? _selectedProject;

    class MeasureItem
    {
        public string Label { get; set; } = "";
        public string Before { get; set; } = "";
        public string After  { get; set; } = "";
        public bool IsCustom { get; set; } = false;
    }

    static readonly string[] _defaultMeasureLabels = { "가슴둘레", "총장", "소매 길이", "소매 단면" };
    List<MeasureItem> _measures = new();

    List<Yarn> _allYarns = new();
    List<KnitTool> _allTools = new();
    List<Swatch> _allSwatches = new();

    List<(ProjectYarnUsage usage, Yarn yarn)> _selectedYarns = new();
    List<KnitTool> _selectedTools = new();
    List<Swatch> _selectedSwatches = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _loading = false;
    }

    async Task LoadData()
    {
        var all = await Storage.GetProjectsAsync();
        _projects = all.Where(p => p.Status == ProjectStatus.완료)
                       .OrderByDescending(p => p.EndDate)
                       .ToList();
        _allYarns    = await Storage.GetYarnsAsync();
        _allTools    = await Storage.GetToolsAsync();
        _allSwatches = await Storage.GetSwatchesAsync();
    }

    void OpenDetail(KnitProject proj)
    {
        _selectedProject = proj;
        _editingMeasurements = false;
        _editingBasicInfo = false;
        _selectedYarns = proj.YarnUsages
            .Select(u => (u, _allYarns.FirstOrDefault(y => y.Id == u.YarnId)))
            .Where(x => x.Item2 != null)
            .Select(x => (x.u, x.Item2!))
            .ToList();
        _selectedTools    = _allTools.Where(t => proj.ToolIds.Contains(t.Id)).ToList();
        _selectedSwatches = _allSwatches.Where(s => s.ProjectId == proj.Id).ToList();
        _showDetail = true;
        LoadMeasures();
    }

    void LoadMeasures()
    {
        if (_selectedProject == null) return;
        var dict = new Dictionary<string, (string, string)>();
        if (!string.IsNullOrEmpty(_selectedProject.MeasurementsMemo))
        {
            foreach (var part in _selectedProject.MeasurementsMemo.Split('|'))
            {
                var seg = part.Split(':');
                if (seg.Length >= 3)
                    dict[seg[0]] = (seg[1], seg[2]);
                else if (seg.Length == 2)
                    dict[seg[0]] = (seg[1], "");
            }
        }

        _measures = new List<MeasureItem>();
        foreach (var label in _defaultMeasureLabels)
        {
            var (b, a) = dict.TryGetValue(label, out var v) ? v : ("", "");
            _measures.Add(new MeasureItem { Label = label, Before = b, After = a, IsCustom = false });
            dict.Remove(label);
        }
        foreach (var kv in dict)
        {
            _measures.Add(new MeasureItem { Label = kv.Key, Before = kv.Value.Item1, After = kv.Value.Item2, IsCustom = true });
        }
    }

    void AddCustomMeasure()
    {
        _measures.Add(new MeasureItem { Label = "", Before = "", After = "", IsCustom = true });
    }

    void CloseDetail()
    {
        _showDetail = false;
        _selectedProject = null;
        _editingMeasurements = false;
        _editingBasicInfo = false;
        _measures.Clear();
        _selectedYarns.Clear();
        _selectedTools.Clear();
        _selectedSwatches.Clear();
    }

    async Task SaveBasicInfo()
    {
        if (_selectedProject == null) return;
        await Storage.SaveProjectAsync(_selectedProject);
        _editingBasicInfo = false;
    }

    async Task SaveMeasurements()
    {
        if (_selectedProject == null) return;
        _selectedProject.MeasurementsMemo = string.Join("|",
            _measures
                .Where(m => !string.IsNullOrEmpty(m.Label) && (!string.IsNullOrEmpty(m.Before) || !string.IsNullOrEmpty(m.After)))
                .Select(m => $"{m.Label}:{m.Before}:{m.After}"));
        await Storage.SaveProjectAsync(_selectedProject);
        _editingMeasurements = false;
    }

    void CancelMeasurements()
    {
        LoadMeasures();
        _editingMeasurements = false;
    }

    async Task RestoreToSchedule(Guid id)
    {
        var all = await Storage.GetProjectsAsync();
        var proj = all.FirstOrDefault(p => p.Id == id);
        if (proj == null) return;
        proj.Status = ProjectStatus.진행중;
        await Storage.SaveProjectAsync(proj);
        CloseDetail();
        await LoadData();
    }

    async Task DeleteProject(Guid id)
    {
        await Storage.DeleteProjectAsync(id);
        CloseDetail();
        await LoadData();
    }
}
