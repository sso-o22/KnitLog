@* =====================================================================
   Pages/ProjectDetail.razor  —  뜨케줄 프로젝트 상세 페이지
   ===================================================================== *@
@page "/projects/{ProjectId:guid}"
@using KnitLog.Models
@using KnitLog.Services
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject StorageService Storage
@inject NavigationManager Nav
@inject IJSRuntime JS

@if (_loading)
{
    <div class="loading">불러오는 중...</div>
}
else if (_project == null)
{
    <div class="empty-state">
        <div class="empty-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-volleyball-icon lucide-volleyball"><path d="M11 7a16 16 20 0 1 10.98 4.362"/><path d="M12 12a13 13 0 0 1-8.66 5"/><path d="M16.83 13.634a16 16 0 0 1-9.267 7.328"/><path d="M20.66 17A13 13 0 0 0 12 12a13 13 0 0 1 0-10"/><path d="M8.17 15.366a16 16 0 0 1-1.713-11.69"/><circle cx="12" cy="12" r="10"/></svg></div>
        <p>프로젝트를 찾을 수 없어요.</p>
        <button class="btn btn-primary mt-2" @onclick="GoBack">← 뒤로가기</button>
    </div>
}
else
{
    <div class="page-header">
        <div style="display:flex; align-items:center; gap:12px;">
            <button class="btn btn-ghost btn-sm" @onclick="GoBack">← 뒤로</button>
            <div>
                <h1 class="page-title" style="margin-bottom:0;">@_project.Title</h1>
                @* <p class="page-subtitle">@_project.PatternName</p> *@
            </div>
        </div>
        <div style="display:flex; gap:6px; flex-wrap:nowrap; align-items:center;">
            <button class="btn btn-secondary btn-sm" @onclick="OpenEditModal">✏️ 수정</button>
            <button class="btn btn-secondary btn-sm" @onclick="GoToViewer">📄 뷰어</button>
            @if (_project.Status == ProjectStatus.진행중)
            {
                <button class="btn btn-ghost btn-sm" @onclick="PauseProject">⏸️ 일시중단</button>
                <button class="btn btn-sage btn-sm" @onclick="CompleteProject">✅ 완료</button>
            }
            else if (_project.Status == ProjectStatus.일시중단)
            {
                <button class="btn btn-ghost btn-sm" @onclick="ResumeProject">▶️ 재개</button>
                <button class="btn btn-sage btn-sm" @onclick="CompleteProject">✅ 완료</button>
            }
            else
            {
                <button class="btn btn-sage btn-sm" @onclick="CompleteProject">✅ 완료</button>
            }
        </div>
    </div>

    <div class="detail-grid">

        <!-- ── 기본 정보 카드 ── -->
        <div class="card" style="grid-column: span 2;">
            <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(180px,1fr)); gap:16px;">
                @if (_project.StartDate.HasValue)
                {
                    <div>
                        <div class="form-label">시작일</div>
                        <div style="font-weight:500;">@_project.StartDate.Value.ToString("yyyy년 M월 d일")</div>
                    </div>
                }
                @if (_project.EndDate.HasValue)
                {
                    <div>
                        <div class="form-label">종료일</div>
                        <div style="font-weight:500;">@_project.EndDate.Value.ToString("yyyy년 M월 d일")</div>
                    </div>
                }
                @if (_project.StartDate.HasValue)
                {
                    var elapsed = (DateTime.Today - _project.StartDate.Value).Days;
                    <div>
                        <div class="form-label">진행 기간</div>
                        <div style="font-weight:500; color:var(--text-dark);">@(elapsed)일째 뜨는 중</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(_project.PatternSource))
                {
                    <div>
                        <div class="form-label">도안 출처</div>
                        <div style="font-weight:500; word-break:break-all;">@_project.PatternSource</div>
                    </div>
                }
                @if (_project.YarnUsages.Count > 0)
                {
                    <div>
                        <div class="form-label">사용 실</div>
                        @foreach (var usage in _project.YarnUsages)
                        {
                            var yarn = _yarns.Find(y => y.Id == usage.YarnId);
                            if (yarn != null)
                            {
                                <div style="display:flex; align-items:center; gap:5px; margin-bottom:3px;">
                                    <span class="color-dot" style="background:@yarn.ColorCode; width:12px; height:12px;"></span>
                                    <span style="font-size:0.85rem; font-weight:500;">@yarn.Brand @yarn.Name</span>
                                    @if (usage.BallsUsed > 0)
                                    {
                                        <span style="font-size:0.78rem; color:var(--text-light);">@(usage.BallsUsed)볼</span>
                                    }
                                </div>
                            }
                        }
                    </div>
                }
                @if (_project.ToolIds.Count > 0 || !string.IsNullOrEmpty(_project.NeedleNote))
                {
                    <div>
                        <div class="form-label">사용 바늘</div>
                        @foreach (var toolId in _project.ToolIds)
                        {
                            var tool = _allTools.Find(t => t.Id == toolId);
                            if (tool != null)
                            {
                                <div style="font-size:0.85rem; font-weight:500; margin-bottom:2px;">
                                    @tool.NeedleType @tool.SizeMm mm
                                </div>
                            }
                        }
                        @if (!string.IsNullOrEmpty(_project.NeedleNote))
                        {
                            <div style="font-size:0.85rem; font-weight:500;">@_project.NeedleNote</div>
                        }
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(_project.Description))
            {
                <div class="divider"></div>
                <div class="form-label">설명</div>
                <p style="white-space:pre-wrap; font-size:0.9rem;">@_project.Description</p>
            }
            @if (!string.IsNullOrEmpty(_project.PatternMemo))
            {
                <div class="divider"></div>
                <div class="form-label">도안 메모</div>
                <p style="white-space:pre-wrap; font-size:0.9rem;">@_project.PatternMemo</p>
            }
            @if (!string.IsNullOrEmpty(_project.Memo))
            {
                <div class="divider"></div>
                <div class="form-label">메모</div>
                <p style="white-space:pre-wrap; font-size:0.9rem;">@_project.Memo</p>
            }

            @* 일시중단 상태 표시 *@
            @if (_project.Status == ProjectStatus.일시중단)
            {
                <div class="divider"></div>
                <div style="display:flex; align-items:center; gap:8px;">
                    <span class="badge" style="background:#fde8e8; color:#c0392b;">일시 중단 중</span>
                    <span style="font-size:0.82rem; color:var(--text-light);">재개 버튼을 눌러 다시 시작하세요</span>
                </div>
            }

            @* 참고 영상 *@
            @* @if (_project.VideoLinks.Count > 0)
            {
                <div class="divider"></div>
                <div class="form-label">🎬 참고 영상</div>
                <div style="display:flex; flex-direction:column; gap:6px;">
                    @foreach (var link in _project.VideoLinks)
                    {
                        <a href="@link" target="_blank" rel="noopener noreferrer"
                           style="display:flex; align-items:center; gap:6px; font-size:0.85rem; color:var(--theme-active); word-break:break-all;">
                            🔗 @link
                        </a>
                    }
                </div>
            } *@
        </div>

        @foreach (var cardId in _cardOrder)
        {
            @if (cardId == "counter")
            {
                <!-- ── 단수 카운터 ── -->
                <div class="card" draggable="true" data-cardid="counter" style="overflow:hidden;">
                    <div style="display:flex; align-items:center; justify-content:space-between; cursor:pointer; padding-bottom:16px;"
                         @onclick='() => { if (_project.Counters.Count > 0) ToggleCard("counter"); }'>
                        <div class="card-title" style="margin-bottom:0;">🔢 단수 카운터</div>
                        @if (_project.Counters.Count > 0)
                        {
                            <span style="font-size:0.85rem; color:var(--text-light);">@(IsCollapsed("counter") ? "▶" : "▼")</span>
                        }
                    </div>
                    @if (!IsCollapsed("counter") || _project.Counters.Count == 0)
                    {
                        <p style="font-size:0.82rem; color:var(--text-mid); margin-bottom:16px;">현재 뜨고 있는 단/코 수를 기록해요</p>
                        @foreach (var counter in _project.Counters)
                        {
                            var hasTarget = counter.Target > 0;
                            var progress  = hasTarget ? Math.Min(100.0, counter.Value * 100.0 / counter.Target) : 0.0;
                            var isDone    = hasTarget && counter.Value >= counter.Target;
                            <div style="background:#f8f8f8; border-radius:var(--radius-sm); padding:14px; margin-bottom:12px; border:1px solid @(isDone ? "#7ec8a0" : "var(--border)");">
                                <!-- 라벨 + 연필 + 삭제 -->
                                <div style="display:flex; align-items:center; gap:6px; margin-bottom:10px;">
                                    @if (_editingCounterId == counter.Id)
                                    {
                                        <input class="form-control" style="flex:1; font-size:0.88rem; padding:4px 8px;"
                                               @bind="_editingCounterLabel"
                                               @onkeydown='async e => { if (e.Key == "Enter") await SaveCounterLabel(counter); if (e.Key == "Escape") _editingCounterId = null; }' />
                                        <button class="btn btn-primary btn-sm" @onclick="() => SaveCounterLabel(counter)">✓</button>
                                        <button class="btn btn-ghost btn-sm" @onclick="() => _editingCounterId = null">✕</button>
                                    }
                                    else
                                    {
                                        <span style="font-weight:600; font-size:0.92rem; flex:1;">@counter.Label</span>
                                        <button class="btn btn-ghost btn-sm" style="padding:2px 6px;" title="이름 수정"
                                                @onclick="() => { _editingCounterId = counter.Id; _editingCounterLabel = counter.Label; }">✏️</button>
                                        <button class="btn btn-danger btn-sm" style="padding:2px 8px;" disabled="@IsPaused" @onclick='() => Confirm($"\"{counter.Label}\" 카운터를 삭제할까요?", async () => await RemoveCounter(counter.Id))'>✕</button>
                                    }
                                </div>
                                <!-- 원형 게이지 + 카운터 버튼 -->
                                <div style="display:flex; align-items:center; gap:16px; justify-content:center; margin-bottom:10px;">
                                    <button class="btn btn-secondary" style="width:44px; height:44px; font-size:1.3rem; padding:0; display:flex; align-items:center; justify-content:center; border-radius:50%;"
                                            disabled="@IsPaused"
                                            @onclick="() => CounterChange(counter, -counter.Step)">−</button>
                                    <div style="position:relative; width:88px; height:88px; flex-shrink:0;">
                                        <svg viewBox="0 0 88 88" width="88" height="88" style="transform:rotate(-90deg);">
                                            <circle cx="44" cy="44" r="36" fill="none" stroke="var(--border)" stroke-width="7" />
                                            @if (hasTarget)
                                            {
                                                var circ = 2 * Math.PI * 36;
                                                var dash = circ * progress / 100.0;
                                                <circle cx="44" cy="44" r="36" fill="none"
                                                        stroke="@(isDone ? "#7ec8a0" : "#f5c842")"
                                                        stroke-width="7" stroke-linecap="round"
                                                        stroke-dasharray="@dash.ToString("F1") @circ.ToString("F1")" />
                                            }
                                        </svg>
                                        <div style="position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center;">
                                            <span style="font-size:1.6rem; font-weight:800; color:var(--text-dark); line-height:1;">@counter.Value</span>
                                            @if (hasTarget) { <span style="font-size:0.65rem; color:var(--text-light); margin-top:1px;">/ @counter.Target</span> }
                                        </div>
                                    </div>
                                    <button class="btn btn-primary" style="width:44px; height:44px; font-size:1.3rem; padding:0; display:flex; align-items:center; justify-content:center; border-radius:50%;"
                                            disabled="@IsPaused"
                                            @onclick="() => CounterChange(counter, counter.Step)">+</button>
                                </div>
                                @if (hasTarget)
                                {
                                    <div style="height:5px; background:var(--border); border-radius:99px; margin-bottom:8px; overflow:hidden;">
                                        <div style="height:100%; width:@(progress.ToString("F1"))%; background:@(isDone ? "#7ec8a0" : "#f5c842"); border-radius:99px; transition:width 0.3s;"></div>
                                    </div>
                                    <div style="text-align:center; font-size:0.75rem; color:@(isDone ? "#267848" : "var(--text-mid)"); margin-bottom:6px;">
                                        @if (isDone) { <span>🎉 목표 달성!</span> }
                                        else { <span>@(progress.ToString("F0"))% (@counter.Value / @counter.Target)</span> }
                                    </div>
                                }
                                @if (counter.LastUpdatedAt.HasValue)
                                {
                                    <div style="text-align:center; font-size:0.75rem; color:var(--text-light); margin-bottom:8px;">
                                        🕐 마지막 업데이트: @counter.LastUpdatedAt.Value.ToString("HH:mm:ss")
                                    </div>
                                }
                                <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap; font-size:0.8rem; color:var(--text-mid);">
                                    <span>단위</span>
                                    <input type="number" style="width:55px;" class="form-control" @bind="counter.Step" min="1" disabled="@IsPaused" />
                                    <span>목표</span>
                                    <input type="number" style="width:80px;" class="form-control"
                                           value="@(counter.Target == 0 ? "" : counter.Target.ToString())"
                                           @onchange="e => { counter.Target = int.TryParse(e.Value?.ToString(), out var t) ? t : 0; _ = Save(); }"
                                           min="0" placeholder="없음" disabled="@IsPaused" />
                                    <button class="btn btn-ghost btn-sm" disabled="@IsPaused" @onclick="() => ResetCounter(counter)">초기화</button>
                                </div>
                            </div>
                        }
                        @if (!IsPaused)
                        {
                            @if (_addingCounter)
                            {
                                <div style="display:flex; gap:8px; margin-top:8px;">
                                    <input class="form-control" @bind="_newCounterLabel" placeholder="이름 (예: 단수, 코수)" />
                                    <button class="btn btn-primary btn-sm" @onclick="AddCounter">추가</button>
                                    <button class="btn btn-ghost btn-sm" @onclick="() => _addingCounter = false">취소</button>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-ghost btn-sm mt-1" @onclick="() => _addingCounter = true">+ 카운터 추가</button>
                            }
                        }
                        else
                        {
                            <p style="font-size:0.8rem; color:var(--text-light); margin-top:8px;">⏸️ 일시중단 중에는 편집할 수 없어요</p>
                        }
                    }
                </div>
            }
            else if (cardId == "checklist")
            {
                <!-- ── 도안 체크리스트 ── -->
                <div class="card" draggable="true" data-cardid="checklist" style="overflow:hidden;">
                    <div style="display:flex; align-items:center; justify-content:space-between; cursor:pointer; padding-bottom:16px;"
                         @onclick='() => { if (_project.Checklist.Count > 0) ToggleCard("checklist"); }'>
                        <div class="card-title" style="margin-bottom:0;">📋 도안 체크리스트</div>
                        @if (_project.Checklist.Count > 0)
                        {
                            <span style="font-size:0.85rem; color:var(--text-light);">@(IsCollapsed("checklist") ? "▶" : "▼")</span>
                        }
                    </div>
                    @if (!IsCollapsed("checklist") || _project.Checklist.Count == 0)
                    {
                        <p style="font-size:0.82rem; color:var(--text-mid); margin-bottom:16px;">완료한 단계를 체크해요</p>
                        @foreach (var item in _project.Checklist)
                        {
                            <div style="display:flex; align-items:center; gap:8px; padding:8px 0; border-bottom:1px solid var(--border);">
                                <input type="checkbox" checked="@item.Done"
                                       @onchange="() => ToggleCheck(item)"
                                       disabled="@IsPaused"
                                       style="width:16px; height:16px; accent-color:#2a5a26; cursor:pointer; flex-shrink:0;" />
                                @if (_editingCheckId == item.Id)
                                {
                                    <input class="form-control" style="flex:1; font-size:0.88rem; padding:4px 8px;"
                                           @bind="_editingCheckText"
                                           @onkeydown='async e => { if (e.Key == "Enter") await SaveCheckLabel(item); if (e.Key == "Escape") _editingCheckId = null; }' />
                                    <button class="btn btn-primary btn-sm" @onclick="() => SaveCheckLabel(item)">✓</button>
                                    <button class="btn btn-ghost btn-sm" @onclick="() => _editingCheckId = null">✕</button>
                                }
                                else
                                {
                                    <span style="flex:1; font-size:0.88rem; @(item.Done ? "text-decoration:line-through; color:var(--text-light);" : "")">@item.Text</span>
                                    <button class="btn btn-ghost btn-sm" style="padding:2px 6px;" title="이름 수정"
                                            @onclick="() => { _editingCheckId = item.Id; _editingCheckText = item.Text; }">✏️</button>
                                    <button class="btn btn-danger btn-sm" style="padding:2px 6px;" disabled="@IsPaused" @onclick='() => Confirm($"\"{item.Text}\" 항목을 삭제할까요?", async () => await RemoveCheckItem(item.Id))'>✕</button>
                                }
                            </div>
                        }
                        @if (_project.Checklist.Count > 0)
                        {
                            var done  = _project.Checklist.Count(c => c.Done);
                            var total = _project.Checklist.Count;
                            <div style="margin:10px 0 4px; font-size:0.8rem; color:var(--text-mid);">@done / @total 완료</div>
                            <div style="height:6px; background:#e8e8e8; border-radius:3px;">
                                <div style="height:6px; background:#c8e6be; border-radius:3px; width:@(done * 100 / total)%;"></div>
                            </div>
                        }
                        @if (!IsPaused)
                        {
                            @if (_addingCheck)
                            {
                                <div style="display:flex; gap:8px; margin-top:12px;">
                                    <input class="form-control" @bind="_newCheckText" placeholder="예: 1~10단 완료" />
                                    <button class="btn btn-primary btn-sm" @onclick="AddCheckItem">추가</button>
                                    <button class="btn btn-ghost btn-sm" @onclick="() => _addingCheck = false">취소</button>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-ghost btn-sm mt-1" @onclick="() => _addingCheck = true">+ 항목 추가</button>
                            }
                        }
                        else
                        {
                            <p style="font-size:0.8rem; color:var(--text-light); margin-top:8px;">⏸️ 일시중단 중에는 편집할 수 없어요</p>
                        }
                    }
                </div>
            }
            else if (cardId == "timer")
            {
                <!-- ── 뜨개 시간 기록 ── -->
                <div class="card" draggable="true" data-cardid="timer" style="overflow:hidden;">
                    <div style="display:flex; align-items:center; justify-content:space-between; cursor:pointer; padding-bottom:16px;"
                         @onclick='() => ToggleCard("timer")'>
                        <div class="card-title" style="margin-bottom:0;">⏱️ 뜨개 시간</div>
                        <span style="font-size:0.85rem; color:var(--text-light);">@(IsCollapsed("timer") ? "▶" : "▼")</span>
                    </div>
                    @if (!IsCollapsed("timer"))
                    {
                        <p style="font-size:0.82rem; color:var(--text-mid); margin-bottom:16px;">지금 뜨는 시간을 기록해요</p>
                
                            <!-- 타이머 디스플레이 -->
                            <div style="background:#f8f8f8; border-radius:var(--radius-sm); padding:20px; margin-bottom:14px; text-align:center; border:1px solid var(--border);">
                                <div style="font-family:'Courier New', monospace; font-size:3rem; font-weight:700; color:var(--sage-dark); letter-spacing:4px; margin-bottom:8px;">
                                    @if (_activeSession != null)
                                    {
                                        <span>@(_timerDisplay)</span>
                                    }
                                    else
                                    {
                                        <span>00:00:00</span>
                                    }
                                </div>
                                <div style="font-size:0.8rem; color:var(--text-mid);">
                                    @if (_activeSession != null)
                                    {
                                        <span>진행 중...</span>
                                    }
                                    else
                                    {
                                        <span>준비 완료</span>
                                    }
                                </div>
                            </div>
                
                            <!-- 시작/종료 버튼 -->
                            <div style="display:flex; gap:8px;">
                                @if (_activeSession == null)
                                {
                                    <!-- 시작 버튼 -->
                                    <button class="btn btn-primary" style="flex:1; padding:10px;" disabled="@IsPaused" @onclick="StartSession">
                                        ▶️ 시작
                                    </button>
                                }
                                else
                                {
                                    <!-- 종료 버튼 -->
                                    <button class="btn btn-danger" style="flex:1; padding:10px;" disabled="@IsPaused" @onclick="EndSession">
                                        ⏹️ 종료
                                    </button>
                                }
                            </div>
                
                        <!-- 메모 입력 (진행 중일 때만) -->
                        @if (_activeSession != null)
                        {
                            <div style="margin-top:14px;">
                                <input class="form-control" type="text" placeholder="메모 (선택사항)" @bind="_sessionMemo" style="font-size:0.9rem; padding:8px;" />
                            </div>
                        }
                        @if (IsPaused)
                        {
                            <p style="font-size:0.8rem; color:var(--text-light); margin-top:8px;">⏸️ 일시중단 중에는 시간 기록을 할 수 없어요</p>
                        }
                    }
                </div>
            }
            else if (cardId == "accum")
            {
                <!-- ── 누적 시간 ── -->
                <div class="card" draggable="true" data-cardid="accum" style="overflow:hidden;">
                    <div style="display:flex; align-items:center; justify-content:space-between; cursor:pointer; padding-bottom:16px;"
                         @onclick='() => ToggleCard("accum")'>
                        <div class="card-title" style="margin-bottom:0;">📊 누적 시간</div>
                        <span style="font-size:0.85rem; color:var(--text-light);">@(IsCollapsed("accum") ? "▶" : "▼")</span>
                    </div>
                    @if (!IsCollapsed("accum"))
                    {
                            
                            <div style="background:var(--sage-light); border-radius:var(--radius-sm); padding:16px; text-align:center;">
                                <div style="font-size:0.85rem; color:var(--text-mid); margin-bottom:8px;">총 뜨개 시간</div>
                                <div style="font-family:'Courier New', monospace; font-size:2.2rem; font-weight:700; color:var(--sage-dark);">
                                    @if (_displayHours > 0)
                                    {
                                        <span>@(_displayHours):@(_displayMins.ToString("D2")):@(_displaySecs.ToString("D2"))</span>
                                    }
                                    else if (_displayMins > 0)
                                    {
                                        <span>00:@(_displayMins.ToString("D2")):@(_displaySecs.ToString("D2"))</span>
                                    }
                                    else
                                    {
                                        <span>00:00:@(_displaySecs.ToString("D2"))</span>
                                    }
                                </div>
                                <div style="font-size:0.75rem; color:var(--text-mid); margin-top:8px;">
                                    @(_project.Sessions.Count)개 세션
                                </div>
                            </div>
                
                            <!-- 시간 기록 목록 -->
                            @if (_project.Sessions.Count > 0)
                            {
                                <div class="divider"></div>
                                <div style="font-size:0.9rem; font-weight:500; margin-bottom:12px; color:var(--text-dark);">
                                    최근 기록
                                </div>
                                
                                @foreach (var session in _project.Sessions.OrderByDescending(s => s.StartTime).Take(5))
                                {
                                    <div style="background:#f8f8f8; border-radius:var(--radius-sm); padding:10px; margin-bottom:8px; border:1px solid var(--border); font-size:0.85rem;">
                                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:4px;">
                                            <span style="color:var(--text-mid);">@(session.StartTime.ToString("M월 d일 HH:mm"))</span>
                                            <button class="btn btn-danger btn-sm" style="padding:2px 6px; font-size:0.7rem;" @onclick='() => Confirm("이 뜨개 기록을 삭제할까요?", async () => await RemoveSession(session.Id))'>✕</button>
                                        </div>
                                        <div style="font-weight:600; color:var(--sage-dark);">
                                            <span>@FormatDuration(session)</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(session.Memo))
                                        {
                                            <div style="font-size:0.75rem; color:var(--text-mid); margin-top:4px;">@(session.Memo)</div>
                                        }
                                    </div>
                                }
                            }
                    }
                </div>
            }
        }

    <div class="card" style="grid-column: span 2; overflow:hidden;">
        <div style="display:flex; align-items:center; justify-content:space-between; cursor:pointer; padding-bottom:16px;"
             @onclick='() => ToggleCard("video")'>
            <div class="card-title" style="margin-bottom:0;">🎬 참고 영상</div>
            @if (_project.VideoLinks.Count > 0)
            {
                <span style="font-size:0.85rem; color:var(--text-light);">@(IsCollapsed("video") ? "▶" : "▼")</span>
            }
        </div>
        @if (!IsCollapsed("video") || _project.VideoLinks.Count == 0)
        {

        @if (_project.VideoLinks.Count > 0)
        {
            <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:14px;">
                @foreach (var link in _project.VideoLinks.ToList())
                {
                    <div style="margin-bottom:16px; border-bottom:1px solid var(--border); padding-bottom:12px;">
                        @if (link.Contains("youtube.com") || link.Contains("youtu.be"))
                        {
                            @* 유튜브 영상 플레이어 *@
                            <div style="position:relative; padding-bottom:56.25%; height:0; overflow:hidden; border-radius:var(--radius-sm); margin-bottom:8px;">
                                <iframe src="@GetEmbedUrl(link)" 
                                        style="position:absolute; top:0; left:0; width:100%; height:100%; border:0;" 
                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                                        allowfullscreen>
                                </iframe>
                            </div>
                        }
                        
                        <div style="display:flex; align-items:center; gap:8px;">
                            <a href="@link" target="_blank" style="flex:1; font-size:0.8rem; color:var(--text-mid);">🔗 원문 링크 보기</a>
                            <button class="btn btn-danger btn-sm" @onclick='() => Confirm("이 링크를 삭제할까요?", async () => await RemoveVideoLink(link))'>✕</button>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p style="color:var(--text-light); font-size:0.88rem; margin-bottom:12px;">참고 영상이 없어요. 도안 영상 링크를 추가해 보세요!</p>
        }

        <div style="display:flex; gap:8px;">
            <input class="form-control" 
                @bind="_newVideoLink" 
                @bind:event="oninput"
                placeholder="유튜브, 블로그 등 URL 입력"
                @onkeydown="@(async e => { if (e.Key == "Enter") await AddVideoLinkAndSave(); })" />
            <button class="btn btn-sage" style="flex-shrink:0;" @onclick="AddVideoLinkAndSave">추가</button>
        </div>
        }
    </div>

    <div class="card" style="grid-column: span 2;">
        <div class="card-title">📷 과정 사진</div>

        @if (_project.Photos.Count > 0)
        {
            <div style="display:flex; flex-wrap:wrap; gap:12px; margin-bottom:16px;">
                @foreach (var photo in _project.Photos)
                {
                    <div style="position:relative;">
                        <img src="@photo.Base64Data"
                            style="width:140px; height:140px; object-fit:cover; border-radius:var(--radius-sm); border:1px solid var(--border); cursor:pointer;"
                            @onclick="() => OpenPhoto(photo)"
                            alt="과정 사진" />
                        @if (!string.IsNullOrEmpty(photo.Caption))
                        {
                            <div style="font-size:0.75rem; color:var(--text-mid); text-align:center; margin-top:4px; max-width:140px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                @photo.Caption
                            </div>
                        }
                        <button class="btn btn-danger btn-sm"
                                style="position:absolute; top:4px; right:4px; padding:2px 6px; font-size:0.7rem;"
                                @onclick="() => RemovePhoto(photo.Id)">✕</button>
                    </div>
                }
            </div>
        }
        else
        {
            <p style="color:var(--text-light); font-size:0.88rem; margin-bottom:12px;">아직 사진이 없어요. 과정을 기록해 보세요!</p>
        }

        <InputFile OnChange="OnPhotoSelected" accept="image/*" multiple class="form-control" style="padding:6px;" />
    </div>

        <!-- ── 연결된 실 ── -->
        <div class="card">
            <div class="card-title" style="margin-bottom:12px;">🧵 연결된 실</div>
            @if (_project.YarnUsages.Count == 0)
            {
                <p style="color:var(--text-light); font-size:0.88rem;">연결된 실이 없어요. 수정 버튼에서 실을 추가할 수 있어요.</p>
            }
            else
            {
                <div style="display:flex; flex-wrap:wrap; gap:10px;">
                    @foreach (var usage in _project.YarnUsages)
                    {
                        var yarn = _yarns.Find(y => y.Id == usage.YarnId);
                        if (yarn != null)
                        {
                            <div style="background:var(--ivory-dark); border-radius:var(--radius-sm); padding:10px 14px; display:flex; align-items:center; gap:10px; min-width:180px;">
                                <span class="color-dot" style="background:@yarn.ColorCode; width:20px; height:20px; border-radius:50%; flex-shrink:0; border:1px solid rgba(0,0,0,0.08);"></span>
                                <div>
                                    <div style="font-size:0.88rem; font-weight:600;">@yarn.Brand @yarn.Name</div>
                                    <div style="font-size:0.78rem; color:var(--text-mid);">@yarn.Color</div>
                                    @if (usage.BallsUsed > 0)
                                    {
                                        <div style="font-size:0.75rem; color:var(--text-light); margin-top:1px;">@(usage.BallsUsed)볼 사용</div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        </div>

        <!-- ── 연결된 스와치 ── -->
        <div class="card">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;">
                <div class="card-title" style="margin-bottom:0;">🧪 연결된 스와치</div>
                <a href="swatches" class="btn btn-ghost btn-sm">스와치 관리</a>
            </div>

            @if (_linkedSwatches.Count == 0)
            {
                <p style="color:var(--text-light); font-size:0.88rem;">
                    연결된 스와치가 없어요.
                    <a href="swatches" style="color:#267848;">스와치 페이지</a>에서 이 프로젝트를 선택해 연결할 수 있어요.
                </p>
            }
            else
            {
                <div class="grid-3">
                    @foreach (var s in _linkedSwatches)
                    {
                        var yarn = _yarns.Find(y => y.Id == s.YarnId);
                        <div style="background:var(--ivory-dark); border-radius:var(--radius-sm); padding:12px;">
                            <div style="font-weight:600; font-size:0.9rem; margin-bottom:6px;">
                                @(string.IsNullOrEmpty(s.Name) ? "스와치" : s.Name)
                            </div>
                            @if (yarn != null)
                            {
                                <div style="display:flex; align-items:center; gap:5px; font-size:0.8rem; color:var(--text-mid); margin-bottom:8px;">
                                    <span class="color-dot" style="background:@yarn.ColorCode; width:10px; height:10px;"></span>
                                    @yarn.Brand @yarn.Name
                                </div>
                            }
                            <div style="font-size:0.78rem; color:var(--text-mid); display:flex; gap:6px; flex-wrap:wrap;">
                                @if (s.NeedleSizeMm > 0)
                                {
                                    <span>⚒️ @s.NeedleSizeMm mm</span>
                                }
                                <span>@s.Stitch</span>
                            </div>
                            @if (s.PreWashWidthCm > 0)
                            {
                                var w = s.WidthShrinkagePercent;
                                var h = s.HeightShrinkagePercent;
                                <div style="margin-top:8px; display:flex; gap:6px;">
                                    <span style="font-size:0.78rem; color:@(w < 0 ? "#c0392b" : "#267848"); font-weight:600;">
                                        가로 @(w > 0 ? "+" : "")@w%
                                    </span>
                                    @if (s.PreWashHeightCm > 0)
                                    {
                                        <span style="font-size:0.78rem; color:@(h < 0 ? "#c0392b" : "#267848"); font-weight:600;">
                                            세로 @(h > 0 ? "+" : "")@h%
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<!-- 사진 확대 모달 -->

<!-- 사진 확대 모달 -->
@if (_showPhoto && _selectedPhoto != null)
{
    <div class="modal-backdrop">
        <div style="max-width:90vw; max-height:90vh;" @onclick:stopPropagation="true">
            <img src="@_selectedPhoto.Base64Data"
                 style="max-width:90vw; max-height:85vh; object-fit:contain; border-radius:var(--radius); display:block;" />
            @if (!string.IsNullOrEmpty(_selectedPhoto.Caption))
            {
                <p style="text-align:center; color:white; margin-top:10px;">@_selectedPhoto.Caption</p>
            }
        </div>
    </div>
}

<!-- 수정 모달 -->
@if (_showEditModal && _project != null)
{
    <div class="modal-backdrop">
        <div class="modal" style="max-width:680px;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">프로젝트 수정</h2>
                <button class="btn btn-ghost btn-sm" @onclick="CloseEditModal">✕</button>
            </div>

            @* ── 도안명 / 출처 ── *@
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">도안명 *</label>
                    <input class="form-control" @bind="_project.PatternName" placeholder="예: 마시멜로 후드 집업" />
                </div>
                <div class="form-group">
                    <label class="form-label">도안 출처</label>
                    <input class="form-control" @bind="_project.PatternSource" placeholder="작가명, 책 이름, URL 등" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">도안 메모</label>
                <textarea class="form-control" rows="2" @bind="_project.PatternMemo" placeholder="사이즈, 수정 사항 등"></textarea>
            </div>

            @* ── 날짜 ── *@
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">시작일</label>
                    <input type="date" class="form-control"
                           value="@_project.StartDate?.ToString("yyyy-MM-dd")"
                           @onchange="e => _project.StartDate = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!)" />
                </div>
                <div class="form-group">
                    <label class="form-label">@(_project!.Status == ProjectStatus.완료 ? "완성일" : "목표 완성일")</label>
                    <input type="date" class="form-control"
                           value="@_project.EndDate?.ToString("yyyy-MM-dd")"
                           @onchange="e => _project.EndDate = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!)" />
                </div>
            </div>

            @* ── 사용 바늘 ── *@
            <div class="form-group">
                <label class="form-label">⚒️ 사용 바늘</label>
                <div style="display:flex; gap:6px; margin-bottom:6px;">
                    <button type="button" class="btn btn-sm @(_project.NeedleType == NeedleType.대바늘 ? "btn-sage" : "btn-ghost")"
                            @onclick='() => _project.NeedleType = (_project.NeedleType == NeedleType.대바늘 ? (NeedleType?)null : NeedleType.대바늘)'>대바늘</button>
                    <button type="button" class="btn btn-sm @(_project.NeedleType == NeedleType.코바늘 ? "btn-sage" : "btn-ghost")"
                            @onclick='() => _project.NeedleType = (_project.NeedleType == NeedleType.코바늘 ? (NeedleType?)null : NeedleType.코바늘)'>코바늘</button>
                </div>
                <input class="form-control" @bind="_project.NeedleNote" placeholder="예: 4mm 대바늘 80cm줄, 3.5mm 코바늘" />
            </div>

            @* ── 사용 실 ── *@
            <div class="form-group">
                <label class="form-label">🧵 사용 실</label>
                <select class="form-control" style="margin-bottom:8px;" @onchange="OnEditAddYarn">
                    <option value="">+ 실 추가</option>
                    @foreach (var y in _yarns)
                    {
                        <option value="@y.Id">@y.Brand @y.Name (@y.Color)</option>
                    }
                </select>
                @foreach (var usage in _project.YarnUsages)
                {
                    var yarn = _yarns.Find(y => y.Id == usage.YarnId);
                    <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px; padding:6px 10px;
                                border-radius:9px; background:#f8f8f8; border:1px solid var(--border);">
                        @if (yarn != null)
                        {
                            <span class="color-dot" style="background:@yarn.ColorCode; flex-shrink:0;"></span>
                            <span style="flex:1; font-size:0.88rem;">@yarn.Brand @yarn.Name (@yarn.Color)</span>
                        }
                        <input class="form-control" type="number" min="1" style="width:64px;"
                               value="@usage.BallsUsed"
                               @onchange="e => usage.BallsUsed = int.TryParse(e.Value?.ToString(), out var n) ? n : 1" />
                        <span style="font-size:0.82rem; color:var(--text-mid);">볼</span>
                        <button class="btn btn-danger btn-sm" @onclick="() => _project.YarnUsages.Remove(usage)">✕</button>
                    </div>
                }
            </div>

            @* ── 스와치 연결 ── *@
            <div class="form-group">
                <label class="form-label">📐 스와치</label>
                @if (!_allSwatches.Any())
                {
                    <p style="font-size:0.82rem; color:var(--text-light);">스와치 페이지에서 먼저 스와치를 만들어주세요.</p>
                }
                else
                {
                    <select class="form-control" @onchange="OnSwatchSelectChange">
                        <option value="">+ 스와치 연결</option>
                        @foreach (var s in _allSwatches)
                        {
                            var sy = _yarns.Find(y => y.Id == s.YarnId);
                            var isLinked = s.ProjectId == _project!.Id;
                            <option value="@s.Id" disabled="@isLinked">
                                @(string.IsNullOrEmpty(s.Name) ? "이름 없는 스와치" : s.Name)
                                @(sy != null ? $" ({sy.Brand} {sy.Name})" : "")
                            </option>
                        }
                    </select>
                    @if (_allSwatches.Any(s => s.ProjectId == _project!.Id))
                    {
                        <div style="margin-top:8px;">
                            @foreach (var s in _allSwatches.Where(s => s.ProjectId == _project!.Id))
                            {
                                var sy = _yarns.Find(y => y.Id == s.YarnId);
                                <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px; padding:8px 12px;
                                            border-radius:var(--radius-sm); background:#f0faf4; border:1px solid #b8e0c8;">
                                    <div style="flex:1; min-width:0;">
                                        <div style="font-size:0.88rem; font-weight:600;">
                                            @(string.IsNullOrEmpty(s.Name) ? "이름 없는 스와치" : s.Name)
                                            @if (!string.IsNullOrEmpty(s.Stitch))
                                            {
                                                <span style="font-weight:400; color:var(--text-mid); margin-left:6px;">(@s.Stitch)</span>
                                            }
                                            @if (s.NeedleSizeMm > 0)
                                            {
                                                <span style="font-weight:400; color:var(--text-mid); margin-left:4px;">@(s.NeedleSizeMm)mm</span>
                                            }
                                        </div>
                                        @if (sy != null)
                                        {
                                            <div style="font-size:0.75rem; color:var(--text-light); display:flex; align-items:center; gap:4px; margin-top:3px;">
                                                <span class="color-dot" style="background:@sy.ColorCode; width:8px; height:8px;"></span>
                                                @sy.Brand @sy.Name
                                            </div>
                                        }
                                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:6px; font-size:0.8rem;">
                                            <div>
                                                <div style="font-size:0.7rem; color:var(--text-light);">세탁 전</div>
                                                @if (s.PreWashStitches > 0 || s.PreWashRows > 0)
                                                {
                                                    <div>@(s.PreWashStitches)코 × @(s.PreWashRows)단</div>
                                                }
                                                @if (s.PreWashWidthCm > 0 || s.PreWashHeightCm > 0)
                                                {
                                                    <div style="color:var(--text-mid);">@(s.PreWashWidthCm)cm × @(s.PreWashHeightCm)cm</div>
                                                }
                                            </div>
                                            @if (s.PostWashStitches > 0 || s.PostWashWidthCm > 0)
                                            {
                                                <div>
                                                    <div style="font-size:0.7rem; color:var(--text-light);">세탁 후</div>
                                                    @if (s.PostWashStitches > 0 || s.PostWashRows > 0)
                                                    {
                                                        <div>@(s.PostWashStitches)코 × @(s.PostWashRows)단</div>
                                                    }
                                                    @if (s.PostWashWidthCm > 0 || s.PostWashHeightCm > 0)
                                                    {
                                                        <div style="color:var(--text-mid);">@(s.PostWashWidthCm)cm × @(s.PostWashHeightCm)cm</div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <button class="btn btn-danger btn-sm" style="padding:2px 8px; flex-shrink:0;" @onclick="() => UnlinkSwatch(s)">✕</button>
                                </div>
                            }
                        </div>
                    }
                }
            </div>

            @* ── 카테고리 + 색상 ── *@
            <div class="form-group" style="margin-top:28px;">
                <label class="form-label">카테고리</label>
                <div style="display:flex; gap:6px; flex-wrap:wrap; margin-bottom:10px;">
                    @foreach (var cat in Enum.GetValues<ProjectCategory>().Where(c => c != ProjectCategory.미분류))
                    {
                        <button type="button"
                                class="btn btn-sm @(_project.Category == cat ? "btn-sage" : "btn-ghost")"
                                @onclick="() => _project.Category = (_project.Category == cat ? ProjectCategory.미분류 : cat)">
                            @cat
                        </button>
                    }
                </div>
                <label class="form-label" style="margin-top:20px; display:block;">캘린더 색상</label>
                <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
                    @foreach (var hex in _colorOptions)
                    {
                        bool sel = _project.ColorCode == hex;
                        <div @onclick="() => _project.ColorCode = hex"
                             style="width:28px; height:28px; border-radius:50%; background:@hex; cursor:pointer;
                                    border:@(sel ? "3px solid #333" : "2px solid transparent");
                                    box-shadow:@(sel ? "0 0 0 2px #fff inset" : "none");
                                    transform:@(sel ? "scale(1.2)" : "scale(1)");">
                        </div>
                    }
                    <input type="color"
                           value="@(string.IsNullOrEmpty(_project.ColorCode) ? "#b8e0c8" : _project.ColorCode)"
                           @onchange="e => _project.ColorCode = e.Value?.ToString() ?? string.Empty"
                           style="width:28px; height:28px; border-radius:50%; border:2px solid var(--border); padding:0; cursor:pointer; overflow:hidden;"
                           title="직접 색상 선택" />
                </div>
            </div>

            @* ── 메모 ── *@
            <div class="form-group" style="margin-top:28px;">
                <label class="form-label">📝 메모</label>
                <textarea class="form-control" rows="2" @bind="_project.Memo" placeholder="기타 메모"></textarea>
            </div>

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseEditModal">취소</button>
                <button class="btn btn-primary" @onclick="SaveEdit">저장</button>
            </div>
        </div>
    </div>
}

<!-- 다른 프로젝트 타이머 충돌 모달 -->
@if (_showTimerConflict && _conflictProject != null)
{
    <div class="modal-backdrop" style="z-index:9999;">
        <div class="modal" style="max-width:380px; text-align:center;" @onclick:stopPropagation="true">
            <div style="font-size:2rem; margin-bottom:12px;">⏱️</div>
            <div style="font-size:1rem; font-weight:600; margin-bottom:8px; color:var(--text-dark);">다른 프로젝트 타이머가 진행 중이에요</div>
            <div style="font-size:0.88rem; color:var(--text-mid); margin-bottom:20px;">
                <strong>@_conflictProject.Title</strong> 프로젝트의 타이머를 종료하고<br/>이 프로젝트를 시작할까요?
            </div>
            <div style="display:flex; gap:10px; justify-content:center;">
                <button class="btn btn-ghost" @onclick="() => _showTimerConflict = false">취소</button>
                <button class="btn btn-primary" @onclick="ForceStartSession">종료하고 시작</button>
            </div>
        </div>
    </div>
}

<!-- 삭제 확인 모달 -->
@if (_showConfirm)
{
    <div class="modal-backdrop" style="z-index:9999;">
        <div class="modal" style="max-width:360px; text-align:center;" @onclick:stopPropagation="true">
            <div style="font-size:2rem; margin-bottom:12px;">🗑️</div>
            <div style="font-size:1rem; font-weight:600; margin-bottom:8px; color:var(--text-dark);">정말 삭제할까요?</div>
            <div style="font-size:0.88rem; color:var(--text-mid); margin-bottom:20px;">@_confirmMsg</div>
            <div style="display:flex; gap:10px; justify-content:center;">
                <button class="btn btn-ghost" @onclick="() => _showConfirm = false">취소</button>
                <button class="btn btn-danger" @onclick="ExecuteConfirm">삭제</button>
            </div>
        </div>
    </div>
}

@code {
    bool _showConfirm = false;
    string _confirmMsg = "";
    Func<Task>? _confirmAction;

    void Confirm(string msg, Func<Task> action)
    {
        _confirmMsg    = msg;
        _confirmAction = action;
        _showConfirm   = true;
    }

    async Task ExecuteConfirm()
    {
        _showConfirm = false;
        if (_confirmAction != null)
            await _confirmAction();
        _confirmAction = null;
    }

    [Parameter] public Guid ProjectId { get; set; }

    bool _loading = true;
    bool _showEditModal = false;

    // 카드 접기/펼치기
    HashSet<string> _collapsedCards = new();
    bool IsCollapsed(string id) => _collapsedCards.Contains(id);
    string CardPb(string id, bool hasItems = true) => _collapsedCards.Contains(id) && hasItems ? "padding-bottom:0;" : "";
    string CardMb(string id, bool hasItems, string expanded = "16px") => _collapsedCards.Contains(id) && hasItems ? "0" : expanded;
    string CardIcon(string id, bool hasItems) => !hasItems ? "" : _collapsedCards.Contains(id) ? "▶" : "▼";
    string CardCursor(bool hasItems) => hasItems ? "pointer" : "default";
    string FormatDuration(KnitSession s) { var e = s.EndTime ?? DateTime.Now; var t = (int)(e - s.StartTime).TotalSeconds; var h = t/3600; var m = (t%3600)/60; var sc = t%60; return h > 0 ? $"{h}:{m:D2}:{sc:D2}" : $"00:{m:D2}:{sc:D2}"; }
    void ToggleCard(string id) { if (!_collapsedCards.Add(id)) _collapsedCards.Remove(id); }

    // 카운터 이름 편집
    Guid? _editingCounterId;
    string _editingCounterLabel = "";

    // 체크리스트 항목 편집
    Guid? _editingCheckId;
    string _editingCheckText = "";

    // 일시중단 여부
    bool IsPaused => _project?.Status == ProjectStatus.일시중단;
    KnitSession? _activeSession => _project?.Sessions.FirstOrDefault(s => s.IsActive);
    int _totalSessionSeconds => _project?.Sessions.Sum(s => { var e = s.EndTime ?? DateTime.Now; return (int)(e - s.StartTime).TotalSeconds; }) ?? 0;
    int _displayHours => _totalSessionSeconds / 3600;
    int _displayMins => (_totalSessionSeconds % 3600) / 60;
    int _displaySecs => _totalSessionSeconds % 60;

    static readonly string[] _colorOptions = new[]
    {
        "#f2b8c6", "#f7e4a0", "#b8e0c8", "#c8b8e8", "#b8d8f0",
        "#ffb74d", "#a5d6a7", "#ef9a9a", "#90caf9", "#ce93d8"
    };
    string _newVideoLink = "";
    bool _showPhoto = false;
    bool _addingCounter = false;
    bool _addingCheck = false;
    string _newCounterLabel = "";
    string _newCheckText = "";
    string _sessionMemo = "";
    string _timerDisplay = "00:00:00";
    bool _showTimerConflict = false;
    KnitProject? _conflictProject;
    KnitProject? _project;
    KnitProject? _editSnapshot;
    List<Guid>? _swatchSnapshotPD;
    ProjectPhoto? _selectedPhoto;
    private PeriodicTimer? _refreshTimer;
    List<Swatch> _linkedSwatches = new();
    List<Swatch> _allSwatches = new();
    List<Yarn> _yarns = new();
    List<KnitTool> _allTools = new();

    protected override async Task OnInitializedAsync()
    {
        var all = await Storage.GetProjectsAsync();
        _project = all.FirstOrDefault(p => p.Id == ProjectId);
        _yarns = await Storage.GetYarnsAsync();
        _allTools = await Storage.GetToolsAsync();
        _allSwatches = await Storage.GetSwatchesAsync();
        _linkedSwatches = _allSwatches.Where(s => s.ProjectId == ProjectId).ToList();

        // 저장된 카드 순서 불러오기
        try
        {
            var savedOrder = await JS.InvokeAsync<string?>("localStorage.getItem", CARD_ORDER_KEY);
            if (!string.IsNullOrEmpty(savedOrder))
            {
                var parsed = System.Text.Json.JsonSerializer.Deserialize<List<string>>(savedOrder);
                if (parsed != null && parsed.Count == 4)
                    _cardOrder = parsed;
            }
        }
        catch { }

        _loading = false;

        if (_project?.Sessions.Any(s => s.IsActive) == true)
            StartRefreshTimer();
    }

    // 유튜브 링크를 임베드용으로 변환하는 함수
    private string GetEmbedUrl(string url)
    {
        if (string.IsNullOrEmpty(url)) return "";
        
        if (url.Contains("youtube.com/watch?v="))
        {
            return url.Replace("youtube.com/watch?v=", "youtube.com/embed/");
        }
        if (url.Contains("youtu.be/"))
        {
            return url.Replace("youtu.be/", "youtube.com/embed/");
        }
        return url; // 유튜브가 아니면 그대로 반환
    }

    void GoBack() => Nav.NavigateTo("projects");
    void GoToViewer() => Nav.NavigateTo("pattern-viewer/" + ProjectId);

    // ── 카드 드래그앤드롭 ──────────────────────────────────
    string _dragCard = "";
    string _dragOver = "";
    List<string> _cardOrder = new() { "counter", "checklist", "timer", "accum" };
    const string CARD_ORDER_KEY = "knitlog_card_order";
    DotNetObjectReference<ProjectDetail>? _dragRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_dragRef == null && !_loading)
        {
            _dragRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initCardDrag", _dragRef);
        }
    }

    [JSInvokable]
    public async Task DropCard(string fromId, string toId)
    {
        var fromIdx = _cardOrder.IndexOf(fromId);
        var toIdx   = _cardOrder.IndexOf(toId);
        if (fromIdx < 0 || toIdx < 0) return;
        _cardOrder.RemoveAt(fromIdx);
        _cardOrder.Insert(toIdx, fromId);
        var json = System.Text.Json.JsonSerializer.Serialize(_cardOrder);
        await JS.InvokeVoidAsync("localStorage.setItem", CARD_ORDER_KEY, json);
        StateHasChanged();
    }

    void DragStart(string card) => _dragCard = card;
    void DragOver(string card) => _dragOver = card;
    void DragLeave(string card) { if (_dragOver == card) _dragOver = ""; }

    // ── 카운터 ──────────────────────────────────────────
    async Task CounterChange(ProjectCounter counter, int delta)
    {
        counter.Value = Math.Max(0, counter.Value + delta);
        if (delta > 0) counter.LastUpdatedAt = DateTime.Now;
        await Save();
    }

    async Task ResetCounter(ProjectCounter counter)
    {
        counter.Value = 0;
        await Save();
    }

    async Task AddCounter()
    {
        if (_project == null || string.IsNullOrWhiteSpace(_newCounterLabel)) return;
        _project.Counters.Add(new ProjectCounter { Label = _newCounterLabel });
        _newCounterLabel = "";
        _addingCounter = false;
        await Save();
    }

    async Task RemoveCounter(Guid id)
    {
        _project?.Counters.RemoveAll(c => c.Id == id);
        await Save();
    }

    async Task SaveCounterLabel(ProjectCounter counter)
    {
        if (!string.IsNullOrWhiteSpace(_editingCounterLabel))
            counter.Label = _editingCounterLabel.Trim();
        _editingCounterId = null;
        await Save();
    }

    async Task SaveCheckLabel(ChecklistItem item)
    {
        if (!string.IsNullOrWhiteSpace(_editingCheckText))
            item.Text = _editingCheckText.Trim();
        _editingCheckId = null;
        await Save();
    }

    // ── 체크리스트 ──────────────────────────────────────
    async Task ToggleCheck(ChecklistItem item)
    {
        item.Done = !item.Done;
        await Save();
    }

    async Task AddCheckItem()
    {
        if (_project == null || string.IsNullOrWhiteSpace(_newCheckText)) return;
        _project.Checklist.Add(new ChecklistItem { Text = _newCheckText });
        _newCheckText = "";
        _addingCheck = false;
        await Save();
    }

    async Task RemoveCheckItem(Guid id)
    {
        _project?.Checklist.RemoveAll(c => c.Id == id);
        await Save();
    }

    // ── 사진 ────────────────────────────────────────────
    async Task OnPhotoSelected(InputFileChangeEventArgs e)
    {
        if (_project == null) return;
        foreach (var file in e.GetMultipleFiles(10))
        {
            var buf = new byte[file.Size];
            await file.OpenReadStream(10 * 1024 * 1024).ReadAsync(buf);
            var base64 = $"data:{file.ContentType};base64,{Convert.ToBase64String(buf)}";
            _project.Photos.Add(new ProjectPhoto
            {
                FileName   = file.Name,
                Base64Data = base64,
                TakenAt    = DateTime.Now
            });
        }
        await Save();
    }

    async Task RemovePhoto(Guid id)
    {
        _project?.Photos.RemoveAll(p => p.Id == id);
        await Save();
    }

    void OpenPhoto(ProjectPhoto photo) { _selectedPhoto = photo; _showPhoto = true; }

    // ── 뜨개 시간 기록 ──────────────────────────────────
    async Task StartSession()
    {
        if (_project == null) return;

        // 다른 프로젝트에 진행 중인 세션 확인
        var allProjects = await Storage.GetProjectsAsync();
        _conflictProject = allProjects.FirstOrDefault(p =>
            p.Id != _project.Id &&
            p.Sessions.Any(s => s.IsActive));

        if (_conflictProject != null)
        {
            _showTimerConflict = true;
            return;
        }

        await DoStartSession();
    }

    async Task ForceStartSession()
    {
        _showTimerConflict = false;
        if (_project == null || _conflictProject == null) return;

        // 다른 프로젝트 세션 강제 종료
        var allProjects = await Storage.GetProjectsAsync();
        var conflict = allProjects.FirstOrDefault(p => p.Id == _conflictProject.Id);
        if (conflict != null)
        {
            foreach (var s in conflict.Sessions.Where(s => s.IsActive))
                s.EndTime = DateTime.Now;
            await Storage.SaveProjectAsync(conflict);
        }
        _conflictProject = null;

        await DoStartSession();
    }

    async Task DoStartSession()
    {
        if (_project == null) return;

        // 이 프로젝트에 진행 중인 세션이 있으면 먼저 종료
        var activeSession = _project.Sessions.FirstOrDefault(s => s.IsActive);
        if (activeSession != null)
        {
            activeSession.EndTime = DateTime.Now;
            if (!string.IsNullOrEmpty(_sessionMemo))
                activeSession.Memo = _sessionMemo;
        }

        // 새 세션 시작
        _project.Sessions.Add(new KnitSession { StartTime = DateTime.Now });
        _sessionMemo = "";
        await Save();
        StartRefreshTimer();
    }

    async Task EndSession()
    {
        if (_project == null) return;
        
        var activeSession = _project.Sessions.FirstOrDefault(s => s.IsActive);
        if (_activeSession != null)
        {
            activeSession.EndTime = DateTime.Now;
            if (!string.IsNullOrEmpty(_sessionMemo))
                activeSession.Memo = _sessionMemo;
        }
        
        _sessionMemo = "";
        await Save();
        StopRefreshTimer();
    }

    async Task RemoveSession(Guid id)
    {
        _project?.Sessions.RemoveAll(s => s.Id == id);
        await Save();
    }

    // 진행 중인 세션의 경과 시간을 표시하기 위해 주기적으로 새로 고침
    private void StartRefreshTimer()
    {
        StopRefreshTimer();
        _refreshTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _ = RefreshUIAsync();
    }

    private void StopRefreshTimer()
    {
        _refreshTimer?.Dispose();
        _refreshTimer = null;
    }

    private async Task RefreshUIAsync()
    {
        try
        {
            while (_refreshTimer is not null && await _refreshTimer.WaitForNextTickAsync())
            {
                UpdateTimerDisplay();
                StateHasChanged();
            }
        }
        catch (OperationCanceledException) { }
    }

    private void UpdateTimerDisplay()
    {
        if (_project == null) return;
        
        var activeSession = _project.Sessions.FirstOrDefault(s => s.IsActive);
        if (_activeSession == null)
        {
            _timerDisplay = "00:00:00";
            return;
        }

        var elapsedSeconds = (int)(DateTime.Now - activeSession.StartTime).TotalSeconds;
        var hours = elapsedSeconds / 3600;
        var minutes = (elapsedSeconds % 3600) / 60;
        var seconds = elapsedSeconds % 60;

        _timerDisplay = $"{hours:D2}:{minutes:D2}:{seconds:D2}";
    }

    public async ValueTask DisposeAsync()
    {
        StopRefreshTimer();
        _dragRef?.Dispose();
        await JS.InvokeVoidAsync("cleanupCardDrag");
    }

    // ── 완료 처리 ────────────────────────────────────────
    async Task CompleteProject()
    {
        if (_project == null) return;
        await Storage.CompleteProjectAsync(_project.Id);
        Nav.NavigateTo("finished");
    }

    async Task PauseProject()
    {
        if (_project == null) return;
        await Storage.PauseProjectAsync(_project.Id);
        _project.Status = ProjectStatus.일시중단;
        StateHasChanged();
    }

    async Task ResumeProject()
    {
        if (_project == null) return;
        await Storage.ResumeProjectAsync(_project.Id);
        _project.Status = ProjectStatus.진행중;
        StateHasChanged();
    }

    // ── 수정 모달 ────────────────────────────────────────
    void OpenEditModal()
    {
        // 취소 시 복원을 위해 JSON 딥카피
        var json = System.Text.Json.JsonSerializer.Serialize(_project);
        _editSnapshot = System.Text.Json.JsonSerializer.Deserialize<KnitProject>(json)!;
        // 스와치 연결 상태 스냅샷
        _swatchSnapshotPD = _allSwatches
            .Where(s => s.ProjectId == _project!.Id)
            .Select(s => s.Id)
            .ToList();
        _showEditModal = true;
    }

    void CloseEditModal()
    {
        // 저장 안 했으면 스냅샷으로 복원
        if (_editSnapshot != null && _project != null)
        {
            _project.PatternName   = _editSnapshot.PatternName;
            _project.PatternSource = _editSnapshot.PatternSource;
            _project.PatternMemo   = _editSnapshot.PatternMemo;
            _project.StartDate     = _editSnapshot.StartDate;
            _project.EndDate       = _editSnapshot.EndDate;
            _project.NeedleType    = _editSnapshot.NeedleType;
            _project.NeedleNote    = _editSnapshot.NeedleNote;
            _project.Category      = _editSnapshot.Category;
            _project.ColorCode     = _editSnapshot.ColorCode;
            _project.Memo          = _editSnapshot.Memo;
            _project.YarnUsages    = _editSnapshot.YarnUsages;
            _project.ToolIds       = _editSnapshot.ToolIds;
                // 스와치 연결 복원
            if (_swatchSnapshotPD != null && _project != null)
            {
                foreach (var s in _allSwatches.Where(s => s.ProjectId == _project.Id).ToList())
                    s.ProjectId = null;
                foreach (var id in _swatchSnapshotPD)
                {
                    var s = _allSwatches.FirstOrDefault(x => x.Id == id);
                    if (s != null) s.ProjectId = _project.Id;
                }
            }
            _swatchSnapshotPD = null;
            _editSnapshot = null;
        }
        _showEditModal = false;
    }

    void AddVideoLink()
    {
        if (string.IsNullOrWhiteSpace(_newVideoLink)) return;
        if (!_project!.VideoLinks.Contains(_newVideoLink))
            _project.VideoLinks.Add(_newVideoLink.Trim());
        _newVideoLink = "";
    }

    async Task AddVideoLinkAndSave()
    {
        if (string.IsNullOrWhiteSpace(_newVideoLink) || _project == null) return;
        if (!_project.VideoLinks.Contains(_newVideoLink.Trim()))
            _project.VideoLinks.Add(_newVideoLink.Trim());
        _newVideoLink = "";
        await Save();
    }

    async Task RemoveVideoLink(string link)
    {
        if (_project == null) return;
        _project.VideoLinks.Remove(link);
        await Save();
    }

    void OnEditAddYarn(ChangeEventArgs e)
    {
        if (_project == null) return;
        var val = e.Value?.ToString();
        if (string.IsNullOrEmpty(val)) return;
        var yarnId = Guid.Parse(val);
        if (!_project.YarnUsages.Any(u => u.YarnId == yarnId))
            _project.YarnUsages.Add(new ProjectYarnUsage { YarnId = yarnId, BallsUsed = 1 });
    }

    async Task SaveEdit()
    {
        await Save();
        // 스와치 연결 변경사항 저장
        foreach (var s in _allSwatches)
            await Storage.SaveSwatchAsync(s);
        // 연결된 스와치 목록 갱신
        _linkedSwatches = _allSwatches.Where(s => s.ProjectId == _project!.Id).ToList();
        _swatchSnapshotPD = null;
        _editSnapshot = null;
        CloseEditModal();
    }

    void ToggleSwatchLink(Swatch s)
    {
        if (s.ProjectId == _project!.Id)
            s.ProjectId = null;
        else
            s.ProjectId = _project.Id;
    }

    void OnSwatchSelectChange(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        if (string.IsNullOrEmpty(val) || _project == null) return;
        if (!Guid.TryParse(val, out var swatchId)) return;
        var swatch = _allSwatches.FirstOrDefault(s => s.Id == swatchId);
        if (swatch == null) return;
        // 기존 연결 스와치 해제 (단일 연결)
        foreach (var s in _allSwatches.Where(s => s.ProjectId == _project.Id))
            s.ProjectId = null;
        swatch.ProjectId = _project.Id;
    }

    void UnlinkSwatch(Swatch s)
    {
        s.ProjectId = null;
    }

    async Task Save()
    {
        if (_project != null)
            await Storage.SaveProjectAsync(_project);
    }
}
