@inherits LayoutComponentBase
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="app-shell">
    <nav class="sidebar">
        <div class="sidebar-brand">
            <span class="brand-icon">🧶</span>
            <span class="brand-name">니트로그</span>
        </div>

        <ul class="nav-list">
            <li><NavLink href="" Match="NavLinkMatch.All" class="nav-item"><span class="nav-icon">🏠</span><span class="nav-label">홈</span></NavLink></li>
            <li><NavLink href="schedule" class="nav-item"><span class="nav-icon">📆</span><span class="nav-label">뜨케줄</span></NavLink></li>
            <li><NavLink href="finished" class="nav-item"><span class="nav-icon">✅</span><span class="nav-label">완성작</span></NavLink></li>
            <li><NavLink href="wishlist" class="nav-item"><span class="nav-icon">💫</span><span class="nav-label">위시리스트</span></NavLink></li>
            <li><NavLink href="yarns" class="nav-item"><span class="nav-icon">🧵</span><span class="nav-label">실 창고</span></NavLink></li>
            <li><NavLink href="swatches" class="nav-item"><span class="nav-icon">🧪</span><span class="nav-label">스와치</span></NavLink></li>
            <li><NavLink href="tools" class="nav-item"><span class="nav-icon">⚒️</span><span class="nav-label">도구</span></NavLink></li>
            <li><NavLink href="stats" class="nav-item"><span class="nav-icon">📊</span><span class="nav-label">통계</span></NavLink></li>
            <li><NavLink href="settings" class="nav-item"><span class="nav-icon">⚙️</span><span class="nav-label">설정</span></NavLink></li>
        </ul>

        <!-- 사이드바 하단 통계 -->
        <div class="sidebar-stats">
            <div class="sidebar-stat-row">
                <span>✅ 완성작</span>
                <strong>@(_finished)개</strong>
            </div>
            <div class="sidebar-stat-row">
                <span>⏱️ 총 시간</span>
                <strong>@(_hours)h</strong>
            </div>
            <div class="sidebar-dark-toggle" @onclick="ToggleDark" title="@(_isDark ? "라이트 모드" : "다크 모드")">
                @(_isDark ? "☀️" : "🌙")
            </div>
        </div>

        <!-- 테마 선택 -->
        <div class="theme-picker">
            <div class="theme-picker-label">테마</div>
            <div class="theme-dots">
                @foreach (var t in _themes)
                {
                    <button class="theme-dot @(_currentTheme == t.Id ? "active" : "")"
                            style="background:@t.DotColor;"
                            title="@t.Name"
                            @onclick="() => SetTheme(t.Id)">
                    </button>
                }
            </div>
        </div>
    </nav>

    <main class="main-content">@Body</main>

    <nav class="bottom-nav">
        <NavLink href="" Match="NavLinkMatch.All" class="bottom-nav-item">
            <span class="bottom-nav-icon">🏠</span><span class="bottom-nav-label">홈</span>
        </NavLink>
        <NavLink href="swatches" class="bottom-nav-item">
            <span class="bottom-nav-icon">🧪</span><span class="bottom-nav-label">스와치</span>
        </NavLink>
        <NavLink href="tools" class="bottom-nav-item">
            <span class="bottom-nav-icon">⚒️</span><span class="bottom-nav-label">도구</span>
        </NavLink>
        <NavLink href="settings" class="bottom-nav-item">
            <span class="bottom-nav-icon">⚙️</span><span class="bottom-nav-label">설정</span>
        </NavLink>
    </nav>
</div>

@code {
    record ThemeOption(string Id, string Name, string DotColor);
    readonly List<ThemeOption> _themes = new()
    {
        new("green",  "연두", "#c8e6be"),
        new("yellow", "노랑", "#fffdc7"),
        new("sky",    "하늘", "#d3f4ff"),
        new("pink",   "분홍", "#ffe7e7"),
        new("purple", "보라", "#e9e1ff"),
    };

    string _currentTheme = "green";
    bool _isDark = false;
    int _finished;
    double _hours;

    protected override async Task OnInitializedAsync()
    {
        var projects = await Storage.GetProjectsAsync();
        _finished = projects.Count(p => p.Status == ProjectStatus.완료);
        var secs = projects.SelectMany(p => p.Sessions)
            .Where(s => s.EndTime.HasValue)
            .Sum(s => (int)((s.EndTime!.Value - s.StartTime).TotalSeconds));
        _hours = Math.Round(secs / 3600.0, 1);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string?>("localStorage.getItem", "knitlog_theme");
            if (!string.IsNullOrEmpty(theme)) _currentTheme = theme;
            var dark = await JS.InvokeAsync<string?>("localStorage.getItem", "knitlog_dark");
            _isDark = dark == "true";
            await ApplyTheme(_currentTheme);
            await ApplyDark(_isDark);
            StateHasChanged();
        }
    }

    async Task SetTheme(string id)
    {
        _currentTheme = id;
        await JS.InvokeVoidAsync("localStorage.setItem", "knitlog_theme", id);
        await ApplyTheme(id);
    }

    async Task ToggleDark()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("localStorage.setItem", "knitlog_dark", _isDark.ToString().ToLower());
        await ApplyDark(_isDark);
    }

    async Task ApplyTheme(string id) =>
        await JS.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-theme','{id}')");

    async Task ApplyDark(bool dark) =>
        await JS.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-dark','{dark.ToString().ToLower()}')");

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
