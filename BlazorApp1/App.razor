@* App.razor *@
<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(KnitLog.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>페이지를 찾을 수 없어요</PageTitle>
        <LayoutView Layout="@typeof(KnitLog.Layout.MainLayout)">
            <div class="empty-state">
                <div class="empty-icon">🧶</div>
                <p>페이지를 찾을 수 없어요.</p>
                <a href="" class="btn btn-primary mt-2">홈으로</a>
            </div>
        </LayoutView>
    </NotFound>
</Router>
